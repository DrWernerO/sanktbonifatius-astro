# Zugangsdaten für den Mailversand des Taufe-Anmeldeformulars.
# Diese Datei als ".env" kopieren und ausfüllen (nur für lokalen Test). Die echte .env
# NIE committen (steht in .gitignore). Werte kommen vom All-inkl-Postfach (kasserver.com).
#
# PRODUKTIV: Diese Werte liegen als Environment-Variablen in NETLIFY
# (Site configuration → Environment variables), NICHT im Repo. Absender ist das
# Funktionspostfach formular@mail.sanktbonifatius.de (All-inkl). Läuft live seit 2026-07.

# SMTP-Server des Postfachs
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Absender (= Funktionspostfach) und Empfänger (durch Komma getrennt)
SMTP_FROM=formular@mail.sanktbonifatius.de
TAUFE_TO=pfarrer@sanktbonifatius.de, info@sanktbonifatius.de, w.otto@sanktbonifatius.de
