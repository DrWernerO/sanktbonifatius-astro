# Zugangsdaten für den Mailversand des Taufe-Anmeldeformulars.
# Diese Datei als ".env" kopieren und ausfüllen. Die echte .env NIE committen
# (steht in .gitignore). Werte kommen vom All-inkl-Postfach (kasserver.com).

# SMTP-Server des Postfachs
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Absender (meist gleich SMTP_USER) und Empfänger (durch Komma getrennt)
SMTP_FROM=info@sanktbonifatius.de
TAUFE_TO=pfarrer@sanktbonifatius.de, info@sanktbonifatius.de, w.otto@sanktbonifatius.de
