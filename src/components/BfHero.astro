---
// Hero der Seite „BonFamily" — WP-Seite 45898 (/bonfamily/).
// Eigene Klassen `astro-bfhero` (goldene Regel — niemals WP-Klassen `bf-hero`).
// Full-Bleed-Bild + Verlauf-Overlay + H1 + 2 Buttons. Bild lokal unter public/uploads/.
const bg = '/uploads/2026/04/bonfamily-hero.jpg';
---
<section class="astro-bfhero">
  <div class="astro-bfhero__bg" role="img"
       aria-label="Familien und Kinder beim BonFamily-Programm der Pfarrei Sankt Bonifatius"
       style={`background-image:url('${bg}')`}></div>
  <div class="astro-bfhero__overlay"></div>
  <div class="astro-bfhero__inner">
    <span class="astro-bfhero__badge">Familien &amp; Kinder in Frankfurt-Sachsenhausen</span>
    <h1 class="astro-bfhero__title">Herzlich<br>willkommen<br>bei <span class="astro-bfhero__accent">BonFamily</span></h1>
    <p class="astro-bfhero__sub">
      Das bunte Familien- und Kinderprogramm der Pfarrei &ndash; f&uuml;r Babys,
      Kleinkinder, Schulkinder und Eltern. Offen f&uuml;r alle!
    </p>
    <div class="astro-bfhero__btns">
      <a href="#bonfamily-termine" class="astro-bfhero__btn astro-bfhero__btn--primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        Nächste Termine
      </a>
      <a href="https://whatsapp.com/channel/0029VbB7E1CLikgAZ8cyHk1a"
         target="_blank" rel="noopener"
         class="astro-bfhero__btn astro-bfhero__btn--outline">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        WhatsApp-Kanal
      </a>
    </div>
  </div>
</section>

<style is:global>
.astro-bfhero{position:relative;width:100vw;left:50%;margin-left:-50vw;margin-right:-50vw;min-height:580px;display:flex;align-items:flex-end;overflow:hidden}
.astro-bfhero__bg{position:absolute;inset:0;background-size:cover;background-position:center 40%}
.astro-bfhero__overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(30,21,18,.08) 0%,rgba(30,21,18,.45) 55%,rgba(30,21,18,.88) 100%)}
.astro-bfhero__inner{position:relative;z-index:2;width:100%;max-width:1280px;margin:0 auto;padding:0 40px 64px;color:#f0e8d8}
.astro-bfhero__badge{display:inline-block;background:#9a2d2d;color:#fff;font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:5px 14px;border-radius:50px;margin:0 0 20px}
.astro-bfhero__accent{color:#9a2d2d}
.astro-bfhero__title{font-family:'Playfair Display',Georgia,serif;font-size:clamp(34px,5vw,66px);color:#fff;margin:0 0 16px;line-height:1.08;font-weight:700}
.astro-bfhero__sub{color:rgba(255,255,255,.88);font-size:clamp(16px,2vw,20px);margin:0 0 32px;max-width:620px;line-height:1.5}
.astro-bfhero__btns{display:flex;gap:12px;flex-wrap:wrap}
.astro-bfhero__btn{display:inline-flex;align-items:center;gap:8px;padding:12px 26px;border-radius:50px;font-size:14px;font-weight:600;text-decoration:none;transition:background .18s,color .18s,border-color .18s}
.astro-bfhero__btn--primary{background:#9a2d2d;color:#fff;border:2px solid #9a2d2d}
.astro-bfhero__btn--primary:hover{background:#7e2424;border-color:#7e2424}
.astro-bfhero__btn--outline{background:rgba(255,255,255,.12);color:#fff;border:2px solid rgba(255,255,255,.5);backdrop-filter:blur(4px)}
.astro-bfhero__btn--outline:hover{background:rgba(255,255,255,.22);border-color:#fff}
@media(max-width:600px){.astro-bfhero{min-height:500px}.astro-bfhero__inner{padding:0 20px 44px}.astro-bfhero__btns{flex-direction:column;gap:10px}.astro-bfhero__btn{justify-content:center}}
</style>
