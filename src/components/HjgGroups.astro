---
// Gruppenübersicht Herz Jesu — WP-Design-Klon (sw-karte-Muster mit rotem Gradient-Header).
// Eigene Klassen astro-hjg. Struktur: Willkommen-Sektion (pink) + Karten-Sektion (weiß).
const GROUPS = [
  {
    name: 'Kreativ-Werkstatt',
    time: 'Jeden Mittwoch · 18:30–21:00 Uhr',
    text: 'In der Kreativ-Werkstatt sind alle willkommen, die Freude daran haben, in der Gruppe kreativ zu sein. Ob häkeln, stricken, nähen oder basteln – gemeinsam und bei einem kleinen Plausch macht es viel mehr Spaß. Auch Anfänger sind herzlich willkommen.',
    contact: 'Ines Walter',
    mail: 'kreativ_Herz-Jesu@web.de',
    icon: '<path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/>',
  },
  {
    name: 'Projektchor',
    time: 'Proben nach Ankündigung',
    text: 'Der Projektchor findet sich zusammen, um mehrstimmige traditionelle und neue Chormusik zu proben und im Gottesdienst zu singen. Er ist maßgeblich beteiligt beim jährlichen Adventskonzert der Reihe „Hörbar Herz Jesu". Sängerinnen und Sänger sind herzlich willkommen.',
    contact: 'Johanna Zerlik',
    mail: 'jzerlik@hotmail.com',
    icon: '<path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>',
  },
  {
    name: 'Oberräder Pfadfinder DPSG',
    time: 'Jeden Freitag · 17:30–19:00 Uhr',
    text: 'Seit mehr als 50 Jahren sind die Oberräder Pfadfinder ein fester Teil von Oberrad. Junge Menschen erleben Abenteuer, Gemeinschaft und lernen Verantwortung für sich, ihre Mitmenschen und die Umwelt zu übernehmen.',
    note: 'Pfarrgarten & Kellerräume · Mathildenstr. 30a',
    icon: '<circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>',
  },
  {
    name: 'Biotop Herz Jesu',
    time: 'Treffs & Aktionen nach Ankündigung',
    text: 'Was blüht, krabbelt und fliegt rund um unseren Kirchturm? Turmfalken, Fledermäuse, Bienen? Wer Lust hat, sich aktiv oder spirituell im Sinne von „Laudato Si" zu engagieren, ist bei unseren Treffs herzlich willkommen.',
    contact: 'Gabi Huckelmann',
    mail: 'biotop-herzjesu@outlook.de',
    icon: '<path d="M17 8C8 10 5.9 16.17 3.82 19.32"/><path d="M21 12c-1-4-4-6-8-6"/><path d="M12 19c3-2 6-5 7-9"/><path d="M8 15c.5-2 2-3.5 4-4"/>',
  },
  {
    name: 'Kirchcafé-Team',
    time: 'Sonntags nach dem Gottesdienst',
    text: 'Nach dem 9:30-Uhr-Gottesdienst findet unser Kirchcafé statt – im Sommer im Kirchgarten, ansonsten hinten in der Kirche. Das Team sorgt für eine herzliche Atmosphäre zum zwanglosen Miteinander. Einfach vorbeikommen!',
    contact: 'Marie Gathof',
    icon: '<path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>',
  },
  {
    name: 'Gemeindeentwicklung',
    time: 'Treffen nach Vereinbarung',
    text: 'Wer sind wir? Wie schauen wir in die Zukunft? Die Gruppe trifft sich regelmäßig zum Austausch über gesellschaftliche und kirchenstrukturelle Veränderungen – und um gemeinsam die Zukunft von Herz Jesu zu gestalten. Mitmachen ist ausdrücklich erwünscht.',
    contact: 'Annette Albert-Zerlik',
    mail: 'azerlik@web.de',
    icon: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  },
  {
    name: 'Messdienergruppe',
    time: 'Sonntagsgottesdienst · 9:30 Uhr',
    text: 'Unsere Messdienerinnen und Messdiener gestalten die Gottesdienste aktiv mit und übernehmen dabei wichtige Aufgaben am Altar. Kinder und Jugendliche, die mitmachen möchten, sind herzlich eingeladen.',
    icon: '<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>',
  },
  {
    name: 'Ökumeneausschuss',
    time: 'Gemeinsame Aktionen im Jahr',
    text: 'Herz Jesu und die Erlösergemeinde in Oberrad sind eng ökumenisch verbunden. „Auf Geht\'s" – in Kleingruppen auf den Weg zum besseren Kennenlernen von Glauben und Konfessionen. Vier Mal im Jahr werden gegenseitig Gottesdienste besucht.',
    icon: '<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>',
  },
  {
    name: 'Partnerschaft Tabenken',
    time: 'Weltkirche & Solidarität',
    text: 'Herz Jesu pflegt eine besondere Partnerschaft mit der Gemeinde in Tabenken. Diese Verbindung lebt durch gegenseitigen Austausch, Solidarität und gelebte Weltkirche.',
    icon: '<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>',
  },
];
---

<section class="astro-hjg__welcome">
  <div class="astro-hjg__inner">
    <div class="astro-hjg__head">
      <h2 id="mitmachen-immer-willkommen">Mitmachen &ndash; immer willkommen</h2>
      <p>Von Kreativem über Naturschutz bis zu Pfadfindern: In Herz&nbsp;Jesu gibt es lebendige Gruppen für alle. Schauen Sie einfach vorbei &ndash; ein erstes Kennenlernen ist völlig unverbindlich.</p>
    </div>
  </div>
</section>

<section class="astro-hjg__karten" id="gruppen">
  <div class="astro-hjg__inner">
    <div class="astro-hjg__head">
      <h2 id="die-gruppen-in-herz-jesu">Die Gruppen in Herz&nbsp;Jesu</h2>
      <p>Neun Gruppen, ein Ort, viele M&ouml;glichkeiten.</p>
    </div>
    <div class="astro-hjg__grid">
      {GROUPS.map((g) => (
        <div class="astro-hjg__karte">
          <div class="astro-hjg__kopf">
            <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={g.icon}></svg>
            <div>
              <div class="astro-hjg__titel">{g.name}</div>
              <div class="astro-hjg__wann">{g.time}</div>
            </div>
          </div>
          <div class="astro-hjg__body">
            <p class="astro-hjg__text">{g.text}</p>
            {(g.contact || g.note) && (
              <div class="astro-hjg__kontakt">
                {g.contact && <span>{g.contact}</span>}
                {g.mail && <Fragment> &middot; <a href={`mailto:${g.mail}`}>{g.mail}</a></Fragment>}
                {g.note && <span>{g.note}</span>}
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
/* Willkommen-Sektion */
.astro-hjg__welcome{background:#fdf0f0;text-align:center;padding:56px 24px;width:100vw;margin-left:calc(50% - 50vw);margin-right:calc(50% - 50vw);box-sizing:border-box}
/* Karten-Sektion */
.astro-hjg__karten{background:#fff;padding:56px 24px;width:100vw;margin-left:calc(50% - 50vw);margin-right:calc(50% - 50vw);box-sizing:border-box}
/* Gemeinsam */
.astro-hjg__inner{max-width:1200px;margin:0 auto}
.astro-hjg__head{text-align:center;max-width:720px;margin:0 auto 32px}
.astro-hjg__head h2{font-family:'Playfair Display',Georgia,serif;font-size:clamp(26px,4vw,40px);font-weight:700;color:#2c2420;margin:0 0 12px;line-height:1.15}
.astro-hjg__head p{font-size:17px;color:#5a4430;margin:0}
/* Karten-Grid */
.astro-hjg__grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:24px}
/* Einzelne Karte */
.astro-hjg__karte{background:#fff;border-radius:14px;box-shadow:0 2px 16px rgba(145,0,3,.09);overflow:hidden;display:flex;flex-direction:column}
/* Roter Kopf */
.astro-hjg__kopf{background:linear-gradient(135deg,#910003 0%,#6e0002 100%);padding:24px 24px 18px;display:flex;align-items:flex-start;gap:14px;min-height:100px}
.astro-hjg__kopf svg{width:34px;height:34px;flex-shrink:0;opacity:.9;margin-top:2px}
.astro-hjg__titel{font-family:'Playfair Display',Georgia,serif;font-size:1.1rem;font-weight:700;color:#fff;line-height:1.25}
.astro-hjg__wann{font-size:.75rem;color:#f0c0c0;letter-spacing:.06em;text-transform:uppercase;margin-top:3px}
/* Karten-Inhalt */
.astro-hjg__body{padding:20px 24px 24px;flex:1;display:flex;flex-direction:column;gap:12px}
.astro-hjg__text{font-size:.95rem;color:#3d3530;line-height:1.65;margin:0;flex:1}
.astro-hjg__kontakt{font-size:.85rem;color:#666;border-top:1px solid #f0e0e0;padding-top:12px}
.astro-hjg__kontakt a{color:#910003;text-decoration:none;font-weight:600}
.astro-hjg__kontakt a:hover{text-decoration:underline}
@media(max-width:600px){.astro-hjg__grid{grid-template-columns:1fr}.astro-hjg__welcome,.astro-hjg__karten{padding:40px 20px}}
</style>
