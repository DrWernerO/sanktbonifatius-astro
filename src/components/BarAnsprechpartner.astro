---
// „Ansprechpartner" der Barrierefreiheit-Seite (WP 49119). Eigene Klassen `astro-bar-asp`.
const MAIL = 'info@sanktbonifatius.de';
---
<section class="astro-bar-asp">
  <div class="astro-bar-asp__inner">
    <div class="astro-bar-asp__card">
      <h2 class="astro-bar-asp__hl">Ansprechpartner</h2>
      <p class="astro-bar-asp__txt">
        Ansprechpartner und Ansprechpartnerinnen rund um Veranstaltungen und Reservierung der
        mobilen Rampen finden Sie in unserem Pfarrbüro. Wenn Sie auf Barrieren stoßen oder
        Vorschläge für mehr Barrierefreiheit sowie eine bessere Beschreibung und Bebilderung haben,
        können Sie uns das gerne über unser Pfarrbüro mitteilen. Eines unserer nächsten Vorhaben ist
        die digitale Barrierefreiheit unserer Gemeindehomepage. Kennen Sie sich damit aus und würden
        Sie uns unterstützen?
      </p>
      <a class="astro-bar-asp__btn" href={`mailto:${MAIL}`}>Pfarrbüro kontaktieren</a>
    </div>
  </div>
</section>

<style is:global>
.astro-bar-asp{background:#f7f3ef;padding:56px 0}
.astro-bar-asp__inner{max-width:840px;margin:0 auto;padding:0 40px}
.astro-bar-asp__card{background:#fff;border:1px solid #e0d8cf;border-left:4px solid #9a2d2d;border-radius:14px;padding:32px 34px;box-shadow:0 4px 20px rgba(30,21,18,.06)}
.astro-bar-asp__hl{font-family:'Playfair Display',serif;font-size:clamp(22px,2.8vw,30px);font-weight:700;color:#2c2420;margin:0 0 14px}
.astro-bar-asp__txt{font-size:16px;color:#3d3530;line-height:1.7;margin:0 0 22px}
.astro-bar-asp__btn{display:inline-block;padding:12px 26px;border-radius:50px;background:#9a2d2d;color:#fff;font-size:14px;font-weight:600;transition:background .2s}
.astro-bar-asp__btn:hover{background:#7e2424}
@media(max-width:600px){.astro-bar-asp{padding:40px 0}.astro-bar-asp__inner{padding:0 20px}.astro-bar-asp__card{padding:24px 22px}}
</style>
