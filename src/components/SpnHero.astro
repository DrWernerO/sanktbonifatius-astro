---
// Hero der Spendenseite (/spenden/) — Inhalte 1:1 aus der Live-Seite (www, /spenden/).
// Eigene Klassen `astro-spn-hero`. Foto-Hero (Spenden-Motiv) als echtes <img> + abdunkelnder
// Verlauf (Muster wie FinHero → Bild-SEO + verlässlich). Bild liegt unter public/uploads/.
// Neben „Projekte ansehen" verweist ein zweiter Link bereits hier oben auf die Bankverbindung
// (#ueberweisung), wie vom Pfarrbüro gewünscht.
const HERO = '/uploads/2023/07/Spenden.jpg';
---
<section class="astro-spn-hero">
  <img class="astro-spn-hero__img" src={HERO} alt="Spenden für die Pfarrei Sankt Bonifatius Frankfurt" loading="eager" />
  <div class="astro-spn-hero__inner">
    <p class="astro-spn-hero__eyebrow">Danke für Ihre Unterstützung</p>
    <h1 class="astro-spn-hero__title">Spenden für die Pfarrei Sankt Bonifatius Frankfurt</h1>
    <p class="astro-spn-hero__sub">
      Mit Ihrer Online-Spende oder per Überweisung unterstützen Sie die (sozial-)pastoralen
      Projekte unserer katholischen Pfarrei in Frankfurt-Sachsenhausen und die von uns
      geförderten Hilfsprojekte.
    </p>
    <div class="astro-spn-hero__btns">
      <a class="astro-spn-hero__btn" href="#projekte">Projekte ansehen →</a>
      <a class="astro-spn-hero__btn astro-spn-hero__btn--ghost" href="#ueberweisung">Lieber überweisen? →</a>
    </div>
  </div>
</section>

<style is:global>
.astro-spn-hero{position:relative;width:100vw;left:50%;margin-left:-50vw;margin-right:-50vw;display:flex;align-items:flex-end;min-height:520px;overflow:hidden;color:#fff}
.astro-spn-hero__img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;z-index:0}
.astro-spn-hero::after{content:"";position:absolute;inset:0;z-index:1;background:linear-gradient(180deg,rgba(40,20,12,.30) 0%,rgba(40,20,12,.55) 50%,rgba(40,20,12,.90) 100%)}
.astro-spn-hero__inner{position:relative;z-index:2;max-width:1200px;width:100%;margin:0 auto;padding:120px 40px 56px;box-sizing:border-box}
.astro-spn-hero__eyebrow{font-family:'Playfair Display',serif;font-style:italic;font-size:14px;letter-spacing:.06em;text-transform:uppercase;color:#f0cf8f;margin:0 0 14px;font-weight:700}
.astro-spn-hero__title{font-family:'Playfair Display',serif;font-weight:700;line-height:1.05;color:#fff;font-size:clamp(34px,5vw,60px);margin:0;letter-spacing:-.01em}
.astro-spn-hero__sub{font-size:clamp(16px,1.9vw,20px);color:rgba(255,255,255,.92);line-height:1.55;margin:18px 0 28px;max-width:640px}
.astro-spn-hero__btns{display:flex;gap:14px;flex-wrap:wrap}
.astro-spn-hero__btn{display:inline-block;padding:14px 30px;border-radius:50px;background:#fff;color:#7e2424;font-size:15px;font-weight:600;transition:transform .15s,background .2s}
.astro-spn-hero__btn:hover{transform:translateY(-1px);background:#fbeede}
.astro-spn-hero__btn--ghost{background:transparent;color:#fff;border:1.5px solid rgba(255,255,255,.55)}
.astro-spn-hero__btn--ghost:hover{background:rgba(255,255,255,.12)}
@media(max-width:600px){.astro-spn-hero{min-height:440px}.astro-spn-hero__inner{padding:96px 20px 40px}}
</style>
