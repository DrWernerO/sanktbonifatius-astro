---
// "Aktuelles" auf der Startseite: Beiträge (posts) + News (pin) gemischt, nach Datum.
// Daten via getAktuelles(); Galerie/Video bekommen ein SVG-Badge (kein Emoji, UI-Regel).
import { getAktuelles } from '../lib/wordpress.js';
const { limit = 3 } = Astro.props;
const items = await getAktuelles(limit);
const fmt = (iso) => new Date(iso).toLocaleDateString('de-DE', { day: 'numeric', month: 'long', year: 'numeric' });
---

{items.length > 0 && (
<section class="astro-news">
  <div class="astro-news__inner">
    <div class="astro-news__head">
      <h2 class="astro-news__hl">Aktuelles</h2>
      <a href="/boniblog/" class="astro-news__more">Alle Beiträge →</a>
    </div>
    <div class="astro-news__grid">
      {items.map((it) => (
        <a href={it.link} class="astro-nc" data-news-id={it.kind === 'news' ? it.id : undefined}>
          <div class="astro-nc__media">
            {it.image
              ? <img class="astro-nc__img" src={it.image} alt={it.title} loading="lazy" />
              : <div class="astro-nc__img astro-nc__img--placeholder"></div>}
            {it.type === 'video' && (
              <span class="astro-nc__badge" aria-label="Video">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
                Video
              </span>
            )}
            {it.type === 'gallery' && (
              <span class="astro-nc__badge" aria-label="Fotogalerie">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="14" height="14" rx="2"/><path d="M21 7v12a2 2 0 0 1-2 2H7"/></svg>
                {it.galleryCount > 0 ? it.galleryCount + ' Fotos' : 'Galerie'}
              </span>
            )}
          </div>
          <div class="astro-nc__body">
            <p class="astro-nc__date">{fmt(it.date)}</p>
            <h3 class="astro-nc__title" set:html={it.title} />
            {it.excerpt && <p class="astro-nc__excerpt" set:html={it.excerpt} />}
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
)}

<style is:global>
.astro-news{background:#fff;padding:28px 0;width:100vw;position:relative;left:50%;margin-left:-50vw;margin-right:-50vw}
.astro-news__inner{max-width:1200px;margin:0 auto;padding:0 40px}
.astro-news__head{display:flex;align-items:baseline;justify-content:space-between;margin:0 0 32px}
.astro-news__hl{font-family:'Playfair Display',serif;font-size:28px;font-weight:700;color:#2c2420}
.astro-news__more{font-size:13px;color:#928269;text-decoration:none;letter-spacing:.05em}
.astro-news__more:hover{color:#2c2420}
.astro-news__grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.astro-nc{display:block;border-radius:10px;overflow:hidden;background:#f7f3ef;text-decoration:none;color:#2c2420;transition:transform .2s,box-shadow .2s;box-shadow:0 2px 12px rgba(30,21,18,.06)}
.astro-nc:hover{transform:translateY(-3px);box-shadow:0 6px 20px rgba(30,21,18,.12)}
.astro-nc__media{position:relative}
.astro-nc__img{width:100%;height:180px;object-fit:cover;display:block}
.astro-nc__img--placeholder{background:#ede8e1}
.astro-nc__badge{position:absolute;top:10px;left:10px;display:inline-flex;align-items:center;gap:5px;background:rgba(44,36,32,.82);color:#fff;font-size:11px;font-weight:600;letter-spacing:.02em;padding:4px 9px;border-radius:50px;backdrop-filter:blur(2px)}
.astro-nc__badge svg{display:block}
.astro-nc__body{padding:20px 22px}
.astro-nc__date{font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:#928269;margin:0 0 8px}
.astro-nc__title{font-family:'Playfair Display',serif;font-size:17px;font-weight:700;line-height:1.3;color:#2c2420;margin:0 0 10px}
.astro-nc__body p{font-size:14px;color:#6b5c52;line-height:1.55;margin:0;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}
@media(max-width:860px){.astro-news__grid{grid-template-columns:1fr 1fr}}
@media(max-width:600px){.astro-news__grid{grid-template-columns:1fr}.astro-news__inner{padding:0 20px}}
</style>
