---
// Hero der Unterseite „Offener Kühlschrank" — WP-Seite 49123 (/engagiert-leben/offener-kuehlschrank/).
// Eigene Klassen `astro-okhero` (goldene Regel — niemals WP-Klassen `ok-…`). Muster SegenHero/BfHero.
// Full-Bleed-Bild + Verlauf-Overlay + Eyebrow + H1 + Sub + 2 Buttons. Bild lokal unter public/uploads/.
const bg = '/uploads/2023/07/foodworkshop-2.jpg';
---
<section class="astro-okhero">
  <div class="astro-okhero__bg" role="img"
       aria-label="Offener K&uuml;hlschrank zum Lebensmittel teilen in der Kirche St. Aposteln, Frankfurt-Sachsenhausen"
       style={`background-image:url('${bg}')`}></div>
  <div class="astro-okhero__overlay"></div>
  <div class="astro-okhero__inner">
    <p class="astro-okhero__eyebrow">Sozialpastoral &middot; Kirche St. Aposteln &middot; Frankfurt-Sachsenhausen</p>
    <h1 class="astro-okhero__title">Offener K&uuml;hlschrank</h1>
    <p class="astro-okhero__sub">
      Lebensmittel teilen in Frankfurt &#8211; kostenlos abgeben und mitnehmen. F&uuml;r alle, ohne Bedingungen.
    </p>
    <div class="astro-okhero__btns">
      <a href="#standort" class="astro-okhero__btn astro-okhero__btn--primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        Zum Standort
      </a>
      <a href="#mitmachen" class="astro-okhero__btn astro-okhero__btn--outline">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
        Wie es funktioniert
      </a>
    </div>
  </div>
</section>

<style is:global>
.astro-okhero{position:relative;width:100vw;left:50%;margin-left:-50vw;margin-right:-50vw;min-height:560px;display:flex;align-items:flex-end;overflow:hidden}
.astro-okhero__bg{position:absolute;inset:0;background-size:cover;background-position:center 45%}
.astro-okhero__overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(30,21,18,.10) 0%,rgba(30,21,18,.46) 58%,rgba(30,21,18,.86) 100%)}
.astro-okhero__inner{position:relative;z-index:2;width:100%;max-width:1280px;margin:0 auto;padding:0 40px 60px;color:#f0e8d8}
.astro-okhero__eyebrow{font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:#c5a55a;margin:0 0 14px;font-weight:600}
.astro-okhero__title{font-family:'Playfair Display',Georgia,serif;font-size:clamp(36px,5vw,68px);color:#fff;margin:0 0 16px;line-height:1.08;font-weight:700}
.astro-okhero__sub{color:rgba(255,255,255,.9);font-size:clamp(16px,2vw,21px);margin:0 0 32px;max-width:620px;line-height:1.5}
.astro-okhero__btns{display:flex;gap:12px;flex-wrap:wrap}
.astro-okhero__btn{display:inline-flex;align-items:center;gap:8px;padding:13px 28px;border-radius:50px;font-size:15px;font-weight:600;text-decoration:none;transition:background .18s,color .18s,border-color .18s}
.astro-okhero__btn--primary{background:#9a2d2d;color:#fff;border:2px solid #9a2d2d}
.astro-okhero__btn--primary:hover{background:#7e2424;border-color:#7e2424}
.astro-okhero__btn--outline{background:rgba(255,255,255,.12);color:#fff;border:2px solid rgba(255,255,255,.5);backdrop-filter:blur(4px)}
.astro-okhero__btn--outline:hover{background:rgba(255,255,255,.22);border-color:#fff}
@media(max-width:600px){.astro-okhero{min-height:480px}.astro-okhero__inner{padding:0 20px 44px}.astro-okhero__btns{flex-direction:column;gap:10px}.astro-okhero__btn{justify-content:center}}
</style>
