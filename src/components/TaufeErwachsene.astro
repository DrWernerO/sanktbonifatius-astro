---
// „Als Erwachsener getauft werden" (WP-Block, Anker `ta-erwachsene`). Eigene Klassen
// `astro-taerw`. id="erwachsene" für die CTA-Sprungmarke aus den Schritten. Feste Inhalte.
const tel = '+4969695975850';
const telLabel = '069 695 97 58 50';
---
<section class="astro-taerw" id="erwachsene">
  <div class="astro-taerw__inner">
    <h2 class="astro-taerw__hl">Als Erwachsener getauft werden</h2>
    <p class="astro-taerw__lead">Der Weg in die Kirche ist auch als Erwachsener jederzeit möglich.</p>
    <p class="astro-taerw__text">
      Wenn Sie als Erwachsener getauft werden oder in die katholische Kirche aufgenommen werden
      möchten, begleiten wir Sie persönlich und individuell. Es gibt keine Altersbeschränkung und
      keinen festen Termin, mit dem Sie beginnen müssen. Wir bieten Orientierungsgespräche,
      Glaubenskurse und &#8211; wenn Sie es wünschen &#8211; die feierliche Aufnahme in unsere
      Gemeinschaft. Sprechen Sie uns einfach an.
    </p>
    <div class="astro-taerw__actions">
      <a class="astro-taerw__btn" href="mailto:info@sanktbonifatius.de?subject=Erwachsenentaufe%20%E2%80%93%20Informationen">Ich möchte mehr Informationen &#8594;</a>
      <a class="astro-taerw__tel" href={`tel:${tel}`}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        {telLabel}
      </a>
    </div>
  </div>
</section>

<style is:global>
.astro-taerw{position:relative;width:100vw;left:50%;margin-left:-50vw;margin-right:-50vw;background:linear-gradient(135deg,#2c1a14 0%,#3a241b 60%,#1f130d 100%);color:#f0e8d8;padding:76px 0;overflow:hidden}
.astro-taerw::after{content:"";position:absolute;inset:0;background:radial-gradient(circle at 80% 0%,rgba(197,165,90,.16),transparent 55%)}
.astro-taerw__inner{position:relative;z-index:1;max-width:820px;margin:0 auto;padding:0 40px;text-align:center}
.astro-taerw__hl{font-family:'Playfair Display',serif;font-size:clamp(26px,3.4vw,40px);font-weight:700;color:#fff;margin:0 0 14px}
.astro-taerw__lead{font-size:clamp(17px,2vw,21px);color:#e8c98a;margin:0 0 18px}
.astro-taerw__text{font-size:clamp(15px,1.7vw,17px);color:#e8ddc9;line-height:1.7;margin:0 auto 30px;max-width:680px}
.astro-taerw__actions{display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:22px}
.astro-taerw__btn{display:inline-block;padding:14px 28px;border-radius:50px;background:#9a2d2d;color:#fff;font-size:15px;font-weight:600;transition:background .2s}
.astro-taerw__btn:hover{background:#7e2424}
.astro-taerw__tel{display:inline-flex;align-items:center;gap:10px;color:#f0e8d8;font-size:16px;font-weight:600}
.astro-taerw__tel svg{width:20px;height:20px;color:#c5a55a}
.astro-taerw__tel:hover{color:#fff}
@media(max-width:600px){.astro-taerw{padding:56px 0}.astro-taerw__inner{padding:0 20px}}
</style>
