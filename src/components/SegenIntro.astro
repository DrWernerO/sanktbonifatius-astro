---
// Intro + Zitat der Seite „Segen und Sakramente" (WP-Blöcke `ss-intro` + `ss-quote`).
// Eigene Klassen `astro-ssintro`. Feste Inhalte.
---
<section class="astro-ssintro">
  <div class="astro-ssintro__inner">
    <p class="astro-ssintro__eyebrow">Glaube &middot; Segen &middot; Sakrament</p>
    <h2 class="astro-ssintro__hl">In den Sakramenten erfahren wir Gottes N&auml;he.</h2>
    <p class="astro-ssintro__lead">
      Sein Segen st&auml;rkt uns auf unserem Lebensweg. Sakramente sind sichtbare und sp&uuml;rbare
      Zeichen, in denen uns Gottes Liebe geschenkt wird &#8212; bei der Taufe, in der Ehe, in
      Krankheit und Trauer.
    </p>
    <blockquote class="astro-ssintro__quote">
      &#8222;Segen kommt vom lateinischen &#8250;Benedicere&#8249; &#8212; Gutes zusprechen. Durch den
      Segen wird dem Menschen in seine ganz pers&ouml;nliche Situation hinein von Gott seine gute und
      heilende N&auml;he zugesprochen.&#8220;
    </blockquote>
  </div>
</section>

<style is:global>
.astro-ssintro{background:#f7f3ef;padding:80px 0}
.astro-ssintro__inner{max-width:820px;margin:0 auto;padding:0 40px;text-align:center}
.astro-ssintro__eyebrow{font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:#9a2d2d;margin:0 0 16px;font-weight:600}
.astro-ssintro__hl{font-family:'Playfair Display',serif;font-size:clamp(28px,3.8vw,44px);font-weight:700;color:#2c2420;margin:0 0 22px;line-height:1.15}
.astro-ssintro__lead{font-size:clamp(16px,1.9vw,20px);color:#6b5c52;line-height:1.65;margin:0 auto;max-width:680px}
.astro-ssintro__quote{margin:40px auto 0;max-width:700px;padding:28px 36px;border-left:4px solid #c5a55a;background:#fff;border-radius:0 10px 10px 0;font-family:'Playfair Display',serif;font-size:clamp(17px,2vw,21px);font-style:italic;color:#3d3530;line-height:1.6;text-align:left;box-shadow:0 2px 14px rgba(30,21,18,.05)}
@media(max-width:600px){.astro-ssintro{padding:56px 0}.astro-ssintro__inner{padding:0 20px}.astro-ssintro__quote{padding:22px 24px}}
</style>
