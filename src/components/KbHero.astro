---
// Hero der Übersichtsseite „Kultur & Begegnung" — WP-Seite 46764 (/kultur-begegnung/).
// Eigene Klassen `astro-kbhero` (goldene Regel, Handbuch Abschnitt 3 — niemals WP-Klassen `el-…`).
// Full-Bleed-Foto + Verlauf-Overlay + Text + Buttons. Bild lokal unter public/uploads/. Hausfarben.
const bg = '/uploads/2023/08/sankt-bonifatius-thema-kultur-begegnung.jpg';
---
<section class="astro-kbhero">
  <div class="astro-kbhero__bg" role="img"
       aria-label="Menschen bei Begegnung und Kultur in der Pfarrei Sankt Bonifatius Frankfurt"
       style={`background-image:url('${bg}')`}></div>
  <div class="astro-kbhero__overlay"></div>
  <div class="astro-kbhero__inner">
    <p class="astro-kbhero__eyebrow">Pfarrei Sankt Bonifatius &middot; Frankfurt</p>
    <h1 class="astro-kbhero__title">Kultur + Begegnung</h1>
    <p class="astro-kbhero__sub">
      Gemeinschaft erleben &#8211; bei Kaffee, Konzerten, Spielen und mehr.
    </p>
    <div class="astro-kbhero__btns">
      <a class="astro-kbhero__btn" href="#kb-angebote">Zu den Angeboten</a>
      <a class="astro-kbhero__btn astro-kbhero__btn--ghost" href="#kb-termine">Veranstaltungen</a>
    </div>
  </div>
</section>

<style is:global>
.astro-kbhero{position:relative;width:100vw;left:50%;margin-left:-50vw;margin-right:-50vw;min-height:min(72vh,580px);display:flex;align-items:flex-end;overflow:hidden}
.astro-kbhero__bg{position:absolute;inset:0;background-size:cover;background-position:center 40%}
.astro-kbhero__overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(30,21,18,.10) 0%,rgba(30,21,18,.45) 55%,rgba(30,21,18,.85) 100%)}
.astro-kbhero__inner{position:relative;z-index:2;width:100%;max-width:1280px;margin:0 auto;padding:0 40px 56px;color:#f0e8d8}
.astro-kbhero__eyebrow{font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:#c5a55a;margin:0 0 14px}
.astro-kbhero__title{font-family:'Playfair Display',Georgia,serif;font-size:clamp(36px,5vw,68px);color:#fff;margin:0 0 16px;line-height:1.08;font-weight:700}
.astro-kbhero__sub{color:rgba(255,255,255,.9);font-size:clamp(16px,2vw,21px);margin:0 0 28px;max-width:640px;line-height:1.5}
.astro-kbhero__btns{display:flex;flex-wrap:wrap;gap:14px}
.astro-kbhero__btn{display:inline-flex;align-items:center;padding:14px 30px;border-radius:50px;font-size:16px;font-weight:700;text-decoration:none;background:#9a2d2d;color:#fff;transition:background .2s,color .2s}
.astro-kbhero__btn:hover{background:#7e2424;color:#fff}
.astro-kbhero__btn--ghost{background:transparent;color:#fff;box-shadow:inset 0 0 0 2px rgba(255,255,255,.7)}
.astro-kbhero__btn--ghost:hover{background:rgba(255,255,255,.12);color:#fff}
@media(max-width:600px){.astro-kbhero{min-height:min(70vh,500px)}.astro-kbhero__inner{padding:0 20px 40px}}
</style>
