.astro-bc-info__quote{font-family:'Playfair Display',Georgia,serif;font-style:italic;font-size:clamp(1.15rem,2.1vw,1.45rem);color:#3a2e28;max-width:900px;margin:0 auto 34px;line-height:1.5}
.astro-bc-info__ref{font-size:.8rem;color:#9a2d2d;font-weight:600;display:inline-block;margin-left:14px;vertical-align:baseline;font-style:normal;letter-spacing:.02em}
.astro-bc-info p:not(.astro-bc-info__quote){color:#5a4a3a;font-size:1rem;line-height:1.8;max-width:680px;margin:0 auto 18px;text-align:left}
@media(max-width:600px){.astro-bc-info{padding:56px 0}.astro-bc-info__inner{padding:0 20px}}
</style>
