---
// Angebots-Grid „Hilfe in zehn Bereichen" (WP-Markup `nh-areas`). Eigene Klassen `astro-nharea`.
// SVG-Icons statt Emoji (Handbuch Lektion 7). Feste Inhalte. Hausfarben.
const AREAS = [
  { label: 'Haushaltshilfen',
    icon: '<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>' },
  { label: 'Putzen',
    icon: '<path d="M19 11l-7 7-4-4"/><path d="M14 4l6 6"/><path d="M16 2l-3 3 6 6 3-3z"/><path d="M5 15l-3 7 7-3"/>' },
  { label: 'Einkaufen',
    icon: '<circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>' },
  { label: 'Boteng&auml;nge',
    icon: '<path d="M16 3h5v5"/><path d="M21 3l-9 9"/><path d="M21 14v5a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5"/>' },
  { label: 'Treppenhausreinigung',
    icon: '<path d="M3 21h4v-4h4v-4h4V9h4V5h4"/>' },
  { label: 'Fenster &amp; Vorh&auml;nge',
    icon: '<rect x="3" y="3" width="18" height="18" rx="1"/><line x1="12" y1="3" x2="12" y2="21"/><line x1="3" y1="12" x2="21" y2="12"/>' },
  { label: 'Gartenarbeiten',
    icon: '<path d="M12 22v-7"/><path d="M9 9a3 3 0 0 1 6 0c0 3-3 6-3 6s-3-3-3-6z"/><path d="M5 13c0-2 1.5-3.5 3.5-3.5"/><path d="M19 13c0-2-1.5-3.5-3.5-3.5"/>' },
  { label: 'Begleitung zum Arzt',
    icon: '<path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.29 1.51 4.04 3 5.5l7 7z"/>' },
  { label: 'Spazierengehen',
    icon: '<circle cx="13" cy="4" r="2"/><path d="M11 7l-2 4 3 2 1 7"/><path d="M9 11l-3 1-2 5"/><path d="M14 13l4 1 1 5"/>' },
  { label: 'Betreuungsdienste',
    icon: '<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>' },
];
---
<section class="astro-nharea">
  <div class="astro-nharea__inner">
    <p class="astro-nharea__eyebrow">Unser Angebot</p>
    <h2 class="astro-nharea__hl">Hilfe in zehn Bereichen</h2>
    <p class="astro-nharea__sub">
      Von der Haushaltsreinigung bis zur Begleitung zum Arzt &#8211; wir finden f&uuml;r jeden
      Bedarf die passende Unterst&uuml;tzung.
    </p>
    <div class="astro-nharea__grid">
      {AREAS.map((a) => (
        <div class="astro-nharea__tile">
          <svg class="astro-nharea__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={a.icon} />
          <span class="astro-nharea__label" set:html={a.label} />
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
.astro-nharea{background:#f7f3ef;padding:80px 0}
.astro-nharea__inner{max-width:1100px;margin:0 auto;padding:0 40px;text-align:center}
.astro-nharea__eyebrow{font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:#9a2d2d;margin:0 0 14px;font-weight:600}
.astro-nharea__hl{font-family:'Playfair Display',serif;font-size:clamp(26px,3.4vw,40px);font-weight:700;color:#2c2420;margin:0 0 14px}
.astro-nharea__sub{font-size:clamp(15px,1.8vw,19px);color:#6b5c52;line-height:1.6;margin:0 auto 44px;max-width:620px}
.astro-nharea__grid{display:grid;grid-template-columns:repeat(5,1fr);gap:18px}
.astro-nharea__tile{display:flex;flex-direction:column;align-items:center;gap:14px;background:#fff;border:1px solid #ece3d8;border-radius:14px;padding:28px 16px;box-shadow:0 2px 12px rgba(30,21,18,.04);transition:transform .15s,box-shadow .15s}
.astro-nharea__tile:hover{transform:translateY(-3px);box-shadow:0 8px 22px rgba(30,21,18,.10)}
.astro-nharea__icon{width:34px;height:34px;color:#9a2d2d}
.astro-nharea__label{font-size:14px;font-weight:600;color:#2c2420;line-height:1.3}
@media(max-width:900px){.astro-nharea__grid{grid-template-columns:repeat(3,1fr)}}
@media(max-width:600px){.astro-nharea{padding:56px 0}.astro-nharea__inner{padding:0 20px}.astro-nharea__grid{grid-template-columns:repeat(2,1fr);gap:14px}.astro-nharea__tile{padding:22px 12px}}
</style>
