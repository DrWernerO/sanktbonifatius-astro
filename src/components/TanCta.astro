---
// Abschluss-Hinweis unter dem Anmeldeformular der Seite „Anmeldung zur Taufe" (WP-Seite 48011).
// Eigene Klassen `astro-tan-cta`. Verweist auf die ausführliche Taufe-Infoseite + Pfarrbüro-Kontakt.
---
<section class="astro-tan-cta">
  <div class="astro-tan-cta__inner">
    <p class="astro-tan-cta__eyebrow">Noch Fragen?</p>
    <h2 class="astro-tan-cta__hl">Wir sind f&uuml;r Sie da</h2>
    <p class="astro-tan-cta__sub">
      Alle Infos rund um Ablauf, Termine und Taufpaten finden Sie auf unserer Taufe-Seite.
      Oder melden Sie sich direkt bei unserem Pfarrb&uuml;ro &#8211; wir helfen gerne weiter.
    </p>
    <div class="astro-tan-cta__btns">
      <a class="astro-tan-cta__btn" href="/segen-sakramente/taufe/">Alles zur Taufe &#8594;</a>
      <a class="astro-tan-cta__btn astro-tan-cta__btn--ghost" href="/kontakt/pfarrbuero/">Pfarrb&uuml;ro kontaktieren</a>
    </div>
  </div>
</section>

<style is:global>
.astro-tan-cta{position:relative;width:100vw;left:50%;margin-left:-50vw;margin-right:-50vw;background:linear-gradient(135deg,#4a2e1a,#3a2315);color:#fff;padding:72px 0;overflow:hidden}
.astro-tan-cta::after{content:"";position:absolute;inset:0;background:radial-gradient(circle at 20% 10%,rgba(255,255,255,.08),transparent 55%)}
.astro-tan-cta__inner{position:relative;z-index:1;max-width:760px;margin:0 auto;padding:0 40px;text-align:center}
.astro-tan-cta__eyebrow{font-family:'Playfair Display',serif;font-style:italic;font-size:15px;letter-spacing:.06em;text-transform:uppercase;color:#c8a96e;margin:0 0 16px}
.astro-tan-cta__hl{font-family:'Playfair Display',serif;font-size:clamp(26px,3.4vw,38px);font-weight:700;color:#fff;margin:0 0 16px}
.astro-tan-cta__sub{font-size:clamp(15px,1.8vw,18px);color:rgba(255,255,255,.82);line-height:1.6;margin:0 0 34px}
.astro-tan-cta__btns{display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:16px}
.astro-tan-cta__btn{display:inline-flex;align-items:center;gap:10px;padding:15px 32px;border-radius:50px;font-size:16px;font-weight:700;text-decoration:none;background:#fff;color:#9a2d2d;transition:background .2s,color .2s}
.astro-tan-cta__btn:hover{background:#f3e7d4;color:#7e2424}
.astro-tan-cta__btn--ghost{background:transparent;color:#fff;box-shadow:inset 0 0 0 1.5px rgba(255,255,255,.5)}
.astro-tan-cta__btn--ghost:hover{background:rgba(255,255,255,.12);color:#fff}
@media(max-width:600px){.astro-tan-cta{padding:52px 0}.astro-tan-cta__inner{padding:0 20px}}
</style>
