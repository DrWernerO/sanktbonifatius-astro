---
// „Ansprechpartner Jugend" (WP-Block `jug-kontakt`). Eigene Klassen `astro-jukontakt`.
// id="jugend-kontakt" als Sprungziel der Welcome-Buttons. Weißer Hintergrund (Bänder-Prinzip:
// EventCalendar crème → Kontakt weiß → FAQ crème). Bilder lokal unter public/uploads/.
// Lilian Wykipil = Jugend-Ansprechpartnerin; JONA = Kooperationspartner (eigene Website).
const people = [
  {
    kind: 'person',
    img: '/uploads/2023/09/lilian-wykipil.jpeg',
    name: 'Lilian Wykipil',
    role: 'Pastoralreferentin &middot; Jugend',
    linkHref: 'mailto:l.wykipil@sanktbonifatius.de?subject=Jugend%20in%20Sankt%20Bonifatius',
    linkText: 'l.wykipil@sanktbonifatius.de',
  },
  {
    kind: 'partner',
    img: '/uploads/2026/05/logo-jugendkirche-jona.jpg',
    name: 'Jugendkirche JONA',
    role: 'Kath. Jugendkirche &middot; Partner',
    linkHref: 'https://www.jugendkirche-jona.de',
    linkText: 'www.jugendkirche-jona.de',
  },
];
---
<section class="astro-jukontakt" id="jugend-kontakt">
  <div class="astro-jukontakt__inner">
    <p class="astro-jukontakt__eyebrow">Wir sind f&uuml;r dich da</p>
    <h2 class="astro-jukontakt__hl">Ansprechpartner Jugend</h2>
    <div class="astro-jukontakt__grid">
      {people.map((p) => (
        <div class={`astro-jukontakt-card astro-jukontakt-card--${p.kind}`}>
          <div class="astro-jukontakt-card__media" role="img" aria-label={p.name}
               style={`background-image:url('${p.img}')`}></div>
          <div class="astro-jukontakt-card__body">
            <h3 class="astro-jukontakt-card__name">{p.name}</h3>
            <p class="astro-jukontakt-card__role" set:html={p.role} />
            <a class="astro-jukontakt-card__link" href={p.linkHref}
               {...(p.kind === 'partner' ? { target: '_blank', rel: 'noopener' } : {})}
               set:html={p.linkText} />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
.astro-jukontakt{background:#fff;padding:80px 0}
.astro-jukontakt__inner{max-width:960px;margin:0 auto;padding:0 40px}
.astro-jukontakt__eyebrow{font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:#9a2d2d;margin:0 0 14px;font-weight:600;text-align:center}
.astro-jukontakt__hl{font-family:'Playfair Display',serif;font-size:clamp(26px,3.4vw,40px);font-weight:700;color:#2c2420;margin:0 0 40px;text-align:center}
.astro-jukontakt__grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px}
.astro-jukontakt-card{display:flex;align-items:center;gap:22px;background:#f7f3ef;border-radius:14px;padding:26px 28px;box-shadow:0 2px 14px rgba(30,21,18,.06)}
.astro-jukontakt-card__media{width:96px;height:96px;flex-shrink:0;background-size:cover;background-position:center;background-repeat:no-repeat}
.astro-jukontakt-card--person .astro-jukontakt-card__media{border-radius:50%}
.astro-jukontakt-card--partner .astro-jukontakt-card__media{border-radius:12px;background-size:contain;background-color:#fff;border:1px solid #ede8e1}
.astro-jukontakt-card__name{font-family:'Playfair Display',serif;font-size:21px;font-weight:700;color:#2c2420;margin:0 0 4px}
.astro-jukontakt-card__role{font-size:14px;font-style:italic;color:#928269;margin:0 0 10px}
.astro-jukontakt-card__link{font-size:14px;font-weight:600;color:#9a2d2d;text-decoration:none;word-break:break-word;border-bottom:1px solid rgba(154,45,45,.35);padding-bottom:1px;transition:border-color .2s}
.astro-jukontakt-card__link:hover{border-color:#9a2d2d}
@media(max-width:600px){.astro-jukontakt{padding:56px 0}.astro-jukontakt__inner{padding:0 20px}.astro-jukontakt__grid{grid-template-columns:1fr}}
</style>
