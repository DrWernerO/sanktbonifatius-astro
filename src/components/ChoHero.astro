---
// Hero der Unterseite „Chöre" — WP-Seite 49153 (/kultur-begegnung/choere/).
// Eigene Klassen `astro-chohero` (goldene Regel — WP nutzt `ch-`). Full-Bleed-Foto + Verlauf-Overlay.
// Bild lokal unter public/uploads/. Inhalte fest gepflegt.
const bg = '/uploads/2024/07/michael-maasen-bu-6kNWQj6U-unsplash.jpg';
---
<section class="astro-chohero">
  <div class="astro-chohero__bg" role="img"
       aria-label="Chor beim Singen in der Pfarrei Sankt Bonifatius Frankfurt"
       style={`background-image:url('${bg}')`}></div>
  <div class="astro-chohero__overlay"></div>
  <div class="astro-chohero__inner">
    <p class="astro-chohero__eyebrow">Kirchenmusik &middot; Pfarrei Sankt Bonifatius Frankfurt</p>
    <h1 class="astro-chohero__title">Unsere Ch&ouml;re</h1>
    <p class="astro-chohero__sub">
      Vier Ch&ouml;re an unseren Kirchorten &#8211; vom Kinderchor bis zum Vokalensemble. Wir singen
      geistliche und weltliche Werke aus allen Epochen.
    </p>
    <div class="astro-chohero__btns">
      <a class="astro-chohero__btn" href="#cho-choere">Zu den Ch&ouml;ren</a>
    </div>
  </div>
</section>

<style is:global>
.astro-chohero{position:relative;width:100vw;left:50%;margin-left:-50vw;margin-right:-50vw;min-height:min(64vh,540px);display:flex;align-items:flex-end;overflow:hidden}
.astro-chohero__bg{position:absolute;inset:0;background-size:cover;background-position:center 35%}
.astro-chohero__overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(30,21,18,.25) 0%,rgba(30,21,18,.45) 50%,rgba(30,21,18,.85) 100%)}
.astro-chohero__inner{position:relative;z-index:2;width:100%;max-width:1200px;margin:0 auto;padding:96px 40px 56px;color:#f0e8d8}
.astro-chohero__eyebrow{font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:#c5a55a;margin:0 0 14px;font-weight:600}
.astro-chohero__title{font-family:'Playfair Display',Georgia,serif;font-size:clamp(36px,5vw,68px);color:#fff;margin:0 0 16px;line-height:1.08;font-weight:700}
.astro-chohero__sub{color:rgba(255,255,255,.9);font-size:clamp(16px,1.9vw,19px);margin:0 0 28px;max-width:560px;line-height:1.55}
.astro-chohero__btns{display:flex;flex-wrap:wrap;gap:14px}
.astro-chohero__btn{display:inline-flex;align-items:center;padding:14px 30px;border-radius:50px;font-size:16px;font-weight:700;text-decoration:none;background:#9a2d2d;color:#fff;transition:background .2s}
.astro-chohero__btn:hover{background:#7e2424;color:#fff}
@media(max-width:600px){.astro-chohero{min-height:min(64vh,460px)}.astro-chohero__inner{padding:80px 20px 40px}}
</style>
