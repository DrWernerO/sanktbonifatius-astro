---
// Abschluss-CTA „Kommen Sie vorbei" der Unterseite „Offener Kühlschrank" (WP-Seite 49123).
// Eigene Klassen `astro-okcta`. Full-Bleed Bordeaux (Muster EngagementCta). Feste Inhalte.
---
<section class="astro-okcta">
  <div class="astro-okcta__inner">
    <p class="astro-okcta__eyebrow">Lebensmittel teilen in Frankfurt</p>
    <h2 class="astro-okcta__hl">Kommen Sie vorbei &#8211; wir freuen uns auf Sie</h2>
    <p class="astro-okcta__sub">
      Der Offene K&uuml;hlschrank Frankfurt-Sachsenhausen freut sich &uuml;ber jeden Besuch &#8211;
      ob Sie etwas mitbringen oder mitnehmen m&ouml;chten.
    </p>
    <p class="astro-okcta__addr">
      Kirche St. Aposteln &middot; Ziegelh&uuml;ttenweg 149 &middot; 60598 Frankfurt am Main &middot; t&auml;gl. 10&#8211;18 Uhr (Fr. 10&#8211;14 Uhr)
    </p>
    <div class="astro-okcta__btns">
      <a class="astro-okcta__btn astro-okcta__btn--light" href="/kontakt/engagement/">Mehr Engagement entdecken &#8594;</a>
      <a class="astro-okcta__btn astro-okcta__btn--outline" href="/kontakt/">Kontakt aufnehmen</a>
    </div>
  </div>
</section>

<style is:global>
.astro-okcta{position:relative;width:100vw;left:50%;margin-left:-50vw;margin-right:-50vw;background:linear-gradient(135deg,#9a2d2d 0%,#7e2424 100%);color:#fff;padding:76px 0;overflow:hidden}
.astro-okcta::after{content:"";position:absolute;inset:0;background:radial-gradient(circle at 20% 10%,rgba(255,255,255,.10),transparent 55%)}
.astro-okcta__inner{position:relative;z-index:1;max-width:780px;margin:0 auto;padding:0 40px;text-align:center}
.astro-okcta__eyebrow{font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:#f0d9a0;margin:0 0 14px;font-weight:600}
.astro-okcta__hl{font-family:'Playfair Display',serif;font-size:clamp(28px,3.5vw,44px);font-weight:700;color:#fff;margin:0 0 14px}
.astro-okcta__sub{font-size:clamp(15px,1.8vw,19px);color:#f2dede;line-height:1.6;margin:0 0 18px}
.astro-okcta__addr{font-size:14px;color:#f0d9a0;line-height:1.6;margin:0 0 32px;font-weight:600}
.astro-okcta__btns{display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:16px}
.astro-okcta__btn{display:inline-flex;align-items:center;gap:10px;padding:15px 32px;border-radius:50px;font-size:16px;font-weight:700;text-decoration:none;transition:background .2s,color .2s,border-color .2s}
.astro-okcta__btn--light{background:#fff;color:#9a2d2d;border:2px solid #fff}
.astro-okcta__btn--light:hover{background:#f3e7d4;color:#7e2424;border-color:#f3e7d4}
.astro-okcta__btn--outline{background:transparent;color:#fff;border:2px solid rgba(255,255,255,.6)}
.astro-okcta__btn--outline:hover{background:rgba(255,255,255,.14);border-color:#fff}
@media(max-width:600px){.astro-okcta{padding:56px 0}.astro-okcta__inner{padding:0 20px}.astro-okcta__btn{justify-content:center}}
</style>
