---
// Geschichte & Architektur (WP-Seite 49303: Intro `stb2-sec` + `arch-row`-Reihen + Beleuchtungs-
// Sektion). Eigene Klassen `astro-kfarch`. Inhalte aus src/data/kirche.js. Architektur-Reihen
// alternierend Text/Bild; Reihen ohne Bild laufen einspaltig. Reihen mit mehreren Bildern
// bekommen einen kleinen Slider (Client-Script unten). Bilder lokal in public/uploads/.
import { INTRO, ARCH, BELEUCHTUNG, IMG_BASE } from '../data/kirche.js';
const url = (rel) => `${IMG_BASE}${rel}`;
---
<section class="astro-kfarch" id="architektur">
  <div class="astro-kfarch__in">
    <span class="astro-kfarch__eyebrow">{INTRO.eyebrow}</span>
    <h2 class="astro-kfarch__h2">{INTRO.h2}</h2>
    <div class="astro-kfarch__intro">
      {INTRO.ps.map((p) => <p>{p}</p>)}
    </div>

    {ARCH.map((row, i) => (
      <div class={`astro-kfarch__row${row.imgs.length ? '' : ' is-text'}${row.imgs.length && i % 2 === 1 ? ' is-rev' : ''}`}>
        <div class="astro-kfarch__text">
          <p class="astro-kfarch__q">{row.q}</p>
          {row.ps.map((p) => <p>{p}</p>)}
        </div>
        {row.imgs.length > 0 && (
          <div class="astro-kfarch__media">
            {row.imgs.length === 1
              ? <div class="astro-kfarch__img" role="img" aria-label={row.q} style={`background-image:url('${url(row.imgs[0])}')`}></div>
              : (
                <div class="astro-kfarch__slider" data-slider>
                  {row.imgs.map((im, k) => (
                    <div class={`astro-kfarch__slide${k === 0 ? ' is-active' : ''}`} style={`background-image:url('${url(im)}')`}></div>
                  ))}
                  <div class="astro-kfarch__dots">
                    {row.imgs.map((_, k) => (
                      <button type="button" class={`astro-kfarch__dot${k === 0 ? ' is-active' : ''}`} data-dot={k} aria-label={`Bild ${k + 1}`}></button>
                    ))}
                  </div>
                </div>
              )}
          </div>
        )}
      </div>
    ))}
  </div>

  <div class="astro-kfarch__beleucht">
    <div class="astro-kfarch__in">
      <span class="astro-kfarch__eyebrow astro-kfarch__eyebrow--light">{BELEUCHTUNG.eyebrow}</span>
      <h2 class="astro-kfarch__h2 astro-kfarch__h2--light">{BELEUCHTUNG.h2}</h2>
      <div class="astro-kfarch__beleucht-body">
        {BELEUCHTUNG.ps.map((p) => <p>{p}</p>)}
      </div>
    </div>
  </div>
</section>

<style is:global>
.astro-kfarch{background:#fff;padding:64px 0 0}
.astro-kfarch__in{max-width:1080px;margin:0 auto;padding:0 32px}
.astro-kfarch__eyebrow{display:block;font-family:'Playfair Display',Georgia,serif;font-style:italic;font-size:14px;color:#6440a4;letter-spacing:.06em;text-transform:uppercase;margin-bottom:10px;text-align:center}
.astro-kfarch__h2{font-family:'Playfair Display',Georgia,serif;font-size:34px;color:#6440a4;text-align:center;margin:0 0 24px;line-height:1.15}
.astro-kfarch__intro{max-width:780px;margin:0 auto 56px}
.astro-kfarch__intro p{font-size:16px;line-height:1.75;color:#3a3330;margin:0 0 14px}
.astro-kfarch__intro p:last-child{margin-bottom:0}
/* Q&A-Reihen */
.astro-kfarch__row{display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:start;margin-bottom:56px}
.astro-kfarch__row.is-rev .astro-kfarch__text{order:2}
.astro-kfarch__row.is-text{display:block;max-width:780px;margin-left:auto;margin-right:auto}
.astro-kfarch__q{font-family:'Playfair Display',Georgia,serif;font-size:21px;font-weight:700;color:#6440a4;margin:0 0 14px;line-height:1.25}
.astro-kfarch__text p{font-size:15px;line-height:1.75;color:#3a3330;margin:0 0 12px}
.astro-kfarch__text p:last-child{margin-bottom:0}
.astro-kfarch__img,.astro-kfarch__slider{border-radius:12px;overflow:hidden;aspect-ratio:4/3;background:#eee;background-size:cover;background-position:center}
.astro-kfarch__slider{position:relative}
.astro-kfarch__slide{position:absolute;inset:0;background-size:cover;background-position:center;opacity:0;transition:opacity .5s ease}
.astro-kfarch__slide.is-active{opacity:1}
.astro-kfarch__dots{position:absolute;bottom:14px;left:50%;transform:translateX(-50%);display:flex;gap:7px;z-index:2}
.astro-kfarch__dot{width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,.55);border:none;cursor:pointer;padding:0;transition:background .2s}
.astro-kfarch__dot.is-active{background:#fff}
/* Beleuchtung 2013 — dunkle Akzent-Sektion */
.astro-kfarch__beleucht{margin-top:8px;background:#6440a4;padding:64px 0;width:100vw;position:relative;left:50%;margin-left:-50vw;margin-right:-50vw}
.astro-kfarch__eyebrow--light{color:rgba(255,255,255,.75)}
.astro-kfarch__h2--light{color:#fff}
.astro-kfarch__beleucht-body{max-width:780px;margin:0 auto}
.astro-kfarch__beleucht-body p{color:rgba(255,255,255,.92);font-size:16px;line-height:1.75;margin:0 0 14px;text-align:center}
.astro-kfarch__beleucht-body p:last-child{margin-bottom:0}
@media(max-width:760px){.astro-kfarch__row{grid-template-columns:1fr;gap:20px}.astro-kfarch__row.is-rev .astro-kfarch__text{order:0}.astro-kfarch__h2{font-size:27px}}
@media(max-width:600px){.astro-kfarch__in{padding:0 16px}}
</style>

<script>
(function(){
  document.querySelectorAll('.astro-kfarch__slider[data-slider]').forEach(function(sl){
    var slides = sl.querySelectorAll('.astro-kfarch__slide');
    var dots = sl.querySelectorAll('.astro-kfarch__dot');
    var cur = 0, n = slides.length, timer;
    function go(i){
      cur = (i + n) % n;
      slides.forEach(function(s,k){ s.classList.toggle('is-active', k===cur); });
      dots.forEach(function(d,k){ d.classList.toggle('is-active', k===cur); });
    }
    dots.forEach(function(d,k){ d.addEventListener('click', function(){ go(k); restart(); }); });
    function restart(){ clearInterval(timer); timer = setInterval(function(){ go(cur+1); }, 5000); }
    restart();
  });
})();
</script>
