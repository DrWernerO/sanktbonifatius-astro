---
// „Unser Leitungsteam" der Seite „Ministranten St. Bonifatius" (WP-Block `mn-team`).
// Eigene Klassen `astro-mnteam`. Bild + Text (zweispaltig). Bild lokal (Handbuch 1b).
const teamImg = '/uploads/2022/06/Leitungsteam-ministranten-stbonifatius-1024x768.jpg';
---
<section class="astro-mnteam">
  <div class="astro-mnteam__in">
    <div class="astro-mnteam__img">
      <img src={teamImg} alt="Das Leitungsteam der Ministranten von St. Bonifatius" loading="lazy" decoding="async" />
    </div>
    <div class="astro-mnteam__txt">
      <p class="astro-mnteam__eyebrow">Ministranten St. Bonifatius</p>
      <h2 class="astro-mnteam__hl">Unser Leitungsteam</h2>
      <p>
        Wir sorgen daf&uuml;r, dass der Laden l&auml;uft. Und wir bilden mit viel Freude jedes Jahr
        die neuen Kandidatinnen und Kandidaten f&uuml;r den Dienst aus.
      </p>
    </div>
  </div>
</section>

<style is:global>
.astro-mnteam{background:#f7f3ef;padding:64px 24px}
.astro-mnteam__in{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:44px;align-items:center}
.astro-mnteam__img{border-radius:16px;overflow:hidden;box-shadow:0 4px 16px rgba(44,36,32,.12)}
.astro-mnteam__img img{width:100%;height:100%;object-fit:cover;display:block}
.astro-mnteam__eyebrow{font-size:11.5px;letter-spacing:.13em;text-transform:uppercase;color:#c5a55a;font-weight:600;margin:0 0 10px}
.astro-mnteam__hl{font-family:'Playfair Display',Georgia,serif;font-size:clamp(24px,3.4vw,34px);color:#2c2420;margin:0 0 16px;font-weight:700}
.astro-mnteam__txt p:last-child{font-size:16px;color:#6b5c52;line-height:1.7;margin:0}
@media(max-width:820px){.astro-mnteam__in{grid-template-columns:1fr;gap:28px}}
@media(max-width:600px){.astro-mnteam{padding:48px 18px}}
</style>
