---
// Info-Streifen „Familiengottesdienste" — Präfix `astro-kfgstrip`.
const items = [
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
    label: 'Termin',
    value: '1. & 3. Sonntag im Monat',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    label: 'Beginn',
    value: '11:00 Uhr (parallel zur Messe)',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    label: 'Für wen',
    value: 'Kinder, Familien & Neugierige',
  },
];
---
<div class="astro-kfgstrip">
  <div class="astro-kfgstrip__inner">
    {items.map(item => (
      <div class="astro-kfgstrip__item">
        <span class="astro-kfgstrip__icon" set:html={item.icon} />
        <div class="astro-kfgstrip__text">
          <span class="astro-kfgstrip__label">{item.label}</span>
          <span class="astro-kfgstrip__value">{item.value}</span>
        </div>
      </div>
    ))}
  </div>
</div>

<style is:global>
.astro-kfgstrip{background:#9a2d2d;width:100vw;position:relative;left:50%;margin-left:-50vw;margin-right:-50vw;padding:20px 0}
.astro-kfgstrip__inner{max-width:1100px;margin:0 auto;padding:0 40px;display:flex;justify-content:center;gap:48px;flex-wrap:wrap}
.astro-kfgstrip__item{display:flex;align-items:center;gap:12px;color:#fff}
.astro-kfgstrip__icon{flex-shrink:0;opacity:.85}
.astro-kfgstrip__text{display:flex;flex-direction:column;gap:1px}
.astro-kfgstrip__label{font-size:11px;letter-spacing:.1em;text-transform:uppercase;opacity:.7}
.astro-kfgstrip__value{font-size:15px;font-weight:600}
@media(max-width:600px){.astro-kfgstrip__inner{padding:0 20px;gap:24px}.astro-kfgstrip__item{flex:1;min-width:140px}}
</style>
