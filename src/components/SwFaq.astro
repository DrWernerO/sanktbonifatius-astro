---
// FAQ-Sektion St. Wendel (WP-Block `stb2-faq`, id="faq").
// Eigene Klassen `astro-swfaq`. Natives <details> ohne JS.
const FAQ = [
  {
    q: 'Wo liegt die Kirche St. Wendel?',
    a: 'Die Kirche St. Wendel liegt in Altes Schützenhüttengässchen 2–6, 60599 Frankfurt am Main (Sachsenhausen).',
  },
  {
    q: 'Wann finden Gottesdienste in St. Wendel statt?',
    a: 'Sonntagsgottesdienst: 11 Uhr · Mittwochsgottesdienst: 18 Uhr · Eucharistiefeier. Aktuelle Zeiten finden Sie auf der Gottesdienst-Seite der Pfarrei oder auf den Aushängen in der Kirche.',
  },
  {
    q: 'Was sind die Familiengottesdienste?',
    a: 'Jeweils am 2. Sonntag im Monat findet ein Familiengottesdienst statt. Er lebt von kreativen Ideen, toller Musik und spirituellen Impulsen für die ganze Familie.',
  },
  {
    q: 'Was ist das Repair Café?',
    a: 'Das Repair Café findet monatlich jeden 1. Dienstag statt. Kaputte Dinge werden gemeinsam repariert, statt weggeworfen. Aktuelle Termine entnehmen Sie dem Pfarrbrief oder dem Veranstaltungskalender.',
  },
  {
    q: 'Wie kann ich mich in der Gemeinde einbringen?',
    a: 'Sprechen Sie gerne Martin Kestler oder Pater Gaby Geagea an. Wir freuen uns über Mitarbeit – ob im Gottesdienst-Team, im Repair Café oder in einem unserer Chöre.',
  },
];
---
<section class="astro-swsec" id="faq">
  <div class="astro-swsec__in">
    <span class="astro-swsec__eyebrow">Fragen &amp; Antworten</span>
    <h2 class="astro-swsec__h2">Häufige Fragen zu St. Wendel</h2>
    <div class="astro-swfaq">
      {FAQ.map((f) => (
        <details>
          <summary>{f.q}</summary>
          <div class="astro-swfaq__a">{f.a}</div>
        </details>
      ))}
    </div>
  </div>
</section>

<style is:global>
.astro-swfaq{max-width:840px;margin:0 auto}
.astro-swfaq details{background:#fff;border-radius:10px;margin-bottom:10px;box-shadow:0 2px 16px rgba(30,21,18,.12);overflow:hidden}
.astro-swfaq summary{padding:20px 24px;cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;font-weight:600;font-size:16px;color:#1e1512}
.astro-swfaq summary::-webkit-details-marker{display:none}
.astro-swfaq summary::after{content:"+";font-size:22px;color:#012C7B;transition:transform .2s;flex-shrink:0;margin-left:12px}
.astro-swfaq details[open] summary::after{transform:rotate(45deg)}
.astro-swfaq__a{padding:0 24px 20px;font-size:15px;color:#3d3530;line-height:1.65}
</style>
