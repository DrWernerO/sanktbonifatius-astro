---
// Hero des Kirchorts „St. Bonifatius" (WP-Seite 47279, ersetzt WP-Block `stb2-hero`).
// Eigene Klassen `astro-stbhero` (goldene Regel, Handbuch Abschnitt 3). Full-Bleed-Bild
// + Verlauf-Overlay + Text. Inhalte fest gepflegt; Bild lokal im Projekt unter public/uploads/
// (vom WP heruntergeladen → unabhängig vom Dev-Server, vgl. Handbuch 1b).
const bg = '/uploads/2026/05/Sankt-Bonifatius-DJI.jpg';
---
<section class="astro-stbhero">
  <div class="astro-stbhero__bg" role="img"
       aria-label="Luftaufnahme der Kirche St. Bonifatius in Frankfurt-Sachsenhausen"
       style={`background-image:url('${bg}')`}></div>
  <div class="astro-stbhero__overlay"></div>
  <div class="astro-stbhero__inner">
    <span class="astro-stbhero__badge">Kirchort &middot; Frankfurt-Sachsenhausen</span>
    <h1 class="astro-stbhero__title">St. Bonifatius</h1>
    <p class="astro-stbhero__sub">Ein Ort des Glaubens und der Gemeinschaft in Frankfurt</p>
    <div class="astro-stbhero__btns">
      <a class="astro-stbhero__btn astro-stbhero__btn--primary" href="#angebote">Unsere Angebote</a>
      <a class="astro-stbhero__btn astro-stbhero__btn--ghost" href="#kontakt">Kontakt</a>
    </div>
  </div>
</section>

<style is:global>
.astro-stbhero{position:relative;width:100vw;left:50%;margin-left:-50vw;margin-right:-50vw;height:min(72vh,600px);display:flex;align-items:flex-end;overflow:hidden}
.astro-stbhero__bg{position:absolute;inset:0;background-size:cover;background-position:center 30%}
.astro-stbhero__overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(30,21,18,.05) 0%,rgba(30,21,18,.55) 60%,rgba(30,21,18,.88) 100%)}
.astro-stbhero__inner{position:relative;z-index:2;width:100%;max-width:1280px;margin:0 auto;padding:0 40px 56px}
.astro-stbhero__badge{display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,.15);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,.3);border-radius:30px;padding:6px 16px;margin-bottom:20px;color:#fff;font-size:12px;font-weight:700;letter-spacing:.1em;text-transform:uppercase}
.astro-stbhero__title{font-family:'Playfair Display',Georgia,serif;font-size:clamp(36px,5vw,72px);color:#fff;margin:0 0 14px;line-height:1.08;font-weight:700}
.astro-stbhero__sub{color:rgba(255,255,255,.88);font-size:clamp(16px,2vw,22px);margin:0 0 28px;max-width:600px;line-height:1.45}
.astro-stbhero__btns{display:flex;gap:12px;flex-wrap:wrap}
.astro-stbhero__btn{padding:13px 26px;border-radius:999px;font-size:15px;font-weight:600;text-decoration:none;transition:all .2s}
.astro-stbhero__btn--primary{background:#fff;color:#6440a4}
.astro-stbhero__btn--primary:hover{background:#f0ebe0}
.astro-stbhero__btn--ghost{background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.5);color:#fff}
.astro-stbhero__btn--ghost:hover{background:rgba(255,255,255,.25)}
@media(max-width:600px){.astro-stbhero__inner{padding:0 16px 44px}}
</style>
