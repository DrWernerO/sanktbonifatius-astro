---
// Abschluss-CTA Kirchortrat Herz Jesu — roter Gradient, WP-Design-Klon.
// Eigene Klassen astro-hjkcta.
---
<section class="astro-hjkcta">
  <div class="astro-hjkcta__inner">
    <div class="astro-hjkcta__head">
      <h2 id="fragen-oder-anliegen">Fragen oder Anliegen?</h2>
      <p>Der Kirchortrat freut sich &uuml;ber R&uuml;ckmeldungen aus der Gemeinde. Sprechen Sie uns einfach an.</p>
    </div>
    <div class="astro-hjkcta__btns">
      <a href="/kirchorte/herz-jesu/" class="astro-hjkcta__btn astro-hjkcta__btn--out">&larr; Zur&uuml;ck zu Herz&nbsp;Jesu</a>
      <a href="mailto:azerlik@web.de" class="astro-hjkcta__btn astro-hjkcta__btn--wht">Annette Albert-Zerlik schreiben</a>
    </div>
    <div class="astro-hjkcta__address">
      <span>Herz Jesu &middot; Mathildestra&szlig;e 30 &middot; 60599 Frankfurt</span>
      <a href="tel:+4969695975850">069 695 97 58 50</a>
    </div>
  </div>
</section>

<style is:global>
.astro-hjkcta{background:linear-gradient(135deg,#910003 0%,#6e0002 100%);text-align:center;padding:56px 24px;width:100vw;margin-left:calc(50% - 50vw);margin-right:calc(50% - 50vw);box-sizing:border-box}
.astro-hjkcta__inner{max-width:1200px;margin:0 auto}
.astro-hjkcta__head{max-width:720px;margin:0 auto 24px}
.astro-hjkcta__head h2{font-family:'Playfair Display',Georgia,serif;font-size:clamp(26px,4vw,36px);font-weight:700;color:#fff;margin:0 0 12px;line-height:1.15}
.astro-hjkcta__head p{font-size:16px;color:rgba(255,255,255,.8);margin:0}
.astro-hjkcta__btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-bottom:24px}
.astro-hjkcta__btn{display:inline-flex;align-items:center;gap:8px;padding:14px 26px;border-radius:28px;font-size:15.5px;font-weight:600;text-decoration:none;transition:all .2s;border:2px solid transparent}
.astro-hjkcta__btn--out{background:transparent;color:#fff;border:2px solid rgba(255,255,255,.8)}
.astro-hjkcta__btn--out:hover{background:#fff;color:#2c2420;border-color:#fff}
.astro-hjkcta__btn--wht{background:#fff;color:#910003;border-color:#fff}
.astro-hjkcta__btn--wht:hover{background:rgba(255,255,255,.9)}
.astro-hjkcta__address{font-size:14.5px;color:rgba(255,255,255,.7);display:flex;gap:24px;justify-content:center;flex-wrap:wrap;align-items:center}
.astro-hjkcta__address a{color:#f0c0c0;text-decoration:none;font-weight:600}
.astro-hjkcta__address a:hover{color:#fff}
@media(max-width:600px){.astro-hjkcta{padding:40px 20px}.astro-hjkcta__address{flex-direction:column;gap:8px}}
</style>
