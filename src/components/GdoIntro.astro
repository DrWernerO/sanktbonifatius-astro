---
// „Besondere Gottesdienste in Frankfurt" — Intro-Text + 5 Format-Icon-Karten.
// Präfix: astro-gdointro / astro-gdocard. Karten mit SVG-Icon, Titel, Kurztext, Link.
// Inhalte aus WP-Seite 46977 (boni-gdo-intro / boni-gdo-grid), fest gepflegt.
const cards = [
  {
    href: '/gottesdienst-glaube/gottesdienste-die-beruehren/',
    title: 'Taizé',
    desc: 'Meditative Gesänge, Stille und persönlicher Segen — für alle, die innerlich ankommen wollen.',
    svg: '<path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>',
  },
  {
    href: '/gottesdienst-glaube/gottesdienste-die-beruehren/',
    title: 'Fiat Lux',
    desc: 'Stimmungsvolles Licht und Live-Musik mit Cello, Flöte oder Saxophon — Gottesdienst für alle Sinne.',
    svg: '<circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>',
  },
  {
    href: '/gottesdienst-glaube/gottesdienste-die-beruehren/',
    title: 'BonEsprit',
    desc: 'Band, Dialog-Predigt und kreative Gestaltung — zeitgenössisch und lebendig, mit Pizza danach.',
    svg: '<path d="M9 19V6l12-3v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>',
  },
  {
    href: '/bonfamily/familiengottesdienste/',
    title: 'Familiengottesdienst',
    desc: 'Fröhlich, modern und lebensnah — mit Kirchcafé oder Familienbrunch im Anschluss.',
    svg: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>',
  },
  {
    href: '/bonfamily/familiengottesdienste/',
    title: 'Kindergottesdienst',
    desc: 'Parallel zur Sonntagsmesse — mit Bilderbuch, Kreativität und Rückkehr zur Gabenbereitung.',
    svg: '<circle cx="12" cy="8" r="4"/><path d="M6 20v-1a6 6 0 0 1 12 0v1"/>',
  },
];
---
<section class="astro-gdointro" id="besondere-gottesdienste">
  <div class="astro-gdointro__inner">
    <h2 class="astro-gdointro__hl">Besondere Gottesdienste in Frankfurt</h2>
    <p class="astro-gdointro__lead">Von meditativer Stille bis lebendiger Band-Musik — finden Sie den Gottesdienst, der zu Ihnen passt.</p>
    <div class="astro-gdointro__grid">
      {cards.map((c) => (
        <a href={c.href} class="astro-gdocard">
          <div class="astro-gdocard__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" set:html={c.svg} aria-hidden="true" />
          </div>
          <strong class="astro-gdocard__title">{c.title}</strong>
          <span class="astro-gdocard__desc">{c.desc}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style is:global>
.astro-gdointro{background:#f7f3ef;padding:72px 40px}
.astro-gdointro__inner{max-width:1200px;margin:0 auto}
.astro-gdointro__hl{font-family:'Playfair Display',serif;font-size:clamp(26px,3.5vw,38px);color:#2c2420;margin:0 0 12px;text-align:center}
.astro-gdointro__lead{text-align:center;color:#928269;font-size:17px;margin:0 0 48px}
.astro-gdointro__grid{display:flex;flex-wrap:wrap;gap:20px;justify-content:center}
.astro-gdocard{display:flex;flex-direction:column;align-items:center;text-align:center;gap:14px;padding:32px 24px;background:#fff;border-radius:12px;text-decoration:none;color:#2c2420;border:1px solid #ede8e0;transition:box-shadow .2s,transform .2s;width:calc(20% - 16px);min-width:160px}
.astro-gdocard:hover{box-shadow:0 6px 24px rgba(44,36,32,.1);transform:translateY(-3px)}
.astro-gdocard__icon{width:52px;height:52px;border-radius:50%;background:#f7f3ef;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.astro-gdocard__icon svg{width:24px;height:24px;color:#9a2d2d}
.astro-gdocard__title{font-weight:700;font-size:15px;color:#2c2420;line-height:1.3}
.astro-gdocard__desc{font-size:13px;color:#6b5c52;line-height:1.55}
@media(max-width:860px){
  .astro-gdointro{padding:56px 24px}
  .astro-gdocard{width:calc(33.33% - 14px)}
}
@media(max-width:600px){
  .astro-gdocard{width:calc(50% - 10px);min-width:140px}
}
@media(max-width:400px){
  .astro-gdocard{width:100%}
}
</style>
