<style is:global>
.astro-mncontact{background:#fff;padding:24px 24px 64px}
.astro-mncontact__in{max-width:1000px;margin:0 auto}
.astro-mncontact__grid{display:grid;grid-template-columns:1fr 1fr;gap:24px}
.astro-mncontact__card{background:#f7f3ef;border-radius:16px;padding:32px 28px;border-top:4px solid #9a2d2d}
.astro-mncontact__title{font-family:'Playfair Display',Georgia,serif;font-size:21px;color:#2c2420;margin:0 0 8px;font-weight:700}
.astro-mncontact__lead{font-size:14px;color:#9a2d2d;font-weight:600;margin:0 0 10px}
.astro-mncontact__txt{font-size:15.5px;color:#6b5c52;line-height:1.6;margin:0 0 12px}
.astro-mncontact__row{font-size:15px;color:#6b5c52;margin:0 0 8px;line-height:1.5}
.astro-mncontact__row span{color:#928269}
.astro-mncontact__row a{color:#9a2d2d;font-weight:600;text-decoration:none}
.astro-mncontact__row a:hover{text-decoration:underline}
@media(max-width:720px){.astro-mncontact__grid{grid-template-columns:1fr}.astro-mncontact{padding:8px 18px 48px}}
</style>
