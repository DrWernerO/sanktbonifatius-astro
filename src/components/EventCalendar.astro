---
// Termin-Kacheln (Abschnitt 7). Wiederverwendbar: per Props anpassbar, damit die Komponente
// auch auf Unterseiten (z.B. Gottesdienst & Glaube) mit eigener Überschrift und nur einer
// Termin-Kategorie genutzt werden kann. Defaults = bisheriges Startseiten-Verhalten.
//   heading  – Überschrift über den Kacheln
//   moreHref – Ziel des „Alle Termine →"-Links
//   category – event-category-ID; ist sie gesetzt, zeigt der Block NUR Termine dieser
//              Kategorie (clientseitig gefiltert). 0/leer = alle Termine.
const {
  heading = 'Unsere nächsten Veranstaltungen',
  moreHref = '/terminkalender/',
  category = 0,
  categoryLabel = '',
} = Astro.props;
---
<section class="astro-ev" data-category={category} data-category-label={categoryLabel}>
  <div class="astro-ev__inner">
    <div class="astro-ev__head">
      <h2 class="astro-ev__hl">{heading}</h2>
      <a href={moreHref} class="astro-ev__more">Alle Termine →</a>
    </div>
    <div class="astro-ev__grid">
      <div id="astro-ev-card1" class="astro-ev-card astro-ev-card--loading">Lädt …</div>
      <div id="astro-ev-card2" class="astro-ev-card astro-ev-card--loading">Lädt …</div>
      <div id="astro-ev-list" class="astro-ev-list">
        <h3 class="astro-ev-list__hl">Weitere Termine</h3>
        <div id="astro-ev-list-items" class="astro-ev-list__items">Lädt …</div>
      </div>
    </div>
  </div>
</section>

<style is:global>
.astro-ev{background:#f7f3ef;padding:28px 0;width:100vw;position:relative;left:50%;margin-left:-50vw;margin-right:-50vw}
.astro-ev__inner{max-width:1200px;margin:0 auto;padding:0 40px}
.astro-ev__head{display:flex;align-items:baseline;justify-content:space-between;margin:0 0 32px}
.astro-ev__hl{font-family:'Playfair Display',serif;font-size:28px;font-weight:700;color:#2c2420}
.astro-ev__more{font-size:13px;color:#928269;text-decoration:none;letter-spacing:.05em}
.astro-ev__more:hover{color:#2c2420}
/* align-items:stretch → alle drei Spalten gleich hoch */
.astro-ev__grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;align-items:stretch}
.astro-ev-card{border-radius:10px;overflow:hidden;background:#f7f3ef;box-shadow:0 2px 12px rgba(30,21,18,.06);text-decoration:none;color:#2c2420;display:flex;flex-direction:column;transition:transform .2s,box-shadow .2s}
.astro-ev-card:hover{transform:translateY(-3px);box-shadow:0 6px 20px rgba(30,21,18,.12)}
.astro-ev-card--loading{display:flex;align-items:center;justify-content:center;min-height:220px;color:#928269;font-size:14px}
.astro-ev-card__img{width:100%;height:220px !important;object-fit:cover !important;display:block;background:#ede8e1}
.astro-ev-card__body{padding:18px 22px 22px}
.astro-ev-card__meta{font-size:11px;letter-spacing:.06em;color:#928269;margin:0 0 8px;line-height:1.4}
.astro-ev-card__title{font-family:'Playfair Display',serif;font-size:17px;font-weight:700;line-height:1.3;margin:0 0 10px;color:#2c2420}
.astro-ev-card__sub{font-size:14px;color:#6b5c52;line-height:1.55;margin:0;font-style:normal;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}
/* Liste: füllt die volle Spaltenhöhe, Einträge gleichmäßig verteilt (space-between) */
.astro-ev-list{background:#fff;border-radius:10px;padding:20px 24px;box-shadow:0 2px 12px rgba(30,21,18,.07);display:flex;flex-direction:column}
.astro-ev-list__hl{font-family:'Playfair Display',serif;font-size:16px;font-weight:700;color:#2c2420;margin:0 0 6px;padding-bottom:12px;border-bottom:1px solid #ede8e1}
.astro-ev-list__items{flex:1;display:flex;flex-direction:column;justify-content:space-between}
.astro-ev-list__item{display:block;padding:10px 0;border-bottom:1px solid #f0ebe5;text-decoration:none;color:#2c2420}
.astro-ev-list__item:last-child{border-bottom:none}
.astro-ev-list__item:hover .astro-ev-list__title{color:#928269}
.astro-ev-list__date{display:flex;align-items:center;gap:6px;margin:0 0 3px;font-size:12px;color:#928269}
.astro-ev-list__icon{flex-shrink:0;color:#9a2d2d}
.astro-ev-list__day{font-weight:700;color:#2c2420;letter-spacing:.02em}
.astro-ev-list__time{color:#928269}
.astro-ev-list__title{font-size:14px;font-weight:600;color:#2c2420;margin:0;transition:color .2s;line-height:1.3}
/* Hinweistext in „Weitere Termine", wenn es aktuell keine weiteren Termine gibt */
.astro-ev-list__empty{flex:1;display:flex;align-items:flex-start;justify-content:flex-start;color:#928269;font-size:14px;line-height:1.6;padding-top:6px}
@media(max-width:860px){.astro-ev__grid{grid-template-columns:1fr 1fr}.astro-ev-list{grid-column:1/-1}}
@media(max-width:600px){.astro-ev__grid{grid-template-columns:1fr}.astro-ev__inner{padding:0 20px}}
</style>

<script>
(function() {
  // Proxy-Pfad — kein SSL-Problem im Browser
  const WP = '/wp-proxy/wp-json/wp/v2';
  const DAYS = ['So','Mo','Di','Mi','Do','Fr','Sa'];
  const MONTHS = ['Jan','Feb','Mär','Apr','Mai','Jun','Jul','Aug','Sep','Okt','Nov','Dez'];
  const MONTHS_LONG = ['Januar','Februar','März','April','Mai','Juni','Juli','August','September','Oktober','November','Dezember'];

  const CHURCH_NAMES = {
    'bonifatius': 'St. Bonifatius',
    'aposteln':   'St. Aposteln',
    'georgen':    'Sankt Georgen',
    'judas':      'St. Judas Thaddäus',
  };

  function parseDate(str) {
    return new Date(str.slice(0,4)+'-'+str.slice(4,6)+'-'+str.slice(6,8));
  }

  function formatMeta(m) {
    const d = parseDate(m.start_date);
    const day  = DAYS[d.getDay()];
    const date = d.getDate()+'. '+MONTHS_LONG[d.getMonth()]+' '+d.getFullYear();
    const time = m.times || '';
    const church = CHURCH_NAMES[m.church] || m.church || '';
    const parts = [day+', '+date];
    if (time)   parts.push(time);
    if (church) parts.push(church);
    return parts.join(' · ');
  }

  // WP-Termin-URL → interne Astro-Detailseite (/termine/<slug>/ = Pfad der WP-URL)
  function localPath(url) {
    try { return new URL(url).pathname; } catch (e) { return url || '#'; }
  }

  function renderCard(el, event, imgUrl) {
    const m = event.event_meta || {};
    el.className = 'astro-ev-card';
    el.href = localPath(event.link);
    const imgHtml = imgUrl
      ? '<img class="astro-ev-card__img" src="'+imgUrl+'" alt="'+event.title.rendered+'" loading="lazy">'
      : '<div class="astro-ev-card__img astro-ev-card__img--placeholder"></div>';
    el.innerHTML =
      imgHtml +
      '<div class="astro-ev-card__body">' +
        '<p class="astro-ev-card__meta">'+formatMeta(m)+'</p>' +
        '<h3 class="astro-ev-card__title">'+event.title.rendered+'</h3>' +
        (m.subtitle ? '<p class="astro-ev-card__sub">'+m.subtitle+'</p>' : '') +
      '</div>';
  }

  function renderList(items) {
    const container = document.getElementById('astro-ev-list-items');
    if (!container) return;
    container.innerHTML = items.map(function(ev) {
      const m = ev.event_meta || {};
      const d = parseDate(m.start_date);
      const church = CHURCH_NAMES[m.church] || m.location || '';
      return '<a href="'+localPath(ev.link)+'" class="astro-ev-list__item">' +
        '<div class="astro-ev-list__info">' +
          '<p class="astro-ev-list__date">' +
            '<svg class="astro-ev-list__icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>' +
            '<span class="astro-ev-list__day">'+d.getDate()+'. '+MONTHS[d.getMonth()]+'</span>' +
            (m.times ? '<span class="astro-ev-list__time">· '+m.times+'</span>' : '') +
          '</p>' +
          '<p class="astro-ev-list__title">'+ev.title.rendered+'</p>' +
        '</div>' +
      '</a>';
    }).join('');
  }

  async function loadImage(id) {
    if (!id) return null;
    try {
      const r = await fetch(WP+'/media/'+id+'?_fields=source_url');
      const d = await r.json();
      if (!d.source_url) return null;
      // Absolute WP-URLs (www/dev) → Proxy-Pfad umschreiben (gleiche Origin, kein CORS/SSL-Thema)
      return d.source_url.replace(/^https?:\/\/(?:www|dev)\.sanktbonifatius\.de(\.w021941a\.kasserver\.com)?/, '/wp-proxy');
    } catch(e) { return null; }
  }

  // Optionaler Kategorie-Filter aus dem data-Attribut (siehe Frontmatter-Prop `category`).
  const section = document.querySelector('.astro-ev');
  const CAT = section ? parseInt(section.dataset.category, 10) || 0 : 0;

  async function init() {
    const today = new Date().toISOString().slice(0,10).replace(/-/g,'');
    try {
      const r = await fetch(WP+'/event?per_page=100&_fields=id,title,link,event_meta,event-category');
      const all = await r.json();
      const upcoming = all
        .filter(function(e){ return e.event_meta && e.event_meta.start_date >= today; })
        .filter(function(e){ return !CAT || (e['event-category']||[]).indexOf(CAT) > -1; })
        .sort(function(a,b){ return a.event_meta.start_date.localeCompare(b.event_meta.start_date); });

      const card1 = document.getElementById('astro-ev-card1');
      const card2 = document.getElementById('astro-ev-card2');
      const grid = section ? section.querySelector('.astro-ev__grid') : null;

      // Karte 1 — nächster Termin (sonst Platzhalter entfernen, kein hängendes „Lädt …")
      if (upcoming[0] && card1) {
        const img = await loadImage(upcoming[0].event_meta.image);
        const a = document.createElement('a');
        card1.replaceWith(a);
        renderCard(a, upcoming[0], img);
      } else if (card1) {
        card1.remove();
      }
      // Karte 2 — übernächster Termin. Gibt es keinen zweiten Termin, lassen wir die
      // zweite Vorschau-Kachel ganz weg (Platzhalter entfernen).
      if (upcoming[1] && card2) {
        const img = await loadImage(upcoming[1].event_meta.image);
        const a = document.createElement('a');
        card2.replaceWith(a);
        renderCard(a, upcoming[1], img);
      } else if (card2) {
        card2.remove();
      }

      // Spalte „Weitere Termine": ab 3 Terminen die Liste der folgenden Termine; sonst
      // ein Hinweistext, dass es aktuell keine weiteren Termine gibt (bei gesetzter
      // Kategorie inkl. Bereichsname). Überschrift bleibt immer „Weitere Termine".
      const itemsEl = document.getElementById('astro-ev-list-items');
      if (upcoming.length > 2) {
        renderList(upcoming.slice(2, 6));
      } else if (itemsEl) {
        const label = section ? (section.dataset.categoryLabel || '') : '';
        itemsEl.classList.add('astro-ev-list__empty');
        itemsEl.textContent = label
          ? 'Aktuell keine weiteren Termine im Bereich „' + label + '“.'
          : 'Aktuell keine weiteren Termine.';
      }

      // Spaltenzahl an die tatsächlich sichtbaren Kacheln anpassen (keine leere Lücke)
      if (grid) {
        const tiles = grid.children.length;
        if (tiles <= 1) grid.style.gridTemplateColumns = '1fr';
        else if (tiles === 2) grid.style.gridTemplateColumns = '1fr 1fr';
      }

    } catch(e) {
      console.warn('Events konnten nicht geladen werden:', e);
    }
  }

  document.addEventListener('DOMContentLoaded', init);
})();
</script>
