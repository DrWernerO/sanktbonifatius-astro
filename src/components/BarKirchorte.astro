---
// „Wege an unseren Kirchorten" — Zugänglichkeit der vier Kirchorte als aufklappbare
// <details>-Blöcke (WP 49119). Eigene Klassen `astro-bar-ko`. Feste Inhalte.
const ORTE = [
  {
