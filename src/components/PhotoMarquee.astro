];
// Bildliste verdoppeln → nahtloser Loop (Animation läuft -50% der Gesamtbreite).
const loop = [...photos, ...photos];
---
<div class="astro-marquee">
  <h2 class="astro-marquee__hl">Unser Leben als Pfarrei</h2>
  <div class="astro-marquee__track">
    {loop.map((p, i) => (
      <img
        decoding="async"
        loading="lazy"
        src={HOST + p.u}
        alt={i < photos.length ? p.a : ''}
        aria-hidden={i >= photos.length ? 'true' : undefined}
      />
    ))}
  </div>
</div>

<style is:global>
/* Auf Content-Breite begrenzt (kein Full-Bleed) → gleiche Breite wie die übrigen Sektionen,
   plus vertikaler Abstand zu Nachbarelementen. */
.astro-marquee{overflow:hidden;background:#2c2420;padding:14px 0;width:calc(100% - 80px);max-width:1120px;margin:48px auto;border-radius:12px}
.astro-marquee__hl{text-align:center;color:#c5a55a;font-size:.75rem;font-weight:400;letter-spacing:.15em;text-transform:uppercase;margin:0 0 8px;font-family:'Source Sans 3',sans-serif}
.astro-marquee__track{display:flex;gap:10px;width:max-content;animation:astro-marquee-scroll 150s linear infinite}
.astro-marquee__track:hover{animation-play-state:paused}
.astro-marquee__track img{height:204px;width:auto;object-fit:cover;border-radius:4px;display:block;flex-shrink:0}
@keyframes astro-marquee-scroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}
@media(max-width:600px){.astro-marquee{width:calc(100% - 40px);margin:32px auto}}
@media(prefers-reduced-motion:reduce){.astro-marquee__track{animation:none;overflow-x:auto}}
</style>
