---
// Kachel-Grid „Deine Möglichkeiten" der Seite „Engagement" (WP-Block `eng-kacheln`).
// Eigene Klassen `astro-eng-tiles`. 6 Karten mit Icon, Lead, einer oder mehreren Optionen
// (Titel + Text + Zitat) und einem Mehr-Link. Inhalte 1:1 aus WP übernommen.
// Props:
//   heading  – Überschrift der Sektion
//   eyebrow  – kleine Auszeichnung über der Überschrift
//   cards    – [{ icon, title, lead, opts:[{title,text,quote}], href, linkText }]
const { heading, eyebrow, cards = [] } = Astro.props;
---
<section class="astro-eng-tiles" id="ich-mache-mit">
  <div class="astro-eng-tiles__inner">
    <div class="astro-eng-tiles__head">
      {eyebrow && <p class="astro-eng-tiles__eyebrow">{eyebrow}</p>}
      <h2 class="astro-eng-tiles__hl" set:html={heading} />
    </div>
    <div class="astro-eng-tiles__grid">
      {cards.map((c) => (
        <article class="astro-eng-card">
          <div class="astro-eng-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={c.icon} />
          </div>
          <h3 class="astro-eng-card__title" set:html={c.title} />
          <p class="astro-eng-card__lead" set:html={c.lead} />
          <ul class="astro-eng-card__opts">
            {c.opts.map((o) => (
              <li class="astro-eng-card__opt">
                <p class="astro-eng-card__opt-title" set:html={o.title} />
                <p class="astro-eng-card__opt-text" set:html={o.text} />
                {o.quote && <p class="astro-eng-card__quote" set:html={o.quote} />}
              </li>
            ))}
          </ul>
          <a class="astro-eng-card__link" href={c.href} set:html={c.linkText} />
        </article>
      ))}
    </div>
  </div>
</section>

<style is:global>
.astro-eng-tiles{background:#f7f3ef;padding:80px 0}
.astro-eng-tiles__inner{max-width:1200px;margin:0 auto;padding:0 40px}
.astro-eng-tiles__head{text-align:center;margin:0 0 48px}
.astro-eng-tiles__eyebrow{font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:#9a2d2d;margin:0 0 12px;font-weight:600}
.astro-eng-tiles__hl{font-family:'Playfair Display',serif;font-size:clamp(26px,3.5vw,42px);font-weight:700;color:#2c2420;margin:0;line-height:1.15}
.astro-eng-tiles__grid{display:grid;grid-template-columns:repeat(2,1fr);gap:28px}
.astro-eng-card{display:flex;flex-direction:column;background:#fff;border-radius:16px;padding:36px 32px;box-shadow:0 2px 14px rgba(30,21,18,.07);border-top:4px solid #9a2d2d;transition:transform .15s,box-shadow .2s}
.astro-eng-card:hover{transform:translateY(-3px);box-shadow:0 10px 32px rgba(30,21,18,.12)}
.astro-eng-card__icon{width:48px;height:48px;background:#f7f3ef;border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:18px;color:#9a2d2d}
.astro-eng-card__icon svg{width:24px;height:24px}
.astro-eng-card__title{font-family:'Playfair Display',serif;font-size:22px;font-weight:700;color:#2c2420;margin:0 0 12px;line-height:1.2}
.astro-eng-card__lead{font-size:15px;color:#6b5c52;line-height:1.65;margin:0 0 20px}
.astro-eng-card__opts{list-style:none;padding:0;margin:0 0 20px;display:flex;flex-direction:column;gap:16px}
.astro-eng-card__opt{border-left:3px solid #c5a55a;padding-left:14px}
.astro-eng-card__opt-title{font-weight:700;font-size:14px;color:#2c2420;margin:0 0 4px}
.astro-eng-card__opt-text{font-size:13.5px;color:#6b5c52;line-height:1.55;margin:0 0 8px}
.astro-eng-card__quote{font-size:13px;font-style:italic;color:#7e2424;line-height:1.5;margin:0;padding:8px 12px;background:#f7f3ef;border-radius:6px}
.astro-eng-card__quote::before{content:"\201E"}
.astro-eng-card__quote::after{content:"\201C"}
.astro-eng-card__link{font-size:14px;font-weight:600;color:#9a2d2d;text-decoration:none;align-self:flex-start;margin-top:auto;border-bottom:1px solid rgba(154,45,45,.35);padding-bottom:2px;transition:border-color .2s}
.astro-eng-card__link:hover{border-color:#9a2d2d}
@media(max-width:860px){.astro-eng-tiles__grid{grid-template-columns:1fr}}
@media(max-width:600px){.astro-eng-tiles{padding:56px 0}.astro-eng-tiles__inner{padding:0 20px}.astro-eng-card{padding:28px 24px}}
</style>
