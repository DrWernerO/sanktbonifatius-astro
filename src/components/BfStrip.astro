---
// Schnellzugriff-Band der BonFamily-Seite — Präfix `astro-bfstrip`.
// Gestaltung wie das Schnellzugriff-Band „Engagiert Leben" (ElStrip.astro, Handbuch 17):
// weiße Pill-Buttons mit dünnem Rand + SVG-Icon in der Rubrik-Farbe (BonFamily-Bordeaux),
// Hover füllt die Pille. Springt zu den Anker-Sektionen der Seite.
const links = [
  { label: 'Familientreffpunkte', href: '#bonfamily-lounge',
    icon: '<path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/>' },
  { label: 'Familiengottesdienste', href: '#bonfamily-gottesdienste',
    icon: '<path d="M10 9h4"/><path d="M12 7v5"/><path d="M14 22v-4a2 2 0 0 0-2-2a2 2 0 0 0-2 2v4"/><path d="M18 22V5.618a1 1 0 0 0-.553-.894l-4.553-2.277a2 2 0 0 0-1.788 0L6.553 4.724A1 1 0 0 0 6 5.618V22"/><path d="m18 7 3.447 1.724a1 1 0 0 1 .553.894V20a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V9.618a1 1 0 0 1 .553-.894L6 7"/>' },
  { label: 'Taufe', href: '#bonfamily-taufe',
    icon: '<path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z"/>' },
  { label: 'WhatsApp-Kanal', href: '/bonfamily/whatsapp-kanal/',
    icon: '<path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/>' },
  { label: 'Kontakt', href: '#bonfamily-kontakt',
    icon: '<rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>' },
];
---
<nav class="astro-bfstrip" aria-label="Schnellzugriff BonFamily">
  <div class="astro-bfstrip__inner">
    <span class="astro-bfstrip__label">Schnellzugriff:</span>
    <div class="astro-bfstrip__row">
      {links.map(l => (
        <a href={l.href} class="astro-bfstrip__link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
               aria-hidden="true" set:html={l.icon} />
          {l.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<style is:global>
.astro-bfstrip{background:#f7f3ef;padding:22px 0;width:100vw;position:relative;left:50%;margin-left:-50vw;margin-right:-50vw}
.astro-bfstrip__inner{max-width:1280px;margin:0 auto;padding:0 32px;display:flex;align-items:center;justify-content:center;flex-wrap:wrap;gap:14px}
.astro-bfstrip__label{font-weight:700;color:#1e1512;font-size:15px;margin-right:6px}
.astro-bfstrip__row{display:flex;flex-wrap:wrap;gap:10px}
.astro-bfstrip__link{display:inline-flex;align-items:center;gap:8px;padding:8px 14px;border-radius:999px;background:#fff;color:#1e1512;text-decoration:none;font-size:14px;font-weight:700;border:1px solid rgba(0,0,0,.08);transition:all .2s}
.astro-bfstrip__link svg{flex-shrink:0;color:#9a2d2d}
.astro-bfstrip__link:hover{background:#9a2d2d;color:#fff;border-color:#9a2d2d}
.astro-bfstrip__link:hover svg{color:#fff}
@media(max-width:760px){.astro-bfstrip__inner{flex-direction:column;align-items:flex-start}}
@media(max-width:600px){.astro-bfstrip__inner{padding:0 16px}}
</style>
