---
// Beitrags-/News-Grid für den BoniBlog (Präfix astro-blog / astro-bc).
// Beiträge (posts) + News (pin) gemischt nach Datum (getAktuelles, server-seitig).
// Da es insgesamt nur ~33 Einträge sind, wird alles gebaut und beim Build gemischt;
// "Mehr laden" blendet weitere bereits gerenderte Karten ein (kein Client-Merge nötig).
import { getAktuelles } from '../lib/wordpress.js';
const items = await getAktuelles();
const PER_PAGE = 9;
const fmt = (iso) => new Date(iso).toLocaleDateString('de-DE', { day: 'numeric', month: 'long', year: 'numeric' });
---
<section class="astro-blog">
  <div class="astro-blog__inner">
    <div class="astro-blog__grid" id="astro-blog-grid">
      {items.map((it, i) => (
        <a href={it.link} class="astro-bc" hidden={i >= PER_PAGE} data-news-id={it.kind === 'news' ? it.id : undefined}>
          <div class="astro-bc__media">
            {it.image
              ? <img class="astro-bc__img" src={it.image} alt={it.title} loading="lazy" />
              : <div class="astro-bc__img astro-bc__img--ph"></div>}
            {it.type === 'video' && (
              <span class="astro-bc__badge" aria-label="Video">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
                Video
              </span>
            )}
            {it.type === 'gallery' && (
              <span class="astro-bc__badge" aria-label="Fotogalerie">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="14" height="14" rx="2"/><path d="M21 7v12a2 2 0 0 1-2 2H7"/></svg>
                {it.galleryCount > 0 ? it.galleryCount + ' Fotos' : 'Galerie'}
              </span>
            )}
          </div>
          <div class="astro-bc__body">
            <p class="astro-bc__date">{fmt(it.date)}</p>
            <h3 class="astro-bc__title" set:html={it.title} />
            {it.excerpt && <p class="astro-bc__excerpt" set:html={it.excerpt} />}
          </div>
        </a>
      ))}
    </div>

    {items.length === 0 && <p class="astro-blog__empty">Zurzeit sind keine Beiträge vorhanden.</p>}

    <div class="astro-blog__more-wrap">
      <button type="button" class="astro-blog__more" id="astro-blog-more"
              data-per={PER_PAGE} style={items.length > PER_PAGE ? '' : 'display:none'}>
        Mehr anzeigen
      </button>
    </div>
  </div>
</section>

<style is:global>
.astro-blog{background:#fff;padding:56px 0 24px}
.astro-blog__inner{max-width:1200px;margin:0 auto;padding:0 40px}
.astro-blog__grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.astro-bc{display:block;border-radius:10px;overflow:hidden;background:#f7f3ef;text-decoration:none;
  color:#2c2420;box-shadow:0 2px 12px rgba(30,21,18,.06);transition:transform .2s,box-shadow .2s}
.astro-bc[hidden]{display:none}
.astro-bc:hover{transform:translateY(-3px);box-shadow:0 6px 20px rgba(30,21,18,.12)}
.astro-bc__media{position:relative}
.astro-bc__img{width:100%;height:200px;object-fit:cover;display:block}
.astro-bc__img--ph{background:#ede8e1}
.astro-bc__badge{position:absolute;top:10px;left:10px;display:inline-flex;align-items:center;gap:5px;
  background:rgba(44,36,32,.82);color:#fff;font-size:11px;font-weight:600;letter-spacing:.02em;
  padding:4px 9px;border-radius:50px;backdrop-filter:blur(2px)}
.astro-bc__badge svg{display:block}
.astro-bc__body{padding:20px 22px}
.astro-bc__date{font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:#928269;margin:0 0 8px}
.astro-bc__title{font-family:'Playfair Display',serif;font-size:18px;font-weight:700;line-height:1.3;color:#2c2420;margin:0 0 10px}
.astro-bc__excerpt{font-size:14px;color:#6b5c52;line-height:1.55;margin:0;
  display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}
.astro-blog__empty{text-align:center;color:#928269;font-size:15px;padding:40px 0}
.astro-blog__more-wrap{display:flex;justify-content:center;margin:40px 0 8px}
.astro-blog__more{font-family:inherit;font-size:14px;font-weight:600;color:#fff;background:#9a2d2d;
  border:none;border-radius:50px;padding:13px 32px;cursor:pointer;transition:background .2s}
.astro-blog__more:hover{background:#7e2424}
@media(max-width:860px){.astro-blog__grid{grid-template-columns:1fr 1fr}}
@media(max-width:600px){.astro-blog__grid{grid-template-columns:1fr}.astro-blog__inner{padding:0 20px}}
</style>

<script>
(function(){
  // Alle Karten sind bereits gerendert (server-seitig gemischt). "Mehr anzeigen" blendet
  // nur die nächsten PER versteckten Karten ein — kein Nachladen/Mischen im Browser nötig.
  var grid = document.getElementById('astro-blog-grid');
  var btn  = document.getElementById('astro-blog-more');
  if(!grid || !btn) return;
  var per = parseInt(btn.dataset.per, 10) || 9;
  btn.addEventListener('click', function(){
    var hidden = grid.querySelectorAll('.astro-bc[hidden]');
    for(var i = 0; i < per && i < hidden.length; i++) hidden[i].removeAttribute('hidden');
    if(grid.querySelectorAll('.astro-bc[hidden]').length === 0) btn.style.display = 'none';
  });
})();
</script>
