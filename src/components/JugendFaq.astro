---
// „Fragen & Antworten" (WP-Block `jug-faq`). Eigene Klassen `astro-jufaq`.
// Natives <details> (kein JS, Muster wie SegenFaq/TaufeFaq). Crème-Hintergrund (Bänder-Prinzip).
// Hinweis: Auf der Live-Seite hatten zwei weitere Fragen ("Jugendangebote in allen Kirchorten?",
// "konfessionslos?") KEINE Antworttexte — daher hier bewusst weggelassen, bis Antworten vorliegen.
const FAQ = [
  { q: 'Ab welchem Alter kann ich Ministrant werden?',
    a: 'Kinder k&ouml;nnen ab der 3. Klasse mit der Ausbildung beginnen. Nach einer Vorbereitungszeit findet die erste feierliche Einf&uuml;hrung als Ministrant statt. Wir freuen uns &uuml;ber jedes neue Gesicht!' },
  { q: 'Wann findet die n&auml;chste Firmung statt, und wie melde ich mich an?',
    a: 'Die Firmung wird in der Regel im Fr&uuml;hjahr gefeiert. Die Vorbereitung beginnt etwa ein Jahr vorher. F&uuml;r genaue Termine und die Anmeldung wende dich bitte an unser Pfarrb&uuml;ro oder an unsere Jugendansprechpartner.' },
  { q: 'Wie kann ich bei einer Jugendgruppe mitmachen?',
    a: 'Am einfachsten: einfach beim n&auml;chsten Treffen vorbeikommen! Alle Gruppen freuen sich &uuml;ber neue Gesichter. Du kannst auch per E-Mail oder Telefon Kontakt aufnehmen &#8212; die Adressen stehen oben.' },
];
---
<section class="astro-jufaq">
  <div class="astro-jufaq__inner">
    <p class="astro-jufaq__eyebrow">H&auml;ufige Fragen</p>
    <h2 class="astro-jufaq__hl">Fragen &amp; Antworten</h2>
    <div class="astro-jufaq__list">
      {FAQ.map((f) => (
        <details>
          <summary><span set:html={f.q} /></summary>
          <div class="astro-jufaq__a" set:html={f.a} />
        </details>
      ))}
    </div>
  </div>
</section>

<style is:global>
.astro-jufaq{background:#f7f3ef;padding:80px 0}
.astro-jufaq__inner{max-width:840px;margin:0 auto;padding:0 40px}
.astro-jufaq__eyebrow{font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:#9a2d2d;margin:0 0 14px;font-weight:600;text-align:center}
.astro-jufaq__hl{font-family:'Playfair Display',serif;font-size:clamp(26px,3.4vw,40px);font-weight:700;color:#2c2420;margin:0 0 36px;text-align:center}
.astro-jufaq__list{max-width:840px;margin:0 auto}
.astro-jufaq details{background:#fff;border-radius:10px;margin-bottom:10px;box-shadow:0 2px 12px rgba(30,21,18,.05);overflow:hidden}
.astro-jufaq summary{padding:20px 24px;cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;gap:12px;font-weight:600;font-size:16px;color:#2c2420}
.astro-jufaq summary::-webkit-details-marker{display:none}
.astro-jufaq summary::after{content:"+";font-size:24px;color:#9a2d2d;transition:transform .2s;flex-shrink:0}
.astro-jufaq details[open] summary::after{transform:rotate(45deg)}
.astro-jufaq__a{padding:0 24px 20px;font-size:15px;color:#3d3530;line-height:1.65}
@media(max-width:600px){.astro-jufaq{padding:56px 0}.astro-jufaq__inner{padding:0 20px}}
</style>
