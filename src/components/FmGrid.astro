---
// Treffpunkt-Karten „Familientreffpunkte" — Präfix `astro-fmgrid`.
// Karte 1: Baby-/Familien-Lounge St. Bonifatius (2 Gruppen)
// Karte 2: Eltern-Kind-Gruppe St. Wendel (externe Anmeldung)
---
<section class="astro-fmgrid">
  <div class="astro-fmgrid__inner">
    <div class="astro-fmgrid__head">
      <h2 class="astro-fmgrid__title">Unsere Treffpunkte</h2>
      <p class="astro-fmgrid__sub">Drei laufende Angebote für Familien an zwei Kirchorten.</p>
    </div>
    <div class="astro-fmgrid__grid">

      <!-- Karte 1: St. Bonifatius -->
      <article class="astro-fmcard">
        <div class="astro-fmcard__img-wrap">
          <img src="/uploads/2023/04/babylounge-stbonifatius-frankfurt-37-1024x767.jpg"
               alt="Baby-Lounge im Kleinen Pfarrsaal St. Bonifatius Frankfurt"
               class="astro-fmcard__img" loading="lazy" width="1024" height="767" />
        </div>
        <div class="astro-fmcard__body">
          <h3 class="astro-fmcard__title">Baby- und Familien-Lounge St. Bonifatius</h3>

          <div class="astro-fmcard__group">
            <p class="astro-fmcard__group-label">Baby-Lounge <span class="astro-fmcard__group-age">Kinder bis 12 Monate</span></p>
            <div class="astro-fmcard__meta-row">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              <span>Freitags · 09:30–11:30 Uhr</span>
            </div>
            <p class="astro-fmcard__note">außer Brückentagen und hess. Schulferien</p>
          </div>

          <div class="astro-fmcard__group">
            <p class="astro-fmcard__group-label">Familien-Lounge <span class="astro-fmcard__group-age">Kinder 1–3 Jahre</span></p>
            <div class="astro-fmcard__meta-row">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              <span>Freitags · 15:30–17:30 Uhr</span>
            </div>
            <p class="astro-fmcard__note">außer Brückentagen und hess. Schulferien</p>
          </div>

          <div class="astro-fmcard__info">
            <div class="astro-fmcard__meta-row">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              <span>Leitung: Barbara Schröder-Spitzenberg (DELFI)</span>
            </div>
            <div class="astro-fmcard__meta-row">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <span>Kleiner Pfarrsaal St. Bonifatius, Zugang Achenbachstraße</span>
            </div>
          </div>
          <p class="astro-fmcard__free">Kostenlos · Keine Anmeldung nötig</p>
          <a href="/kontakt/pfarrbuero/" class="astro-fmcard__btn">Fragen? Pfarrbüro kontaktieren</a>
        </div>
      </article>

      <!-- Karte 2: St. Wendel -->
      <article class="astro-fmcard">
        <div class="astro-fmcard__img-wrap">
          <img src="/uploads/2023/04/babylounge-st-bonifatius-1024x684.jpeg"
               alt="Eltern-Kind-Gruppe bei St. Wendel Frankfurt"
               class="astro-fmcard__img" loading="lazy" width="1024" height="684" />
        </div>
        <div class="astro-fmcard__body">
          <h3 class="astro-fmcard__title">Eltern-Kind-Gruppe St. Wendel</h3>

          <div class="astro-fmcard__group">
            <p class="astro-fmcard__group-label">Kinder 1–3 Jahre <span class="astro-fmcard__group-age">8 Treffen pro Kurs</span></p>
            <div class="astro-fmcard__meta-row">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              <span>Mittwochs · 09:15–11:15 Uhr · Start: 12.08.2026</span>
            </div>
          </div>

          <div class="astro-fmcard__group">
            <p class="astro-fmcard__group-label">Inhalte</p>
            <p class="astro-fmcard__group-text">Altersgerechte Spiel- und Sinnesanregungen, Lieder, kurze Impulse zu Entwicklung und Familienalltag, Zeit für Fragen und Vernetzung.</p>
          </div>

          <div class="astro-fmcard__info">
            <div class="astro-fmcard__meta-row">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              <span>Leitung: Susanne Tombers</span>
            </div>
            <div class="astro-fmcard__meta-row">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <span>Gemeinderaum St. Wendel, Altes Schützenhüttengäßchen 6</span>
            </div>
            <div class="astro-fmcard__meta-row">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 1 0 0 7h5a3.5 3.5 0 1 1 0 7H6"/></svg>
              <span>56 € für 8 Treffen</span>
            </div>
          </div>
          <a href="https://kufer-web.bistumlimburg.de/frankfurt-fbs/webbasys/index.php?kathaupt=11&knr=261-2600&kursname=Eltern-Kind-Gruppe"
             target="_blank" rel="noopener" class="astro-fmcard__btn">
            Über Kath. Familienbildung anmelden
          </a>
        </div>
      </article>

    </div>
  </div>
</section>

<style is:global>
.astro-fmgrid{padding:56px 0 72px;background:#fff;width:100vw;position:relative;left:50%;margin-left:-50vw;margin-right:-50vw}
.astro-fmgrid__inner{max-width:1200px;margin:0 auto;padding:0 40px}
.astro-fmgrid__head{text-align:center;margin-bottom:48px}
.astro-fmgrid__title{font-family:'Playfair Display',Georgia,serif;font-size:clamp(26px,3.5vw,38px);font-weight:700;color:#9a2d2d;margin:0 0 12px}
.astro-fmgrid__sub{font-size:17px;color:#6b5c52;margin:0}
.astro-fmgrid__grid{display:grid;grid-template-columns:1fr 1fr;gap:32px}
.astro-fmcard{background:#f7f3ef;border:1px solid #e0d8cf;border-radius:16px;overflow:hidden;display:flex;flex-direction:column;box-shadow:0 4px 24px rgba(30,21,18,.07)}
.astro-fmcard__img-wrap{height:240px;overflow:hidden;flex-shrink:0}
.astro-fmcard__img{width:100%;height:100%;object-fit:cover;display:block}
.astro-fmcard__body{padding:28px;display:flex;flex-direction:column;gap:18px;flex:1}
.astro-fmcard__title{font-family:'Playfair Display',Georgia,serif;font-size:20px;font-weight:700;color:#2c2420;margin:0}
.astro-fmcard__group{background:#fff;border-radius:10px;padding:14px 16px;border:1px solid #e8e0d8;display:flex;flex-direction:column;gap:6px}
.astro-fmcard__group-label{font-size:13px;font-weight:700;color:#9a2d2d;letter-spacing:.04em;text-transform:uppercase;margin:0;display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.astro-fmcard__group-age{font-size:12px;font-weight:500;color:#928269;text-transform:none;letter-spacing:0}
.astro-fmcard__group-text{font-size:14px;line-height:1.6;color:#5a4a3a;margin:4px 0 0}
.astro-fmcard__meta-row{display:flex;align-items:flex-start;gap:8px;font-size:14px;color:#3d2b1a;line-height:1.4}
.astro-fmcard__meta-row svg{flex-shrink:0;margin-top:1px;color:#9a2d2d}
.astro-fmcard__note{font-size:12px;color:#928269;font-style:italic;margin:2px 0 0}
.astro-fmcard__info{display:flex;flex-direction:column;gap:8px;margin-top:4px}
.astro-fmcard__free{font-size:13px;font-weight:600;color:#128C7E;margin:0}
.astro-fmcard__btn{display:inline-flex;align-items:center;padding:11px 20px;background:#9a2d2d;color:#fff;font-size:14px;font-weight:600;text-decoration:none;border-radius:50px;transition:background .18s;margin-top:auto;align-self:flex-start}
.astro-fmcard__btn:hover{background:#7e2424}
@media(max-width:860px){.astro-fmgrid__grid{grid-template-columns:1fr}}
@media(max-width:600px){.astro-fmgrid__inner{padding:0 20px}.astro-fmgrid{padding:40px 0 56px}}
</style>
