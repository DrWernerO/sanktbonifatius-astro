---
// „Ein Fest für die Familie" (WP-Block `ta-fest` mit Foto-Galerie). Eigene Klassen `astro-tafest`
// + eigene Lightbox (Muster aus GdGallery.astro). Bilder lokal in public/uploads/2023/03
// (vom WP heruntergeladen, Handbuch 1b). 34 Taufe-Fotos; 6 als Vorschau, Rest in der Lightbox.
const IMG = '/uploads/2023/03';
const photos = Array.from({ length: 34 }, (_, i) => ({
  src: `${IMG}/taufe-stbonifatius-${i + 1}.jpg`,
  alt: `Taufe in Sankt Bonifatius (${i + 1})`,
}));
const previews = photos.slice(0, 6);
---
<section class="astro-tafest" id="astro-tafest">
  <div class="astro-tafest__inner">
    <div class="astro-tafest__head">
      <h2 class="astro-tafest__hl">Taufe in Sankt Bonifatius &#8211; ein Fest für die Familie</h2>
      <p class="astro-tafest__sub">Eindrücke aus unseren Taufgottesdiensten. Klicken Sie auf ein Foto, um die Galerie zu öffnen.</p>
    </div>
    <div class="astro-tafest__grid" id="astro-tafest-grid">
      {previews.map((p, i) => (
        <button type="button" class="astro-tafest__cell" data-index={i} aria-label={`Foto ${i + 1} öffnen`}>
          <img class="astro-tafest__img" src={p.src} alt={p.alt} loading="lazy" />
        </button>
      ))}
    </div>
    <div class="astro-tafest__more">
      <button type="button" class="astro-tafest__open-all" id="astro-tafest-open-all">Alle Fotos anzeigen &#8594;</button>
    </div>
  </div>

  <div class="astro-tafest__data" id="astro-tafest-data" data-photos={JSON.stringify(photos)} hidden></div>

  <div class="astro-tafest__lb" id="astro-tafest-lb" aria-hidden="true">
    <button type="button" class="astro-tafest__lb-close" id="astro-tafest-close" aria-label="Galerie schließen">&times;</button>
    <button type="button" class="astro-tafest__lb-nav astro-tafest__lb-prev" id="astro-tafest-prev" aria-label="Vorheriges Foto">&#8249;</button>
    <img class="astro-tafest__lb-img" id="astro-tafest-lb-img" src="" alt="" />
    <button type="button" class="astro-tafest__lb-nav astro-tafest__lb-next" id="astro-tafest-next" aria-label="Nächstes Foto">&#8250;</button>
    <span class="astro-tafest__lb-count" id="astro-tafest-count"></span>
  </div>
</section>

<style is:global>
.astro-tafest{background:#f7f3ef;padding:72px 0}
.astro-tafest__inner{max-width:1100px;margin:0 auto;padding:0 40px}
.astro-tafest__head{text-align:center;margin:0 0 40px}
.astro-tafest__hl{font-family:'Playfair Display',serif;font-size:clamp(24px,3.2vw,38px);font-weight:700;color:#2c2420;margin:0 0 14px;line-height:1.2}
.astro-tafest__sub{font-size:clamp(15px,1.7vw,18px);color:#6b5c52;line-height:1.6;margin:0 auto;max-width:600px}
.astro-tafest__grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
.astro-tafest__cell{padding:0;border:none;background:#ede8e1;border-radius:10px;overflow:hidden;cursor:pointer;aspect-ratio:4/3}
.astro-tafest__img{width:100%;height:100%;object-fit:cover;transition:transform .4s ease}
.astro-tafest__cell:hover .astro-tafest__img{transform:scale(1.06)}
.astro-tafest__more{text-align:center;margin:28px 0 0}
.astro-tafest__open-all{background:#c5a55a;color:#2c2420;border:none;padding:13px 28px;border-radius:50px;font-size:15px;font-weight:600;cursor:pointer;transition:background .2s}
.astro-tafest__open-all:hover{background:#b3914a}
.astro-tafest__lb{position:fixed;inset:0;z-index:2000;background:rgba(18,12,8,.92);display:none;align-items:center;justify-content:center}
.astro-tafest__lb.is-open{display:flex}
.astro-tafest__lb-img{max-width:88vw;max-height:84vh;border-radius:6px;box-shadow:0 12px 50px rgba(0,0,0,.5)}
.astro-tafest__lb-close{position:absolute;top:22px;right:28px;background:none;border:none;color:#f0e8d8;font-size:40px;line-height:1;cursor:pointer}
.astro-tafest__lb-nav{position:absolute;top:50%;transform:translateY(-50%);background:rgba(0,0,0,.35);border:none;color:#fff;font-size:44px;line-height:1;width:60px;height:80px;cursor:pointer;border-radius:8px;transition:background .2s}
.astro-tafest__lb-nav:hover{background:rgba(0,0,0,.6)}
.astro-tafest__lb-prev{left:22px}
.astro-tafest__lb-next{right:22px}
.astro-tafest__lb-count{position:absolute;bottom:24px;left:0;right:0;text-align:center;color:#e0d6c6;font-size:14px;letter-spacing:.05em}
@media(max-width:860px){.astro-tafest__grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:560px){.astro-tafest__grid{grid-template-columns:1fr}.astro-tafest{padding:52px 0}.astro-tafest__inner{padding:0 20px}.astro-tafest__lb-nav{width:46px;height:64px;font-size:34px}}
</style>

<script>
(function(){
  const root = document.getElementById('astro-tafest');
  const lb   = document.getElementById('astro-tafest-lb');
  if(!root || !lb) return;
  const dataEl = document.getElementById('astro-tafest-data');
  let sources = [];
  try { sources = JSON.parse(dataEl.getAttribute('data-photos') || '[]'); } catch(e) { sources = []; }
  const lbImg = document.getElementById('astro-tafest-lb-img');
  const count = document.getElementById('astro-tafest-count');
  let cur = 0;

  function show(i){
    cur = (i + sources.length) % sources.length;
    lbImg.src = sources[cur].src;
    lbImg.alt = sources[cur].alt;
    count.textContent = (cur+1) + ' / ' + sources.length;
  }
  function open(i){ show(i); lb.classList.add('is-open'); lb.setAttribute('aria-hidden','false'); document.body.style.overflow='hidden'; }
  function close(){ lb.classList.remove('is-open'); lb.setAttribute('aria-hidden','true'); document.body.style.overflow=''; }

  root.querySelectorAll('.astro-tafest__cell').forEach(function(c){
    c.addEventListener('click', function(){ open(parseInt(c.getAttribute('data-index'),10)||0); });
  });
  document.getElementById('astro-tafest-open-all').addEventListener('click', function(){ open(0); });
  document.getElementById('astro-tafest-close').addEventListener('click', close);
  document.getElementById('astro-tafest-prev').addEventListener('click', function(){ show(cur-1); });
  document.getElementById('astro-tafest-next').addEventListener('click', function(){ show(cur+1); });
  lb.addEventListener('click', function(e){ if(e.target===lb) close(); });
  document.addEventListener('keydown', function(e){
    if(!lb.classList.contains('is-open')) return;
    if(e.key==='Escape') close();
    else if(e.key==='ArrowLeft') show(cur-1);
    else if(e.key==='ArrowRight') show(cur+1);
  });
})();
</script>
