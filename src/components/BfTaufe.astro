---
// Taufe-Kurzinfo auf der BonFamily-Seite — Teaser mit Link zur Taufe-Seite.
// Präfix `astro-bftaufe` (nicht `bf-taufe-...`).
const punkte = [
  'Persönliches Taufgespräch mit dem Pfarrer',
  'Taufvorbereitung für Eltern und Paten',
  'Feierliche Taufe in St. Bonifatius oder St. Wendel',
  'Offen für alle Familien – auch ohne Kirchenmitgliedschaft',
];
---
<section class="astro-bftaufe">
  <div class="astro-bftaufe__inner">
    <div class="astro-bftaufe__text">
      <h2 class="astro-bftaufe__title">Ihr Kind taufen lassen</h2>
      <p class="astro-bftaufe__lead">
        Die Taufe ist der Beginn einer Gemeinschaft &ndash; mit Gott und mit den Menschen.
        Wir begleiten Sie und Ihre Familie herzlich in diesen besonderen Moment des Lebens.
      </p>
      <ul class="astro-bftaufe__list">
        {punkte.map(p => (
          <li class="astro-bftaufe__item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#9a2d2d" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            {p}
          </li>
        ))}
      </ul>
      <div class="astro-bftaufe__btns">
        <a href="/segen-sakramente/taufe/" class="astro-bftaufe__btn astro-bftaufe__btn--primary">
          Zur Taufe informieren
        </a>
        <a href="mailto:info@sanktbonifatius.de" class="astro-bftaufe__btn astro-bftaufe__btn--outline">
          Kontakt aufnehmen
        </a>
      </div>
    </div>
    <div class="astro-bftaufe__deco" role="img" aria-label="Taufkerze – Symbol für die Taufe">
      <svg class="astro-bftaufe__symbol" viewBox="0 0 120 180" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <ellipse cx="60" cy="160" rx="18" ry="8" fill="#e0d8cf" opacity=".6"/>
        <rect x="52" y="60" width="16" height="100" rx="8" fill="#f7f3ef" stroke="#e0d8cf" stroke-width="1.5"/>
        <path d="M60 10 Q65 30 60 55 Q55 30 60 10Z" fill="#c5a55a"/>
        <ellipse cx="60" cy="57" rx="5" ry="3" fill="#b88a3a" opacity=".6"/>
        <line x1="60" y1="57" x2="60" y2="60" stroke="#928269" stroke-width="1.5"/>
      </svg>
    </div>
  </div>
</section>

<style is:global>
.astro-bftaufe{padding:72px 0;background:#f7f3ef;width:100vw;position:relative;left:50%;margin-left:-50vw;margin-right:-50vw}
.astro-bftaufe__inner{max-width:1200px;margin:0 auto;padding:0 40px;display:grid;grid-template-columns:1fr auto;gap:60px;align-items:center}
.astro-bftaufe__title{font-family:'Playfair Display',Georgia,serif;font-size:clamp(26px,3vw,36px);font-weight:700;color:#9a2d2d;margin:0 0 16px}
.astro-bftaufe__lead{font-size:17px;line-height:1.7;color:#5a4a3a;margin:0 0 24px;max-width:560px}
.astro-bftaufe__list{list-style:none;padding:0;margin:0 0 32px;display:flex;flex-direction:column;gap:10px}
.astro-bftaufe__item{display:flex;align-items:flex-start;gap:10px;font-size:15px;color:#3d2b1a;line-height:1.5}
.astro-bftaufe__item svg{flex-shrink:0;margin-top:2px}
.astro-bftaufe__btns{display:flex;gap:12px;flex-wrap:wrap}
.astro-bftaufe__btn{display:inline-flex;align-items:center;padding:11px 24px;border-radius:50px;font-size:14px;font-weight:600;text-decoration:none;transition:background .18s,color .18s,border-color .18s}
.astro-bftaufe__btn--primary{background:#9a2d2d;color:#fff;border:2px solid #9a2d2d}
.astro-bftaufe__btn--primary:hover{background:#7e2424;border-color:#7e2424}
.astro-bftaufe__btn--outline{background:transparent;color:#9a2d2d;border:2px solid #c5a0a0}
.astro-bftaufe__btn--outline:hover{background:#9a2d2d;color:#fff;border-color:#9a2d2d}
.astro-bftaufe__deco{display:flex;align-items:center;justify-content:center}
.astro-bftaufe__symbol{width:90px;height:135px;filter:drop-shadow(0 4px 12px rgba(30,21,18,.1))}
@media(max-width:760px){.astro-bftaufe__inner{grid-template-columns:1fr}.astro-bftaufe__deco{display:none}}
@media(max-width:600px){.astro-bftaufe__inner{padding:0 20px}.astro-bftaufe{padding:52px 0}}
</style>
