---
// „Für jede Lebensphase das Richtige" — 4 Gruppen-Kacheln mit Liste + Link. Eigene Klassen
// `astro-gmgrp`. id="gruppen" (Sprungziel aus Hero/Welcome). SVG-Icons (kein Emoji, Handbuch 8.7).
const GROUPS = [
  { name: 'Familien',
    svg: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>',
    items: ['Baby-Lounge & Familien-Lounge', 'BonFriday – für alle von 0–99', 'Kinderprojektchor & Kochwerkstatt', 'Sommerwoche für Kinder'],
    href: '/bonfamily/', link: 'Mehr zu BonFamily →' },
  { name: 'Jugendliche',
    svg: '<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>',
    items: ['Schülercafé ORCA', 'Freizeiten & Fahrten', 'Kreativ-Workshops', 'Spirituelle Angebote bei JONA'],
    href: '/jugend/', link: 'Mehr zur Jugend →' },
  { name: 'Engagiert',
    svg: '<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>',
    items: ['Nachbarschaftliches Hilfenetz', 'KleiCa & Offener Kühlschrank', 'Arbeitsgruppe Weltkirche', 'Sozialberatung & Inklusion'],
    href: '/engagiert-leben/', link: 'Mehr zu Engagement →' },
  { name: 'Alle Generationen',
    svg: '<circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2M9 9h.01M15 9h.01"/>',
    items: ['BonCasino – Spielnachmittag ab 60', 'Chöre für alle Stimmen', 'Kirchcafé an allen 4 Standorten', 'Bibelrunde & Gebetsgruppen'],
    href: '/kultur-begegnung/', link: 'Mehr zu Kultur & Begegnung →' },
];
---
<section class="astro-gmgrp" id="gruppen">
  <div class="astro-gmgrp__in">
    <p class="astro-gmgrp__eyebrow">Angebote</p>
    <h2 class="astro-gmgrp__h2">Für jede Lebensphase das Richtige</h2>
    <p class="astro-gmgrp__lead">Ob jung oder alt, Familie oder Einzelperson — bei uns findet jeder seinen Platz.</p>
    <div class="astro-gmgrp__grid">
      {GROUPS.map((g) => (
        <div class="astro-gmgrp__card">
          <span class="astro-gmgrp__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="24" height="24" set:html={g.svg} />
          </span>
          <h3 class="astro-gmgrp__name">{g.name}</h3>
          <ul class="astro-gmgrp__list">
            {g.items.map((it) => <li>{it}</li>)}
          </ul>
          <a href={g.href} class="astro-gmgrp__link">{g.link}</a>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
.astro-gmgrp{background:#f7f3ef;padding:80px 0;width:100vw;position:relative;left:50%;margin-left:-50vw;margin-right:-50vw;scroll-margin-top:90px}
.astro-gmgrp__in{max-width:1140px;margin:0 auto;padding:0 40px}
.astro-gmgrp__eyebrow{text-align:center;font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:#1f7a6d;font-weight:600;margin:0 0 12px}
.astro-gmgrp__h2{font-family:'Playfair Display',Georgia,serif;font-weight:700;color:#2c2420;text-align:center;font-size:clamp(26px,3.6vw,38px);margin:0 0 12px}
.astro-gmgrp__lead{text-align:center;color:#8a7a6e;max-width:560px;margin:0 auto 44px;font-size:16px}
.astro-gmgrp__grid{display:grid;grid-template-columns:repeat(4,1fr);gap:24px}
.astro-gmgrp__card{display:flex;flex-direction:column;background:#fff;border:1px solid #e0d8cf;border-radius:14px;padding:30px 24px;transition:transform .2s,box-shadow .2s}
.astro-gmgrp__card:hover{transform:translateY(-4px);box-shadow:0 12px 32px rgba(30,21,18,.10)}
.astro-gmgrp__icon{display:flex;align-items:center;justify-content:center;width:52px;height:52px;border-radius:50%;background:#e3f2ef;color:#1f7a6d;margin-bottom:18px}
.astro-gmgrp__name{font-family:'Playfair Display',Georgia,serif;font-weight:700;color:#2c2420;font-size:21px;margin:0 0 16px}
.astro-gmgrp__list{list-style:none;margin:0 0 20px;padding:0;flex:1}
.astro-gmgrp__list li{position:relative;padding-left:20px;color:#5b5048;font-size:14.5px;line-height:1.5;margin-bottom:10px}
.astro-gmgrp__list li::before{content:"";position:absolute;left:0;top:8px;width:7px;height:7px;border-radius:50%;background:#1f7a6d}
.astro-gmgrp__link{color:#1f7a6d;font-weight:600;font-size:14px;transition:color .2s}
.astro-gmgrp__link:hover{color:#176055}
@media(max-width:980px){.astro-gmgrp__grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:560px){.astro-gmgrp{padding:56px 0}.astro-gmgrp__in{padding:0 20px}.astro-gmgrp__grid{grid-template-columns:1fr}}
</style>
