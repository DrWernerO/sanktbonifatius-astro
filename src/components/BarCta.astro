---
// Abschluss-CTA der Barrierefreiheit-Seite (WP 49119). Eigene Klassen `astro-bar-cta`.
// Greift die Feedback-Einladung aus dem Ansprechpartner-Abschnitt auf.
const MAIL = 'info@sanktbonifatius.de';
---
<section class="astro-bar-cta">
  <div class="astro-bar-cta__inner">
    <h2 class="astro-bar-cta__hl">Barriere entdeckt?</h2>
    <p class="astro-bar-cta__sub">
      Sagen Sie uns Bescheid, wenn Sie auf Hindernisse stoßen oder Vorschläge für mehr
      Barrierefreiheit haben. Jeder Hinweis hilft uns, Wege zu ebnen.
    </p>
    <div class="astro-bar-cta__btns">
      <a class="astro-bar-cta__btn" href={`mailto:${MAIL}`}>E-Mail schreiben</a>
      <a class="astro-bar-cta__btn astro-bar-cta__btn--ghost" href="/kontakt/">Zum Kontakt</a>
    </div>
  </div>
</section>

<style is:global>
.astro-bar-cta{background:#f7f3ef}
.astro-bar-cta__inner{max-width:760px;margin:0 auto;padding:72px 40px;text-align:center}
.astro-bar-cta__hl{font-family:'Playfair Display',serif;font-size:clamp(26px,3.4vw,38px);font-weight:700;color:#2c2420;margin:0 0 14px}
.astro-bar-cta__sub{font-size:clamp(16px,1.8vw,18px);color:#6b5c52;line-height:1.6;margin:0 0 28px}
.astro-bar-cta__btns{display:flex;gap:14px;justify-content:center;flex-wrap:wrap}
.astro-bar-cta__btn{display:inline-block;padding:14px 30px;border-radius:50px;background:#9a2d2d;color:#fff;font-size:15px;font-weight:600;transition:background .2s,color .2s}
.astro-bar-cta__btn:hover{background:#7e2424}
.astro-bar-cta__btn--ghost{background:transparent;color:#9a2d2d;border:1.5px solid #d8b3b3}
.astro-bar-cta__btn--ghost:hover{background:#9a2d2d;color:#fff}
@media(max-width:560px){.astro-bar-cta__inner{padding:52px 20px}}
</style>
