---
// Gottesdienst-Formate als Bild-Karten (ersetzt WP-Block `gd-formate`, Anker #formate).
// Eigene Klassen `astro-gdfmt`. Inhalte fest gepflegt, Bilder direkt von dev.sanktbonifatius.de.
const IMG = '/uploads';
const cards = [
  { eyebrow: 'Licht & Klang',          title: 'Fiat Lux',   desc: 'Atmosphärischer Gottesdienst mit Licht, Musik und Stille', href: '/gottesdienst-glaube/gottesdienste-die-beruehren/', img: `${IMG}/2026/01/fiat-lux-gottesdienst.jpg` },
  { eyebrow: 'Meditation & Stille',    title: 'Taizé',      desc: 'Meditative Gesänge für Ruhe und innere Einkehr',          href: '/gottesdienst-glaube/gottesdienste-die-beruehren/', img: `${IMG}/2022/10/taizegottesdienst-stbonifatius-10.jpg` },
  { eyebrow: 'Gospel & Energie',       title: 'BonEsprit',  desc: 'Lebendige Gospelgottesdienste voller Freude und Begeisterung', href: '/gottesdienst-glaube/gottesdienste-die-beruehren/', img: `${IMG}/2023/07/stbonifatius-gottesdienste-die-beruehren.jpg` },
  { eyebrow: 'Für die ganze Familie',  title: 'Familien',   desc: 'Kreativ, lebendig und voller Freude – für alle Generationen', href: '/bonfamily/familiengottesdienste/', img: `${IMG}/2026/06/familiengottesdienst-stwendel-frankfurt.jpg` },
];
---
<section class="astro-gdfmt" id="formate">
  <div class="astro-gdfmt__inner">
    <div class="astro-gdfmt__head">
      <h2 class="astro-gdfmt__hl">Gottesdienste für jeden Geschmack</h2>
      <p class="astro-gdfmt__sub">Von meditativer Stille bis zu lebendiger Gemeinschaft – entdecken Sie das Format, das zu Ihnen passt.</p>
    </div>
    <div class="astro-gdfmt__grid">
      {cards.map((c) => (
        <a class="astro-gdfmt-card" href={c.href}>
          <div class="astro-gdfmt-card__img" role="img" aria-label={c.title}
               style={`background-image:url('${c.img}')`}></div>
          <div class="astro-gdfmt-card__overlay"></div>
          <div class="astro-gdfmt-card__body">
            <span class="astro-gdfmt-card__eyebrow">{c.eyebrow}</span>
            <h3 class="astro-gdfmt-card__title">{c.title}</h3>
            <p class="astro-gdfmt-card__desc">{c.desc}</p>
            <span class="astro-gdfmt-card__more">Mehr erfahren →</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style is:global>
.astro-gdfmt{background:#f7f3ef;padding:72px 0}
.astro-gdfmt__inner{max-width:1200px;margin:0 auto;padding:0 40px}
.astro-gdfmt__head{text-align:center;margin:0 0 40px}
.astro-gdfmt__hl{font-family:'Playfair Display',serif;font-size:clamp(26px,3.4vw,38px);font-weight:700;color:#2c2420;margin:0 0 14px}
.astro-gdfmt__sub{font-size:clamp(15px,1.7vw,18px);color:#6b5c52;line-height:1.6;margin:0 auto;max-width:620px}
.astro-gdfmt__grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}
.astro-gdfmt-card{position:relative;display:flex;align-items:flex-end;min-height:340px;border-radius:12px;overflow:hidden;text-decoration:none;box-shadow:0 2px 12px rgba(30,21,18,.08)}
.astro-gdfmt-card__img{position:absolute;inset:0;background-size:cover;background-position:center;transition:transform .5s ease}
.astro-gdfmt-card:hover .astro-gdfmt-card__img{transform:scale(1.05)}
.astro-gdfmt-card__overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(20,12,8,.9) 0%,rgba(20,12,8,.45) 55%,rgba(20,12,8,.1) 100%)}
.astro-gdfmt-card__body{position:relative;padding:22px 22px 24px;color:#f0e8d8}
.astro-gdfmt-card__eyebrow{font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:#c5a55a;display:block;margin:0 0 8px}
.astro-gdfmt-card__title{font-family:'Playfair Display',serif;font-size:24px;font-weight:700;color:#fff;margin:0 0 8px}
.astro-gdfmt-card__desc{font-size:13.5px;color:#e0d6c6;line-height:1.5;margin:0 0 12px}
.astro-gdfmt-card__more{font-size:12px;font-weight:600;letter-spacing:.04em;color:#f0e8d8;border-bottom:1px solid rgba(240,232,216,.4);padding-bottom:2px;transition:border-color .2s}
.astro-gdfmt-card:hover .astro-gdfmt-card__more{border-color:#f0e8d8}
@media(max-width:980px){.astro-gdfmt__grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:560px){.astro-gdfmt__grid{grid-template-columns:1fr}.astro-gdfmt{padding:52px 0}.astro-gdfmt__inner{padding:0 20px}}
</style>
