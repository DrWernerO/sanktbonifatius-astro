---
// Wiederverwendbares Kachel-Grid für „Segen und Sakramente" (WP-Blöcke `ss-tiles2` / `ss-tiles3`).
// Eigene Klassen `astro-sstiles`. Wird zweimal genutzt: 2-spaltig (Segensformen) und 3-spaltig
// (6 Sakramente). Bilder als CSS-Hintergrund (lokal unter public/uploads/).
// Props:
//   heading  – Überschrift der Sektion
//   intro    – Einleitungstext unter der Überschrift
//   cols     – 2 oder 3 (Spaltenzahl im Desktop-Grid)
//   bg       – 'creme' | 'white' (Sektions-Hintergrund)
//   tiles    – [{ img, pos?, label, title, text, href, linkText }]
const { heading, intro, cols = 3, bg = 'white', tiles = [] } = Astro.props;
---
<section class={`astro-sstiles astro-sstiles--${bg}`}>
  <div class="astro-sstiles__inner">
    <div class="astro-sstiles__head">
      <h2 class="astro-sstiles__hl">{heading}</h2>
      {intro && <p class="astro-sstiles__intro" set:html={intro} />}
    </div>
    <div class={`astro-sstiles__grid astro-sstiles__grid--c${cols}`}>
      {tiles.map((t) => (
        <a class="astro-sstile" href={t.href}>
          <div class="astro-sstile__img" role="img" aria-label={t.title}
               style={`background-image:url('${t.img}')${t.pos ? `;background-position:${t.pos}` : ''}`}></div>
          <div class="astro-sstile__body">
            {t.label && <p class="astro-sstile__label">{t.label}</p>}
            <h3 class="astro-sstile__title" set:html={t.title} />
            <p class="astro-sstile__text" set:html={t.text} />
            <span class="astro-sstile__link" set:html={t.linkText} />
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style is:global>
.astro-sstiles{padding:80px 0}
.astro-sstiles--creme{background:#f7f3ef}
.astro-sstiles--white{background:#fff}
.astro-sstiles__inner{max-width:1200px;margin:0 auto;padding:0 40px}
.astro-sstiles__head{text-align:center;margin:0 0 44px}
.astro-sstiles__hl{font-family:'Playfair Display',serif;font-size:clamp(26px,3.5vw,42px);font-weight:700;color:#2c2420;margin:0 0 16px;line-height:1.15}
.astro-sstiles__intro{font-size:clamp(15px,1.8vw,18px);color:#6b5c52;line-height:1.6;margin:0 auto;max-width:640px}
.astro-sstiles__grid{display:grid;gap:24px}
.astro-sstiles__grid--c2{grid-template-columns:repeat(2,1fr);max-width:920px;margin:0 auto}
.astro-sstiles__grid--c3{grid-template-columns:repeat(3,1fr)}
.astro-sstile{display:flex;flex-direction:column;background:#fff;border-radius:12px;overflow:hidden;text-decoration:none;color:#2c2420;box-shadow:0 2px 14px rgba(30,21,18,.07);transition:transform .15s,box-shadow .2s}
.astro-sstiles--white .astro-sstile{background:#f7f3ef}
.astro-sstile:hover{transform:translateY(-4px);box-shadow:0 10px 28px rgba(30,21,18,.13)}
.astro-sstile__img{height:200px;background-size:cover;background-position:center;flex-shrink:0}
.astro-sstile__body{padding:24px 26px 26px;display:flex;flex-direction:column;flex:1}
.astro-sstile__label{font-size:11.5px;letter-spacing:.12em;text-transform:uppercase;color:#9a2d2d;font-weight:600;margin:0 0 8px}
.astro-sstile__title{font-family:'Playfair Display',serif;font-size:23px;font-weight:700;margin:0 0 12px;line-height:1.2}
.astro-sstile__text{font-size:14.5px;color:#6b5c52;line-height:1.6;margin:0 0 18px;flex:1}
.astro-sstile__link{font-size:14px;font-weight:600;color:#9a2d2d;align-self:flex-start;border-bottom:1px solid rgba(154,45,45,.35);padding-bottom:2px;transition:border-color .2s}
.astro-sstile:hover .astro-sstile__link{border-color:#9a2d2d}
@media(max-width:860px){.astro-sstiles__grid--c3{grid-template-columns:repeat(2,1fr)}}
@media(max-width:600px){.astro-sstiles{padding:56px 0}.astro-sstiles__inner{padding:0 20px}.astro-sstiles__grid--c2,.astro-sstiles__grid--c3{grid-template-columns:1fr}}
</style>
