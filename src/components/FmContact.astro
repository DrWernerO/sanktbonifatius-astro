---
// Kontakt-Section „Familientreffpunkte" — Präfix `astro-fmcontact`.
---
<section class="astro-fmcontact">
  <div class="astro-fmcontact__inner">
    <h2 class="astro-fmcontact__title">Kommen Sie vorbei!</h2>
    <div class="astro-fmcontact__grid">
      <div class="astro-fmcontact__block">
        <div class="astro-fmcontact__icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <div>
          <p class="astro-fmcontact__label">Adresse</p>
          <p class="astro-fmcontact__value">Zentrales Pfarrbüro St. Bonifatius<br/>Holbeinstraße 70 · 60596 Frankfurt am Main</p>
          <a href="https://www.google.de/maps/place/St.+Bonifatiuskirche/@50.0977051,8.6771909,17z"
             target="_blank" rel="noopener" class="astro-fmcontact__maplink">So finden Sie uns →</a>
        </div>
      </div>
      <div class="astro-fmcontact__block">
        <div class="astro-fmcontact__icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.68 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6 6l1-1a2 2 0 0 1 2.11-.45c.91.32 1.85.55 2.81.68A2 2 0 0 1 21.73 16z"/></svg>
        </div>
        <div>
          <p class="astro-fmcontact__label">Telefon</p>
          <a href="tel:+4969695975850" class="astro-fmcontact__value astro-fmcontact__link">069 695 97 58 50</a>
        </div>
      </div>
      <div class="astro-fmcontact__block">
        <div class="astro-fmcontact__icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </div>
        <div>
          <p class="astro-fmcontact__label">E-Mail</p>
          <a href="mailto:info@sanktbonifatius.de" class="astro-fmcontact__value astro-fmcontact__link">info@sanktbonifatius.de</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
.astro-fmcontact{padding:72px 0;background:linear-gradient(135deg,#4a2e1a 0%,#3a2315 100%);width:100vw;position:relative;left:50%;margin-left:-50vw;margin-right:-50vw}
.astro-fmcontact__inner{max-width:1100px;margin:0 auto;padding:0 40px}
.astro-fmcontact__title{font-family:'Playfair Display',Georgia,serif;font-size:clamp(26px,3.5vw,38px);font-weight:700;color:#fff;margin:0 0 40px;text-align:center}
.astro-fmcontact__grid{display:grid;grid-template-columns:repeat(3,1fr);gap:28px}
.astro-fmcontact__block{display:flex;align-items:flex-start;gap:16px}
.astro-fmcontact__icon{color:#c5a55a;flex-shrink:0;margin-top:2px}
.astro-fmcontact__label{font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.6);margin:0 0 4px}
.astro-fmcontact__value{font-size:15px;color:#f0e8d8;line-height:1.5;margin:0}
.astro-fmcontact__link{text-decoration:none;color:#f0e8d8;transition:color .15s}
.astro-fmcontact__link:hover{color:#c5a55a}
.astro-fmcontact__maplink{display:inline-block;margin-top:6px;font-size:13px;color:#c5a55a;text-decoration:none;font-weight:600}
.astro-fmcontact__maplink:hover{text-decoration:underline}
@media(max-width:860px){.astro-fmcontact__grid{grid-template-columns:1fr;gap:24px}}
@media(max-width:600px){.astro-fmcontact__inner{padding:0 20px}.astro-fmcontact{padding:52px 0}}
</style>
