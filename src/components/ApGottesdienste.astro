<div class="astro-ap-root astro-ap-godi-wrap" id="gottesdienste" style="scroll-margin-top:100px">
  <div class="astro-ap-in">
    <div class="astro-ap-godi">
      <div>
        <h2>Gottesdienste in St. Aposteln</h2>
        <p>Unsere Kirche ist jeden Tag von 10 – 18 Uhr zum Gebet geöffnet. Treten Sie ein, verweilen Sie, finden Sie Stille.</p>
        <a class="astro-ap-godi-btn" href="/gottesdienst-glaube/gottesdienstordnung/">Aktuelle Gottesdienstordnung →</a>
      </div>
      <div class="astro-ap-godi-times">
        <div class="astro-ap-godi-row"><span class="astro-ap-godi-day">Täglich</span><span>10 – 18 Uhr · Kirche offen</span></div>
        <div class="astro-ap-godi-row"><span class="astro-ap-godi-day">Dienstag</span><span>18 Uhr · Eucharistiefeier</span></div>
        <div class="astro-ap-godi-row"><span class="astro-ap-godi-day">Sonntag</span><span>9:30 Uhr · Eucharistiefeier</span></div>
        <div class="astro-ap-godi-row"><span class="astro-ap-godi-day">Freitag</span><span>ca. 17:30 Uhr · Abendgebet</span></div>
      </div>
    </div>
  </div>
</div>

<style is:global>
.astro-ap-godi-wrap {
  padding: 56px 0;
}
.astro-ap-godi {
  background: var(--ap-g);
  border-radius: 14px;
  padding: 54px 48px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 40px;
  align-items: center;
}
.astro-ap-godi h2 {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: 36px;
  color: #fff;
  margin: 0 0 14px;
  line-height: 1.2;
}
.astro-ap-godi p {
  font-size: 17px;
  color: rgba(255,255,255,.92);
  margin: 0 0 8px;
  line-height: 1.55;
}
.astro-ap-godi-btn {
  display: inline-flex;
  align-items: center;
  padding: 14px 28px;
  border-radius: 999px;
  background: #fff;
  color: var(--ap-g);
  text-decoration: none;
  font-weight: 600;
  font-size: 15px;
  margin-top: 20px;
  transition: background .2s;
}
.astro-ap-godi-btn:hover { background: #f0ebe0; }
.astro-ap-godi-times {
  background: rgba(255,255,255,.1);
  border-radius: 10px;
  padding: 24px;
}
.astro-ap-godi-row {
  display: flex;
  justify-content: space-between;
  padding: 9px 0;
  border-bottom: 1px solid rgba(255,255,255,.18);
  font-size: 15px;
  color: #fff;
}
.astro-ap-godi-row:last-child { border-bottom: none; }
.astro-ap-godi-day {
  font-weight: 600;
  letter-spacing: .04em;
  text-transform: uppercase;
  font-size: 13px;
  opacity: .8;
}
@media (max-width: 860px) {
  .astro-ap-godi { grid-template-columns: 1fr; padding: 36px 28px; }
}
</style>
