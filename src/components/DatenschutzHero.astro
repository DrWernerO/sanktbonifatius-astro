---
// Hero der Seite „Datenschutz" — WP-Seite 49118 (/datenschutz/, ersetzt WP-Block `dz-hero`).
// Eigene Klassen `astro-dzhero` (Handbuch Abschnitt 3 — niemals WP-Klassen `dz-…`).
// Kein Bild in der WP-Vorlage → dunkel-warmer Verlauf (konsistent mit ImpressumHero).
---
<section class="astro-dzhero">
  <div class="astro-dzhero__inner">
    <p class="astro-dzhero__eyebrow">Rechtliche Hinweise</p>
    <h1 class="astro-dzhero__title">Datenschutz</h1>
    <p class="astro-dzhero__sub">
      Informationen zur Verarbeitung personenbezogener Daten auf sanktbonifatius.de
      gem&auml;&szlig; dem Gesetz &uuml;ber den Kirchlichen Datenschutz (KDG).
    </p>
  </div>
</section>

<style is:global>
.astro-dzhero{position:relative;width:100vw;left:50%;margin-left:-50vw;margin-right:-50vw;display:flex;align-items:flex-end;min-height:340px;overflow:hidden;background:linear-gradient(135deg,#2c1a14 0%,#3a241b 55%,#1f130d 100%)}
.astro-dzhero::after{content:"";position:absolute;inset:0;background:radial-gradient(circle at 20% 0%,rgba(197,165,90,.18),transparent 55%)}
.astro-dzhero__inner{position:relative;z-index:1;max-width:1200px;width:100%;margin:0 auto;padding:96px 40px 52px;color:#f0e8d8}
.astro-dzhero__eyebrow{font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:#c5a55a;margin:0 0 14px}
.astro-dzhero__title{font-family:'Playfair Display',serif;font-weight:700;line-height:1.05;color:#fff;font-size:clamp(36px,5.4vw,64px);margin:0}
.astro-dzhero__sub{font-size:clamp(16px,1.9vw,20px);color:#e8ddc9;line-height:1.55;margin:18px 0 0;max-width:680px}
@media(max-width:600px){.astro-dzhero{min-height:280px}.astro-dzhero__inner{padding:80px 20px 40px}}
</style>
