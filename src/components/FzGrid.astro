---
// Freizeiten-Grid der Unterseite „Kinder- & Jugendfreizeiten" (WP-Block `fz-grid-wrap`).
// Eigene Klassen `astro-fzgrid` (goldene Regel, Handbuch 3 — niemals WP-Klassen `fz-…`).
// 6 Karten aus einem Daten-Array. Bilder lokal unter public/uploads/ (Handbuch 1b).
// Externe Anmelde-Links (JONA, ChurchDesk) + Flyer-PDFs liegen weiterhin auf www
// (Download-URLs ziehen erst beim WP-Umzug auf cms., Handbuch 1b). Mailto bleibt mailto.
//
// Faithful zur Live-Seite (SEO-Quelle): Termine, Altersangaben, Orte und Anmeldewege
// 1:1 übernommen. Ändert sich eine Freizeit, hier im `freizeiten`-Array pflegen.
const freizeiten = [
  {
    img: '/uploads/2025/12/freizeiten-jugend-2026.jpg',
    alt: 'Kinder baden gemeinsam in einem klaren See',
    badge: '14–17 Jahre', region: 'Italien',
    title: 'Sommerfreizeit am Lago Maggiore',
    dates: '03.07.–17.07.2026', place: 'Lago Maggiore',
    text: 'Das schönste Abenteuer des Jahres erlebst du hier! Sonne auf der Haut, Wasser vor dir und eine Gruppe, die schnell zu einer kleinen Gemeinschaft wird. Diese Freizeit schenkt dir Abstand vom Alltag und unvergessliche Momente zwischen Baden, Spielen, Gesprächen und Abenteuern.',
    links: [{ label: 'Anmeldung über JONA', href: 'https://jugendkirche-frankfurt.bistumlimburg.de/angebote/freizeiten', primary: true, ext: true }],
  },
  {
    img: '/uploads/2025/12/sommerfreizeit-daenemark-herz-jesu-2026.jpg',
