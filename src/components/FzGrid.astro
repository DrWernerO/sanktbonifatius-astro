    links: [{ label: 'Anmeldung per Mail', href: 'mailto:g.geagea@sanktbonifatius.de', primary: true }],
  },
];
---
<section class="astro-fzgrid" id="alle-freizeiten">
  <div class="astro-fzgrid__in">
    <div class="astro-fzgrid__head">
      <h2>Alle Freizeiten 2026</h2>
      <p>Sortiert nach Reisedatum. Die Plätze sind begrenzt &#8212; eine frühzeitige Anmeldung lohnt sich.</p>
    </div>
    <div class="astro-fzgrid__grid">
      {freizeiten.map((f) => (
        <article class="astro-fzgrid__card">
          <div class="astro-fzgrid__img">
            <img src={f.img} alt={f.alt} loading="lazy" decoding="async" />
            <span class="astro-fzgrid__badge">{f.badge}</span>
          </div>
          <div class="astro-fzgrid__body">
            <p class="astro-fzgrid__region">{f.region}</p>
            <h3 class="astro-fzgrid__title">{f.title}</h3>
            <p class="astro-fzgrid__meta">
              <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" d="M7 3v3M17 3v3M4 8h16M5 6h14a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V7a1 1 0 0 1 1-1z"/></svg>
              <span>{f.dates} &middot; {f.place}</span>
            </p>
            <p class="astro-fzgrid__text">{f.text}</p>
            {f.note && <p class="astro-fzgrid__note">{f.note}</p>}
            <div class="astro-fzgrid__links">
              {f.links.map((l) => (
                <a class={`astro-fzgrid__btn ${l.primary ? 'astro-fzgrid__btn--primary' : 'astro-fzgrid__btn--ghost'}`}
                   href={l.href}
                   {...(l.ext ? { target: '_blank', rel: 'noopener' } : {})}>{l.label}</a>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style is:global>
.astro-fzgrid{background:#f7f3ef;padding:64px 24px}
.astro-fzgrid__in{max-width:1200px;margin:0 auto}
.astro-fzgrid__head{text-align:center;margin-bottom:44px}
.astro-fzgrid__head h2{font-family:'Playfair Display',Georgia,serif;font-size:clamp(26px,4vw,38px);color:#2c2420;margin:0 0 10px;font-weight:700}
.astro-fzgrid__head p{font-size:15.5px;color:#6b5c52;margin:0;max-width:560px;margin-inline:auto}
.astro-fzgrid__grid{display:grid;grid-template-columns:repeat(3,1fr);gap:26px;align-items:stretch}
.astro-fzgrid__card{display:flex;flex-direction:column;background:#fff;border-radius:16px;overflow:hidden;box-shadow:0 2px 10px rgba(44,36,32,.06);transition:transform .2s,box-shadow .2s}
.astro-fzgrid__card:hover{transform:translateY(-4px);box-shadow:0 10px 26px rgba(44,36,32,.12)}
.astro-fzgrid__img{position:relative;aspect-ratio:16/10;overflow:hidden}
.astro-fzgrid__img img{width:100%;height:100%;object-fit:cover;display:block}
.astro-fzgrid__badge{position:absolute;top:12px;left:12px;background:rgba(154,45,45,.94);color:#fff;font-size:12px;font-weight:600;letter-spacing:.02em;padding:5px 12px;border-radius:50px}
.astro-fzgrid__body{display:flex;flex-direction:column;flex:1;padding:22px 22px 24px}
.astro-fzgrid__region{font-size:11.5px;letter-spacing:.13em;text-transform:uppercase;color:#c5a55a;font-weight:600;margin:0 0 8px}
.astro-fzgrid__title{font-family:'Playfair Display',Georgia,serif;font-size:21px;color:#2c2420;margin:0 0 12px;line-height:1.25;font-weight:700}
.astro-fzgrid__meta{display:flex;align-items:center;gap:8px;color:#9a2d2d;font-size:13.5px;font-weight:600;margin:0 0 14px}
.astro-fzgrid__meta svg{flex:0 0 auto}
.astro-fzgrid__text{font-size:14.5px;color:#6b5c52;line-height:1.6;margin:0 0 16px}
.astro-fzgrid__note{font-size:13px;font-weight:600;color:#7e2424;background:#f7ece9;border-radius:8px;padding:7px 12px;margin:0 0 16px}
.astro-fzgrid__links{display:flex;flex-wrap:wrap;gap:10px;margin-top:auto}
.astro-fzgrid__btn{display:inline-flex;align-items:center;padding:10px 18px;border-radius:50px;font-size:14px;font-weight:600;text-decoration:none;transition:background .2s,border-color .2s,color .2s}
.astro-fzgrid__btn--primary{background:#9a2d2d;color:#fff}
.astro-fzgrid__btn--primary:hover{background:#b8423f}
.astro-fzgrid__btn--ghost{border:1.5px solid #d6cabb;color:#6b5c52}
.astro-fzgrid__btn--ghost:hover{border-color:#9a2d2d;color:#9a2d2d}
@media(max-width:980px){.astro-fzgrid__grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:640px){.astro-fzgrid{padding:48px 18px}.astro-fzgrid__grid{grid-template-columns:1fr}}
</style>
