---
// Hero der Seite „Firmung" — WP-Seite 46778 (/segen-sakramente/firmung/, WP-Block `ta-hero`).
// Eigene Klassen `astro-firm-hero` (goldene Regel, Handbuch Abschnitt 3 — WP-Klassen `ta-…` tabu;
// `astro-fin-` ist die Finanzen-Seite, daher hier `astro-firm-`). Foto-Hero (Live-Mediathek, HTTP 200)
// → Bild + dunkler Gradient (Muster BcHero, Handbuch § 4/10). Einzige sichtbare <h1> der Seite.
---
<section class="astro-firm-hero">
  <div class="astro-firm-hero__inner">
    <span class="astro-firm-hero__eyebrow">Sakrament der Firmung</span>
    <h1 class="astro-firm-hero__title">Firmung &#8211; Dein Ja zu Gott</h1>
    <p class="astro-firm-hero__sub">
      Ein halbes Jahr Kurs, echte Begegnung, pers&ouml;nliche Begleitung &#8211; und am Ende eine
      freie Entscheidung f&uuml;r den Glauben. Bei Sankt Bonifatius in Frankfurt Sachsenhausen.
    </p>
    <div class="astro-firm-hero__btns">
      <a class="astro-firm-hero__btn" href="#firm-kontakt">Jetzt anfragen</a>
      <a class="astro-firm-hero__btn astro-firm-hero__btn--ghost" href="#firm-kurs">Zum Firmkurs &#8595;</a>
    </div>
  </div>
</section>

<style is:global>
.astro-firm-hero{position:relative;width:100vw;left:50%;margin-left:-50vw;margin-right:-50vw;min-height:520px;display:flex;align-items:flex-end;overflow:hidden}
@media(min-width:768px){.astro-firm-hero{min-height:600px}}
.astro-firm-hero::before{content:"";position:absolute;inset:0;background-image:url('https://www.sanktbonifatius.de/wp-content/uploads/2026/05/firmung-mai2026-stbonifatius.jpg');background-size:cover;background-position:center 35%;z-index:0}
.astro-firm-hero::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(20,10,2,.18) 0%,rgba(20,10,2,.5) 55%,rgba(20,10,2,.88) 100%);z-index:1}
.astro-firm-hero__inner{position:relative;z-index:2;width:100%;max-width:1200px;margin:0 auto;padding:48px 48px 60px;color:#fff}
.astro-firm-hero__eyebrow{font-family:'Playfair Display',Georgia,serif;font-style:italic;font-size:.95rem;color:#c8a96e;letter-spacing:.06em;display:block;margin-bottom:12px}
.astro-firm-hero__title{font-family:'Playfair Display',Georgia,serif;font-size:clamp(34px,5vw,66px);font-weight:700;color:#fff;margin:0 0 16px;line-height:1.1}
.astro-firm-hero__sub{font-size:clamp(16px,2vw,21px);color:rgba(255,255,255,.85);max-width:600px;line-height:1.65;margin:0 0 28px}
.astro-firm-hero__btns{display:flex;gap:14px;flex-wrap:wrap}
.astro-firm-hero__btn{display:inline-flex;align-items:center;gap:8px;padding:14px 30px;border-radius:50px;font-size:15px;font-weight:700;text-decoration:none;background:#9a2d2d;color:#fff;transition:background .2s,color .2s}
.astro-firm-hero__btn:hover{background:#7e2424}
.astro-firm-hero__btn--ghost{background:transparent;color:#fff;box-shadow:inset 0 0 0 1.5px rgba(255,255,255,.55)}
.astro-firm-hero__btn--ghost:hover{background:rgba(255,255,255,.14)}
@media(max-width:600px){.astro-firm-hero{min-height:460px}.astro-firm-hero__inner{padding:0 20px 40px}}
</style>
