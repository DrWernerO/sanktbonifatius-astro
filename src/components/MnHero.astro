---
// Hero der Unterseite „Ministranten St. Bonifatius" — WP-Seite 49156
// (/jugend/ministranten-st-bonifatius/, ersetzt WP-Block `mn-hero`).
// Eigene Klassen `astro-mnhero` (goldene Regel, Handbuch 3 — niemals WP-Klassen `mn-…`).
// Full-Bleed-Foto + warm-dunkler Verlauf. Bild lokal (Handbuch 1b).
const bg = '/uploads/2022/08/ministranten-stbonifatius-teaser.jpeg';
---
<section class="astro-mnhero">
  <div class="astro-mnhero__bg" role="img"
       aria-label="Ministrantinnen und Ministranten der Pfarrei Sankt Bonifatius"
       style={`background-image:url('${bg}')`}></div>
  <div class="astro-mnhero__overlay"></div>
  <div class="astro-mnhero__inner">
    <p class="astro-mnhero__eyebrow">Pfarrei Sankt Bonifatius &middot; Frankfurt-Sachsenhausen</p>
    <h1 class="astro-mnhero__title">Ministranten in St. Bonifatius</h1>
    <p class="astro-mnhero__sub">
      56 Kinder und Jugendliche gestalten mit gro&szlig;em Elan die Gottesdienste in unserer
      Pfarrkirche &#8212; mit Weihrauch, Lagerfeuerstimmung und vielen Specials.
    </p>
  </div>
</section>

<style is:global>
.astro-mnhero{position:relative;width:100vw;left:50%;margin-left:-50vw;margin-right:-50vw;height:min(68vh,540px);display:flex;align-items:flex-end;overflow:hidden}
.astro-mnhero__bg{position:absolute;inset:0;background-color:#3a1010;background-size:cover;background-position:center}
.astro-mnhero__overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(40,16,16,.12) 0%,rgba(40,16,16,.52) 58%,rgba(28,10,10,.88) 100%)}
.astro-mnhero__inner{position:relative;z-index:2;width:100%;max-width:1280px;margin:0 auto;padding:0 40px 52px;color:#f0e8d8}
.astro-mnhero__eyebrow{font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:#c5a55a;margin:0 0 14px;font-weight:600}
.astro-mnhero__title{font-family:'Playfair Display',Georgia,serif;font-size:clamp(34px,5vw,64px);color:#fff;margin:0 0 16px;line-height:1.08;font-weight:700}
.astro-mnhero__sub{color:rgba(255,255,255,.9);font-size:clamp(16px,2vw,21px);margin:0;max-width:640px;line-height:1.5}
@media(max-width:600px){.astro-mnhero{height:min(64vh,440px)}.astro-mnhero__inner{padding:0 20px 38px}}
</style>
