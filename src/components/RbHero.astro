---
// Hero der Unterseite „Reisebedingungen" — WP-Seite 32113
// (/jugend/reisebedingungen/). Reiner Verlauf-Hero (die WP-Seite hat kein Hero-Bild,
// Handbuch 10.7). Eigene Klassen `astro-rbhero`.
---
<section class="astro-rbhero">
  <div class="astro-rbhero__inner">
    <p class="astro-rbhero__eyebrow">Kinder- &amp; Jugendfreizeiten</p>
    <h1 class="astro-rbhero__title">Reisebedingungen</h1>
    <p class="astro-rbhero__sub">
      Die allgemeinen Reisebedingungen f&uuml;r unsere Kinder- und Jugendfreizeiten
      der Pfarrei Sankt Bonifatius Frankfurt.
    </p>
  </div>
</section>

<style is:global>
.astro-rbhero{position:relative;width:100vw;left:50%;margin-left:-50vw;margin-right:-50vw;background:linear-gradient(135deg,#4a2e1a 0%,#3a2315 100%);color:#f0e8d8;overflow:hidden}
.astro-rbhero::after{content:"";position:absolute;inset:0;background:radial-gradient(circle at 18% 12%,rgba(197,165,90,.14),transparent 55%)}
.astro-rbhero__inner{position:relative;z-index:1;max-width:880px;margin:0 auto;padding:84px 40px 64px}
.astro-rbhero__eyebrow{font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:#c5a55a;margin:0 0 14px;font-weight:600}
.astro-rbhero__title{font-family:'Playfair Display',Georgia,serif;font-size:clamp(34px,5vw,58px);color:#fff;margin:0 0 16px;line-height:1.1;font-weight:700}
.astro-rbhero__sub{color:rgba(255,255,255,.86);font-size:clamp(16px,2vw,20px);margin:0;max-width:600px;line-height:1.5}
@media(max-width:600px){.astro-rbhero__inner{padding:64px 20px 48px}}
</style>
