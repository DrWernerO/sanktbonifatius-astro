---
// Kirchorte (ersetzt WP-Block `bh3a-kirch`). 4 Kärtchen mit Bild/Overlay/Text.
// Bilder lokal im Projekt unter public/uploads/ (vom WP heruntergeladen, Handbuch 1b).
const IMG = '/uploads';
const cards = [
  { href: '/kirchorte/herz-jesu/', img: `${IMG}/2020/05/Kirche-HerzJesu-1.jpg`,
    name: 'Herz Jesu', desc: '160 Jahre Kirchengeschichte in Oberrad. Ökumenisch offen, mit Visionen für die Zukunft.' },
  { href: '/kirchorte/st-aposteln/', img: `${IMG}/2020/05/KircheStAposteln.jpeg`,
    name: 'St. Aposteln', desc: 'Kirche für die Menschen im Stadtteil. Offen für alle, die Gemeinschaft oder Unterstützung suchen.' },
  { href: '/kirchorte/st-bonifatius/', img: `${IMG}/2020/04/St.-Bonifatius-von-oben.jpg`,
    name: 'St. Bonifatius', desc: 'Pfarrkirche mit Gottesdiensten für jeden Geschmack. Treffpunkt für Familien und Heimat der Jugendkirche JONA.' },
  { href: '/kirchorte/st-wendel/', img: `${IMG}/2021/10/St_Wendel_Teaser.jpg`,
    name: 'St. Wendel', desc: 'Kirche in der Nachbarschaft für alle Generationen. Glaube und Gemeinschaft mit Freude gelebt.' },
];
---
<div class="astro-kirch">
  <div class="astro-kirch__inner">
    <h2 class="astro-kirch__hl">Unsere vier Kirchorte</h2>
    <p class="astro-kirch__sub">Vier Kirchen, ein Geist — in den Stadtteilen Sachsenhausen und Oberrad.</p>
    <div class="astro-kirch__grid">
      {cards.map((c) => (
        <a href={c.href} class="astro-kcard">
          <div class="astro-kcard__img" role="img" aria-label={`Kirche ${c.name}`} style={`background-image:url('${c.img}')`}>
            <div class="astro-kcard__overlay"></div>
          </div>
          <div class="astro-kcard__body">
            <h3 class="astro-kcard__name">{c.name}</h3>
            <p class="astro-kcard__desc">{c.desc}</p>
            <span class="astro-kcard__link">Mehr erfahren →</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</div>

<style is:global>
.astro-kirch{margin-top:24px;width:100vw;position:relative;left:50%;margin-left:-50vw;margin-right:-50vw;background:#f7f3ef;padding:56px 0}
.astro-kirch__inner{max-width:1200px;margin:0 auto;padding:0 40px}
.astro-kirch__hl{font-family:'Playfair Display',serif;font-size:30px;color:#2c2420;text-align:center;margin:0 0 10px;font-weight:700}
.astro-kirch__sub{font-size:15px;color:#7a6d59;text-align:center;margin:0 0 36px}
.astro-kirch__grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px}
.astro-kcard{border-radius:10px;overflow:hidden;text-decoration:none;display:flex;flex-direction:column;transition:transform .2s,box-shadow .2s}
.astro-kcard:hover{transform:translateY(-4px);box-shadow:0 10px 28px rgba(44,36,32,.15)}
.astro-kcard__img{height:160px;background-size:cover;background-position:center;position:relative}
.astro-kcard__overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(44,36,32,.7) 0%,transparent 60%)}
.astro-kcard__body{padding:20px;background:#fff;flex:1;display:flex;flex-direction:column;gap:6px;border-bottom:3px solid #928269}
.astro-kcard__name{font-family:'Playfair Display',serif;font-size:17px;color:#2c2420;font-weight:700;margin:0}
.astro-kcard__desc{font-size:12px;color:#7a6d59;line-height:1.5;margin:0;flex:1}
.astro-kcard__link{font-size:12px;color:#928269;font-weight:600;margin-top:4px}
@media(max-width:900px){.astro-kirch__grid{grid-template-columns:1fr 1fr}}
@media(max-width:560px){.astro-kirch__grid{grid-template-columns:1fr}.astro-kirch{padding:32px 20px}}
</style>
