---
// Ansprechpartner-Karte „Nachbarschaftliches Hilfenetz" — Helga Jantschek.
// Eigene Klassen `astro-nhcontact` (nicht WP `nh-…`). Foto im Hochformat. Feste Inhalte.
const tel = '069 29826270';
const telHref = 'tel:+4969298262700';
const mail = 'hilfenetz.sachsenhausen@caritas-frankfurt.de';
---
<section id="kontakt" class="astro-nhcontact">
  <div class="astro-nhcontact__inner">
    <p class="astro-nhcontact__eyebrow">Ansprechpartnerin</p>
    <h2 class="astro-nhcontact__hl">Wir sind f&uuml;r Sie da</h2>
    <div class="astro-nhcontact__card">
      <div class="astro-nhcontact__media">
        <img src="/uploads/2023/12/Helga_Jantschek--1024x1434.jpg"
             alt="Helga Jantschek, Koordinatorin Hilfenetz Sachsenhausen"
             class="astro-nhcontact__foto" loading="lazy" width="1024" height="1434" />
      </div>
      <div class="astro-nhcontact__info">
        <h3 class="astro-nhcontact__name">Helga Jantschek</h3>
        <p class="astro-nhcontact__rolle">Koordinatorin Hilfenetz Sachsenhausen</p>
        <p class="astro-nhcontact__label">Kontakt &amp; Sprechzeiten</p>
        <a href={`mailto:${mail}`} class="astro-nhcontact__link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          {mail}
        </a>
        <a href={telHref} class="astro-nhcontact__link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.18 6.18l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          {tel}
        </a>
      </div>
    </div>
  </div>
</section>

<style is:global>
.astro-nhcontact{background:#ede4d5;padding:80px 0;width:100vw;position:relative;left:50%;margin-left:-50vw;margin-right:-50vw}
.astro-nhcontact__inner{max-width:1000px;margin:0 auto;padding:0 40px;text-align:center}
.astro-nhcontact__eyebrow{font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:#9a2d2d;margin:0 0 14px;font-weight:600}
.astro-nhcontact__hl{font-family:'Playfair Display',serif;font-size:clamp(26px,3.4vw,40px);font-weight:700;color:#2c2420;margin:0 0 40px}
.astro-nhcontact__card{display:flex;gap:36px;align-items:center;background:#fff;border-radius:18px;padding:36px;max-width:760px;margin:0 auto;text-align:left;box-shadow:0 4px 22px rgba(30,21,18,.08);border:1px solid #e0d8cf}
.astro-nhcontact__media{flex-shrink:0;width:200px;border-radius:12px;overflow:hidden;border:3px solid #9a2d2d}
.astro-nhcontact__foto{width:100%;height:auto;display:block;object-fit:cover}
.astro-nhcontact__info{display:flex;flex-direction:column;gap:8px;min-width:0}
.astro-nhcontact__name{font-family:'Playfair Display',serif;font-size:24px;font-weight:700;color:#2c2420;margin:0}
.astro-nhcontact__rolle{font-size:15px;color:#928269;font-style:italic;margin:0 0 10px}
.astro-nhcontact__label{font-size:12px;letter-spacing:.12em;text-transform:uppercase;color:#9a2d2d;font-weight:600;margin:0 0 4px}
.astro-nhcontact__link{display:flex;align-items:center;gap:9px;font-size:15px;color:#5a4a3a;text-decoration:none;word-break:break-all;transition:color .15s}
.astro-nhcontact__link:hover{color:#9a2d2d}
.astro-nhcontact__link svg{flex-shrink:0;color:#9a2d2d}
@media(max-width:600px){.astro-nhcontact{padding:56px 0}.astro-nhcontact__inner{padding:0 20px}.astro-nhcontact__card{flex-direction:column;text-align:center;padding:28px 24px}.astro-nhcontact__media{width:180px}.astro-nhcontact__info{align-items:center}.astro-nhcontact__link{justify-content:center}}
</style>
