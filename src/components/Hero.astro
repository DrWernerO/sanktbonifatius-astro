---
// Editorial-Hero (ersetzt WP-Block `bh2-editorial`).
// Inhalte selten geändert → fest gepflegt. Bilder lokal im Projekt unter public/uploads/
// (vom WP heruntergeladen → unabhängig vom Dev-Server, Handbuch 1b).
const IMG = '/uploads';
const main = {
  href: '/gottesdienst-glaube/gottesdienstordnung/',
  img: `${IMG}/2025/10/SanktBonifatius-Gottesdienst-Glaube-2025-Slider_01A-1380x380.jpg`,
  title: 'Sie suchen etwas? Wir auch!',
  alt: 'Gottesdienst in der Pfarrei Sankt Bonifatius Frankfurt',
};
const side = [
  {
    href: '/ueberuns/',
    img: `${IMG}/2026/01/SanktBonifatius-BonFamily-2025-Slider.jpg`,
    tag: 'Über uns',
    title: 'Modern. Offen. Für alle.',
    link: 'Mehr über uns →',
    alt: 'Familien der BonFamily-Gemeinschaft bei Sankt Bonifatius',
  },
  {
    href: '/ueberuns/gemeinschaft/',
    img: `${IMG}/2026/06/teaser-jugend-home-teal.jpg`,
    tag: 'Gemeinschaft',
    title: 'Eine Pfarrei, die wirklich trägt',
    link: 'Gemeinschaft erleben →',
    alt: 'Jugendliche in der Gemeinschaft von Sankt Bonifatius',
  },
];
---
<section class="astro-hero">
  <a class="astro-hero__main" href={main.href}>
    <div class="astro-hero__img" role="img" aria-label={main.alt} style={`background-image:url('${main.img}')`}></div>
    <div class="astro-hero__overlay"></div>
    <div class="astro-hero__text">
      <h2 class="astro-hero__title">{main.title}</h2>
    </div>
  </a>
  <div class="astro-hero__side">
    {side.map((s) => (
      <a class="astro-hero__small" href={s.href}>
        <div class="astro-hero__img" role="img" aria-label={s.alt} style={`background-image:url('${s.img}')`}></div>
        <div class="astro-hero__overlay astro-hero__overlay--small"></div>
        <div class="astro-hero__text astro-hero__text--small">
          <span class="astro-hero__tag">{s.tag}</span>
          <h3 class="astro-hero__stitle">{s.title}</h3>
          <span class="astro-hero__link">{s.link}</span>
        </div>
      </a>
    ))}
  </div>
</section>

<style is:global>
.astro-hero{width:100vw;position:relative;left:50%;margin-left:-50vw;margin-right:-50vw;display:grid;grid-template-columns:60fr 40fr;height:620px;gap:4px;margin-top:4px}
.astro-hero__main,.astro-hero__small{position:relative;display:block;overflow:hidden;text-decoration:none}
.astro-hero__img{position:absolute;inset:0;background-size:cover;background-position:center;transition:transform .6s ease}
.astro-hero__main:hover .astro-hero__img,.astro-hero__small:hover .astro-hero__img{transform:scale(1.04)}
.astro-hero__overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.82) 0%,rgba(0,0,0,.35) 50%,transparent 100%)}
.astro-hero__overlay--small{background:linear-gradient(to top,rgba(0,0,0,.78) 0%,rgba(0,0,0,.2) 60%,transparent 100%)}
.astro-hero__text{position:absolute;bottom:0;left:0;right:0;padding:32px 36px;color:#fff}
.astro-hero__text--small{padding:22px 26px}
.astro-hero__title{font-family:'Playfair Display',serif;font-size:clamp(40px,5vw,68px);font-weight:700;line-height:1.05;margin:0;color:#fff}
.astro-hero__tag{font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:rgba(255,255,255,.55);display:block;margin-bottom:10px}
.astro-hero__stitle{font-family:'Playfair Display',serif;font-size:16px;font-weight:700;line-height:1.25;margin:0 0 10px;color:#fff}
.astro-hero__link{font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.78);border-bottom:1px solid rgba(255,255,255,.3);padding-bottom:2px;transition:border-color .2s}
.astro-hero__main:hover .astro-hero__link,.astro-hero__small:hover .astro-hero__link{border-color:rgba(255,255,255,.9);color:#fff}
.astro-hero__side{display:grid;grid-template-rows:1fr 1fr;gap:4px}
@media(max-width:900px){
  .astro-hero{grid-template-columns:1fr;height:auto}
  .astro-hero__main{height:320px}
  .astro-hero__side{grid-template-rows:none;grid-template-columns:1fr 1fr}
  .astro-hero__small{height:220px}
}
@media(max-width:560px){.astro-hero__side{grid-template-columns:1fr}}
</style>
