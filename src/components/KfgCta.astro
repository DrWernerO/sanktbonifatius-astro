---
// Abschluss-CTA „Familiengottesdienste" — Präfix `astro-kfgcta`.
---
<section class="astro-kfgcta">
  <div class="astro-kfgcta__inner">
    <h2 class="astro-kfgcta__title">Kommen Sie einfach vorbei</h2>
    <p class="astro-kfgcta__sub">Keine Anmeldung, keine Vorbedingung — einfach sonntags um 11 Uhr in St. Bonifatius, Sachsenhausen. Wir freuen uns auf Sie und Ihre Familie.</p>
    <div class="astro-kfgcta__btns">
      <a href="tel:+4969695975850" class="astro-kfgcta__btn astro-kfgcta__btn--primary">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.68 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6 6l1-1a2 2 0 0 1 2.11-.45c.91.32 1.85.55 2.81.68A2 2 0 0 1 21.73 16z"/></svg>
        069 695 97 58 50
      </a>
      <a href="mailto:info@sanktbonifatius.de" class="astro-kfgcta__btn astro-kfgcta__btn--ghost">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        E-Mail schreiben
      </a>
    </div>
  </div>
</section>

<style is:global>
.astro-kfgcta{padding:80px 0;background:linear-gradient(135deg,#4a2e1a 0%,#9a2d2d 100%);width:100vw;position:relative;left:50%;margin-left:-50vw;margin-right:-50vw;text-align:center}
.astro-kfgcta__inner{max-width:700px;margin:0 auto;padding:0 40px}
.astro-kfgcta__title{font-family:'Playfair Display',Georgia,serif;font-size:clamp(28px,4vw,44px);font-weight:700;color:#fff;margin:0 0 14px}
.astro-kfgcta__sub{font-size:17px;color:rgba(255,255,255,.85);line-height:1.6;margin:0 0 32px}
.astro-kfgcta__btns{display:flex;gap:16px;justify-content:center;flex-wrap:wrap}
.astro-kfgcta__btn{display:inline-flex;align-items:center;gap:10px;padding:14px 28px;font-size:15px;font-weight:600;text-decoration:none;border-radius:50px;transition:background .18s,color .18s,transform .18s}
.astro-kfgcta__btn--primary{background:#fff;color:#9a2d2d}
.astro-kfgcta__btn--primary:hover{background:#f0e8d8;transform:translateY(-2px)}
.astro-kfgcta__btn--ghost{background:transparent;color:#fff;border:1.5px solid rgba(255,255,255,.5)}
.astro-kfgcta__btn--ghost:hover{background:rgba(255,255,255,.12);border-color:#fff}
@media(max-width:600px){.astro-kfgcta__inner{padding:0 20px}.astro-kfgcta{padding:56px 0}}
</style>
