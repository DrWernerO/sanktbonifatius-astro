---
// Abschluss-CTA „Fragen zu Freizeiten?" (WP-Block `fz-cta`). Eigene Klassen `astro-fzcta`.
// Warm-brauner Verlauf (Design-System §5: kein Blau-/Near-Black-Banner) — konsistent mit JugendCta.
// „Pfarrbüro kontaktieren" → info@ (Handbuch 11). Zweitlink zu den Reisebedingungen.
---
<section class="astro-fzcta">
  <div class="astro-fzcta__in">
    <p class="astro-fzcta__eyebrow">Wir helfen weiter</p>
    <h2 class="astro-fzcta__hl">Fragen zu Freizeiten?</h2>
    <p class="astro-fzcta__sub">
      Du bist dir unsicher, welche Freizeit zu dir passt? Oder hast Fragen zur Anmeldung?
      Schreib uns &#8212; wir helfen gerne weiter.
    </p>
    <div class="astro-fzcta__btns">
      <a class="astro-fzcta__btn astro-fzcta__btn--primary"
         href="mailto:info@sanktbonifatius.de?subject=Frage%20zu%20Kinder-%20und%20Jugendfreizeiten">Pfarrb&uuml;ro kontaktieren</a>
      <a class="astro-fzcta__btn astro-fzcta__btn--ghost" href="/jugend/reisebedingungen/">Reisebedingungen &#8594;</a>
    </div>
  </div>
</section>

<style is:global>
.astro-fzcta{position:relative;width:100vw;left:50%;margin-left:-50vw;margin-right:-50vw;background:linear-gradient(135deg,#4a2e1a 0%,#3a2315 100%);color:#fff;padding:76px 0;overflow:hidden}
.astro-fzcta::after{content:"";position:absolute;inset:0;background:radial-gradient(circle at 20% 10%,rgba(197,165,90,.16),transparent 55%)}
.astro-fzcta__in{position:relative;z-index:1;max-width:760px;margin:0 auto;padding:0 40px;text-align:center}
.astro-fzcta__eyebrow{font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:#d4aa5a;margin:0 0 14px;font-weight:600}
.astro-fzcta__hl{font-family:'Playfair Display',serif;font-size:clamp(26px,3.4vw,40px);font-weight:700;color:#fff;margin:0 0 14px}
.astro-fzcta__sub{font-size:clamp(15px,1.8vw,19px);color:rgba(255,255,255,.85);line-height:1.6;margin:0 auto 32px;max-width:560px}
.astro-fzcta__btns{display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:16px}
.astro-fzcta__btn{display:inline-flex;align-items:center;gap:10px;padding:14px 28px;border-radius:50px;font-size:15px;font-weight:600;text-decoration:none;transition:background .2s,border-color .2s,color .2s}
.astro-fzcta__btn--primary{background:#9a2d2d;color:#fff}
.astro-fzcta__btn--primary:hover{background:#b8423f}
.astro-fzcta__btn--ghost{border:1.5px solid rgba(255,255,255,.55);color:#fff}
.astro-fzcta__btn--ghost:hover{border-color:#fff;background:rgba(255,255,255,.1)}
@media(max-width:600px){.astro-fzcta{padding:56px 0}.astro-fzcta__in{padding:0 20px}}
</style>
