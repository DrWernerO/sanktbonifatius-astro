---
// Abschluss-CTA „BonFamily WhatsApp-Kanal" — Präfix `astro-wacta`.
const WA_URL = 'https://whatsapp.com/channel/0029VbC6BfmJ3juxrDFhJy16';
const WA_ICON = `<svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>`;
---
<section class="astro-wacta">
  <div class="astro-wacta__inner">
    <div class="astro-wacta__box">
      <div class="astro-wacta__icon-wrap" set:html={WA_ICON} />
      <h2 class="astro-wacta__title">Nutzen Sie unseren heißen Draht</h2>
      <p class="astro-wacta__sub">Wir wissen, wie trubelig der Familienalltag sein kann. Deshalb möchten wir Ihnen mit diesem Kanal einen kurzen, unkomplizierten Weg bieten, um über alles Interessante bei BonFamily informiert zu bleiben und nichts Wichtiges mehr zu verpassen. Wir freuen uns auf Sie!</p>
      <a href={WA_URL} target="_blank" rel="noopener" class="astro-wacta__btn">
        <Fragment set:html={WA_ICON} />
        Jetzt abonnieren
      </a>
    </div>
  </div>
</section>

<style is:global>
.astro-wacta{padding:80px 0;background:#f0ebe4;width:100vw;position:relative;left:50%;margin-left:-50vw;margin-right:-50vw}
.astro-wacta__inner{max-width:780px;margin:0 auto;padding:0 40px}
.astro-wacta__box{background:#fff;border-radius:20px;box-shadow:0 8px 40px rgba(18,140,126,.15);border-top:5px solid #128C7E;padding:52px 56px;text-align:center}
.astro-wacta__icon-wrap{color:#25D366;margin-bottom:20px;display:flex;justify-content:center}
.astro-wacta__icon-wrap svg{width:48px;height:48px}
.astro-wacta__title{font-family:'Playfair Display',Georgia,serif;font-size:clamp(24px,3.5vw,36px);font-weight:700;color:#0a4e44;margin:0 0 18px;line-height:1.2}
.astro-wacta__sub{font-size:17px;color:#5a4a3a;line-height:1.75;margin:0 0 36px;max-width:580px;margin-inline:auto;margin-bottom:36px}
.astro-wacta__btn{display:inline-flex;align-items:center;gap:10px;padding:16px 36px;background:#25D366;color:#fff;font-size:16px;font-weight:700;text-decoration:none;border-radius:50px;transition:background .18s,transform .18s,box-shadow .18s;box-shadow:0 6px 24px rgba(37,211,102,.35)}
.astro-wacta__btn:hover{background:#1fb859;transform:translateY(-2px);box-shadow:0 10px 32px rgba(37,211,102,.45)}
@media(max-width:700px){.astro-wacta__box{padding:36px 28px}}
@media(max-width:600px){.astro-wacta__inner{padding:0 20px}.astro-wacta{padding:56px 0}}
</style>
