---
// Weitere Familienangebote (Schnell-Links) — Präfix `astro-fmquick`.
const items = [
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
    title: 'Kindertagesstätten',
    desc: 'Unsere fünf Kitas in Frankfurt für Kinder von 0 bis 6 Jahren.',
    href: '/kitas/',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><circle cx="12" cy="20" r="2" fill="currentColor" stroke="none"/></svg>`,
    title: 'Familiengottesdienste',
    desc: 'Kindergottesdienste und Familiengottesdienste jeden 1. und 3. Sonntag.',
    href: '/bonfamily/familiengottesdienste/',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>`,
    title: 'BonFamily WhatsApp-Kanal',
    desc: 'Aktuelle Infos zu BonFamily-Angeboten direkt aufs Handy.',
    href: '/bonfamily/whatsapp-kanal/',
  },
];
---
<section class="astro-fmquick">
  <div class="astro-fmquick__inner">
    <div class="astro-fmquick__head">
      <h2 class="astro-fmquick__title">Weitere Familienangebote</h2>
      <p class="astro-fmquick__sub">Vielleicht passt eines dieser Angebote auch zu Ihrer Familie.</p>
    </div>
    <div class="astro-fmquick__grid">
      {items.map(item => (
        <a href={item.href} class="astro-fmquick__card">
          <div class="astro-fmquick__icon" set:html={item.icon} />
          <div class="astro-fmquick__card-body">
            <h3 class="astro-fmquick__card-title">{item.title}</h3>
            <p class="astro-fmquick__card-desc">{item.desc}</p>
          </div>
          <span class="astro-fmquick__arrow" aria-hidden="true">→</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style is:global>
.astro-fmquick{padding:72px 0;background:#f7f3ef;width:100vw;position:relative;left:50%;margin-left:-50vw;margin-right:-50vw}
.astro-fmquick__inner{max-width:1200px;margin:0 auto;padding:0 40px}
.astro-fmquick__head{text-align:center;margin-bottom:48px}
.astro-fmquick__title{font-family:'Playfair Display',Georgia,serif;font-size:clamp(24px,3vw,34px);font-weight:700;color:#9a2d2d;margin:0 0 12px}
.astro-fmquick__sub{font-size:17px;color:#6b5c52;margin:0}
.astro-fmquick__grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.astro-fmquick__card{background:#fff;border:1px solid #e0d8cf;border-radius:14px;padding:28px 24px;display:flex;align-items:flex-start;gap:18px;text-decoration:none;transition:border-color .18s,transform .18s,box-shadow .18s;box-shadow:0 2px 12px rgba(30,21,18,.05)}
.astro-fmquick__card:hover{border-color:#9a2d2d;transform:translateY(-2px);box-shadow:0 6px 24px rgba(30,21,18,.1)}
.astro-fmquick__icon{color:#9a2d2d;flex-shrink:0;margin-top:2px}
.astro-fmquick__card-body{flex:1}
.astro-fmquick__card-title{font-size:16px;font-weight:700;color:#2c2420;margin:0 0 6px}
.astro-fmquick__card-desc{font-size:14px;line-height:1.6;color:#6b5c52;margin:0}
.astro-fmquick__arrow{font-size:18px;color:#9a2d2d;flex-shrink:0;transition:transform .18s;align-self:center}
.astro-fmquick__card:hover .astro-fmquick__arrow{transform:translateX(4px)}
@media(max-width:860px){.astro-fmquick__grid{grid-template-columns:1fr}}
@media(max-width:600px){.astro-fmquick__inner{padding:0 20px}.astro-fmquick{padding:52px 0}}
</style>
