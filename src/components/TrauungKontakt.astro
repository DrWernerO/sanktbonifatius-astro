---
// Abschluss-Kontakt-Band „Jetzt Kontakt aufnehmen" (WP-Block `tr-kontakt`). Eigene Klassen
// `astro-tr-kontakt`. Inhalt 1:1 aus WP-Seite 47394. id="tr-kontakt" als Sprungziel aus dem Hero-Button.
---
<section class="astro-tr-kontakt" id="tr-kontakt">
  <div class="astro-tr-kontakt__inner">
    <p class="astro-tr-kontakt__eyebrow">Sakrament der Ehe</p>
    <h2>Jetzt Kontakt aufnehmen</h2>
    <p class="astro-tr-kontakt__sub">
      Wir freuen uns auf Ihre Nachricht. Das Zentrale Pfarrb&uuml;ro steht Ihnen f&uuml;r alle Fragen
      rund um Ihre kirchliche Trauung zur Verf&uuml;gung. Unser Pastoralteam beantwortet Ihre Fragen
      pers&ouml;nlich und begleitet Sie herzlich auf dem Weg zu Ihrer Trauung.
    </p>
    <div class="astro-tr-kontakt__actions">
      <a class="astro-tr-kontakt__btn" href="mailto:pfarrer@sanktbonifatius.de">Per E-Mail schreiben</a>
      <a class="astro-tr-kontakt__btn astro-tr-kontakt__btn--ghost" href="/kontakt/pfarrbuero/">Zum Pfarrb&uuml;ro</a>
    </div>
    <p class="astro-tr-kontakt__note">
      Weitere <a href="/segen-sakramente/">Kasualien und Gottesdienste</a> der Pfarrei finden Sie auf unserer Website.
    </p>
  </div>
</section>

<style is:global>
.astro-tr-kontakt{position:relative;width:100vw;left:50%;margin-left:-50vw;margin-right:-50vw;background:linear-gradient(135deg,#4a2e1a,#3a2315);padding:72px 0;text-align:center;overflow:hidden;scroll-margin-top:96px}
.astro-tr-kontakt__inner{position:relative;z-index:1;max-width:680px;margin:0 auto;padding:0 40px}
.astro-tr-kontakt__eyebrow{font-family:'Playfair Display',Georgia,serif;font-style:italic;color:rgba(255,255,255,.65);font-size:.95rem;margin:0 0 12px;letter-spacing:.04em}
.astro-tr-kontakt h2{font-family:'Playfair Display',Georgia,serif;font-size:clamp(28px,4vw,44px);color:#fff;margin:0 0 20px;font-weight:700}
.astro-tr-kontakt__sub{color:rgba(255,255,255,.82);font-size:1.05rem;max-width:600px;margin:0 auto 36px;line-height:1.7}
.astro-tr-kontakt__actions{display:flex;justify-content:center;align-items:center;gap:16px;flex-wrap:wrap}
.astro-tr-kontakt__btn{display:inline-flex;align-items:center;gap:10px;padding:15px 32px;border-radius:50px;font-size:16px;font-weight:700;text-decoration:none;background:#fff;color:#9a2d2d;transition:background .2s,color .2s}
.astro-tr-kontakt__btn:hover{background:#f3e7d4;color:#7e2424}
.astro-tr-kontakt__btn--ghost{background:transparent;color:#fff;box-shadow:inset 0 0 0 1.5px rgba(255,255,255,.5)}
.astro-tr-kontakt__btn--ghost:hover{background:rgba(255,255,255,.12);color:#fff}
.astro-tr-kontakt__note{color:rgba(255,255,255,.65);font-size:.92rem;margin:30px 0 0}
.astro-tr-kontakt__note a{color:#c8a96e;text-decoration:none;font-weight:600}
.astro-tr-kontakt__note a:hover{text-decoration:underline}
@media(max-width:600px){.astro-tr-kontakt{padding:56px 0}.astro-tr-kontakt__inner{padding:0 20px}}
</style>
