---
// Quick-Strip der Seite „Firmung" (WP-Block `ta-strip`). Eigene Klassen `astro-firm-strip`.
// Drei Kernaussagen 1:1 aus WP-Seite 46778.
const ITEMS = [
  { label: 'Ab 16 Jahren',
    text: 'Mindestalter bis Ende Juni des Firmjahres.' },
  { label: 'Kursstart im Herbst',
    text: 'Rund ein halbes Jahr Vorbereitung.' },
  { label: 'Firmung nach Ostern',
    text: 'Durch einen Beauftragten des Bischofs von Limburg.' },
];
---
<section class="astro-firm-strip">
  <div class="astro-firm-strip__inner">
    {ITEMS.map((it) => (
      <div class="astro-firm-strip__item">
        <p class="astro-firm-strip__label">{it.label}</p>
        <p class="astro-firm-strip__text" set:html={it.text} />
      </div>
    ))}
  </div>
</section>

<style is:global>
.astro-firm-strip{background:#9a2d2d;padding:42px 0}
.astro-firm-strip__inner{max-width:1140px;margin:0 auto;padding:0 48px;display:grid;grid-template-columns:repeat(3,1fr);gap:30px}
.astro-firm-strip__item{text-align:center;padding:0 12px}
.astro-firm-strip__item + .astro-firm-strip__item{border-left:1px solid rgba(255,255,255,.22)}
.astro-firm-strip__label{font-family:'Playfair Display',Georgia,serif;font-weight:700;font-size:1.15rem;color:#fff;margin:0 0 6px}
.astro-firm-strip__text{font-size:.92rem;color:rgba(255,255,255,.82);margin:0;line-height:1.55}
@media(max-width:720px){.astro-firm-strip__inner{grid-template-columns:1fr;gap:24px;padding:0 20px}.astro-firm-strip__item + .astro-firm-strip__item{border-left:none;border-top:1px solid rgba(255,255,255,.22);padding-top:24px}}
</style>
