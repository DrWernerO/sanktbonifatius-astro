---
// „Unsere Angebote bei einem Trauerfall in Frankfurt" — WP-Seite 47631 (WP-Block `tr-cards-sec`).
// Eigene Klassen `astro-trcards`. 6 Angebots-Karten mit SVG-Icons (kein Emoji, Handbuch 8/7).
const ANGEBOTE = [
  { title: 'Sterbesakramente', text: 'Krankensalbung und Wegzehrung — wir kommen jederzeit nach Hause oder ins Krankenhaus, auch nachts.',
    icon: '<path d="M12 3v18M5 9h14"/>' },
  { title: 'Trauergottesdienst', text: 'Ein würdiger Abschied: Requiem, Beerdigung und Urnenbeisetzung — nach Ihren Wünschen gestaltet.',
    icon: '<path d="M3 21h18M5 21V10l7-5 7 5v11M9 21v-6h6v6"/>' },
  { title: 'Trauerbegleitung', text: 'Seelsorgerinnen und Seelsorger hören zu — in Gesprächen, Hausbesuchen oder Gebetszeiten.',
    icon: '<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>' },
  { title: 'Praktische Hilfe', text: 'Beratung bei Formalitäten, Empfehlung von Bestattern, Hilfe bei Gedenkbuch und Danksagung.',
    icon: '<path d="M9 11l3 3L22 4M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>' },
  { title: 'Allerseelen & Jahrtag', text: 'Am 2. November gedenken wir gemeinsam aller Verstorbenen. Angehörige können Namen anmelden.',
    icon: '<path d="M12 2a5 5 0 0 0-5 5c0 2 1 3 1 5h8c0-2 1-3 1-5a5 5 0 0 0-5-5zM9 17h6M10 21h4"/>' },
  { title: 'Gemeinde & Gebet', text: 'Die Gemeinde betet mit und füreinander. Kerzen, Gedenkbücher, stille Zeiten — Sie sind nicht allein.',
    icon: '<path d="M12 21s-7-4.35-7-10a4 4 0 0 1 7-2.65A4 4 0 0 1 19 11c0 5.65-7 10-7 10z"/>' },
];
---
<section class="astro-trcards">
  <div class="astro-trcards__inner">
    <span class="astro-trcards__eyebrow">Wie wir helfen</span>
    <h2 class="astro-trcards__hl">Unsere Angebote bei einem Trauerfall in Frankfurt</h2>
    <div class="astro-trcards__grid">
      {ANGEBOTE.map((a) => (
        <article class="astro-trcards__card">
          <span class="astro-trcards__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={a.icon} />
          </span>
          <h3 class="astro-trcards__title">{a.title}</h3>
          <p class="astro-trcards__text">{a.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style is:global>
.astro-trcards{background:#f7f3ef;padding:80px 0}
.astro-trcards__inner{max-width:1140px;margin:0 auto;padding:0 40px;text-align:center}
.astro-trcards__eyebrow{display:inline-block;font-size:12px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:#9a2d2d;margin:0 0 14px}
.astro-trcards__hl{font-family:'Playfair Display',serif;font-size:clamp(26px,3.4vw,40px);font-weight:700;color:#2c2420;margin:0 0 44px;line-height:1.2}
.astro-trcards__grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:24px;text-align:left}
.astro-trcards__card{background:#fff;border-radius:14px;padding:32px;box-shadow:0 4px 18px rgba(30,21,18,.05)}
.astro-trcards__icon{display:inline-flex;align-items:center;justify-content:center;width:54px;height:54px;border-radius:50%;background:#f0e6e6;color:#9a2d2d;margin:0 0 18px}
.astro-trcards__icon svg{width:26px;height:26px}
.astro-trcards__title{font-family:'Playfair Display',serif;font-size:20px;font-weight:700;color:#2c2420;margin:0 0 10px}
.astro-trcards__text{font-size:15px;color:#5c534c;line-height:1.65;margin:0}
@media(max-width:600px){.astro-trcards{padding:56px 0}.astro-trcards__inner{padding:0 20px}.astro-trcards__card{padding:28px}}
</style>
