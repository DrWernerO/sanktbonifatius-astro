<style is:global>
  .bh3a-hdr {
    position: fixed; top: 0; z-index: 1000; width: 100%; left: 0;
    background: rgba(20,10,2,0.55);
    backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
  }
  .bh3a-hdr__in {
    max-width: 1280px; margin: 0 auto; padding: 0 32px;
    display: flex; align-items: center; height: 80px;
  }
  .bh3a-brand {
    display: flex; align-items: center;
    text-decoration: none; flex-shrink: 0;
  }
  .bh3a-brand img { height: 76px; width: auto; display: block; }
  .bh3a-soc {
    display: flex; gap: 18px; align-items: center;
    margin-left: auto; margin-right: 20px;
  }
  .bh3a-soc a { color: #d4c9b5; display: flex; align-items: center; transition: color .2s; }
  .bh3a-soc a:hover { color: #c5a55a; }
  .bh3a-rnav { display: flex; align-items: center; gap: 2px; flex-shrink: 0; }
  .bh3a-dd { position: relative; }
  .bh3a-dd > a {
    font-size: 12px; color: #c5b9a8; padding: 8px 11px;
    display: flex; align-items: center; gap: 3px;
    text-decoration: none; white-space: nowrap;
  }
  .bh3a-dd > a::after { content: '▾'; font-size: 8px; opacity: .5; }
  .bh3a-dd__menu {
    display: none; position: absolute; top: 100%; left: 0;
    background: #4a3020; border: 1px solid #5c3d28;
    border-radius: 7px; padding: 6px 0; min-width: 210px; z-index: 100;
  }
  .bh3a-dd__menu a {
    display: block; padding: 9px 18px; font-size: 12px;
    color: #b5a898; text-decoration: none; white-space: nowrap;
  }
  .bh3a-dd__menu a:hover { color: #c5a55a; background: rgba(197,165,90,.06); }
  .bh3a-dd:hover .bh3a-dd__menu { display: block; }
  .bh3a-dd:last-child .bh3a-dd__menu { left: auto; right: 0; }
  .bh3a-dd__menu::before {
    content: ''; position: absolute; left: 0; right: 0;
    top: -10px; height: 12px; background: transparent;
  }
  .bh3a-dd > a { padding-bottom: 12px; }
  .bh3a-btn-spd {
    background: #9a2d2d !important; color: #fff !important;
    font-size: 13px; font-weight: 600;
    padding: 9px 20px; border-radius: 50px; text-decoration: none;
    margin-left: 10px; white-space: nowrap; transition: background .2s;
    display: inline-flex !important; align-items: center;
  }
  .bh3a-btn-spd:hover { background: #7e2424 !important; }

  /* Eigenständige Top-Level-Links ohne Dropdown (Kirchorte, Kitas) */
  .bh3a-navlink {
    font-size: 12px; color: #c5b9a8; padding: 8px 11px 12px;
    text-decoration: none; white-space: nowrap;
    display: flex; align-items: center; transition: color .2s;
  }
  .bh3a-navlink:hover { color: #c5a55a; }

  /* Hamburger-Button */
  .bh3a-hamburger {
    display: none; flex-direction: column; justify-content: center;
    gap: 5px; background: none; border: none; cursor: pointer;
    padding: 8px; margin-left: auto;
  }
  .bh3a-hamburger span {
    display: block; width: 24px; height: 2px;
    background: #f0e8d8; border-radius: 2px;
    transition: transform .25s, opacity .25s;
  }

  @media (max-width: 860px) {
    .bh3a-soc { display: none; }
    .bh3a-rnav { display: none; }
    .bh3a-hamburger { display: flex; }
  }

  /* Mobiles Menü (per JS eingeblendet) */
  .bh3a-hdr.bh3a-open .bh3a-rnav {
    display: flex; flex-direction: column; align-items: stretch;
    position: fixed; top: 80px; left: 0; right: 0;
    height: calc(100vh - 80px);
    background: rgba(15,8,2,.92); backdrop-filter: blur(8px);
    z-index: 99999; overflow-y: auto; padding: 8px 0 80px;
  }
  .bh3a-hdr.bh3a-open .bh3a-dd {
    display: block; width: 100%;
    border-bottom: 1px solid rgba(255,255,255,.12);
  }
  .bh3a-hdr.bh3a-open .bh3a-dd > a {
    font-size: 17px; color: #f0e8d8; padding: 16px 24px; width: 100%;
  }
  .bh3a-hdr.bh3a-open .bh3a-dd > a::after { display: none; }
  .bh3a-hdr.bh3a-open .bh3a-navlink {
    font-size: 17px; color: #f0e8d8; padding: 16px 24px; width: 100%;
    border-bottom: 1px solid rgba(255,255,255,.12);
  }
  .bh3a-hdr.bh3a-open .bh3a-dd__menu[data-open="1"] {
    display: block; position: static; background: rgba(255,255,255,.06);
    border: none; border-radius: 0; min-width: auto; padding: 4px 0 12px;
  }
  .bh3a-hdr.bh3a-open .bh3a-dd__menu[data-open="1"] a {
    padding: 10px 24px 10px 40px; font-size: 15px;
    color: rgba(240,232,216,.85);
  }
  .bh3a-hdr.bh3a-open .bh3a-btn-spd {
    margin: 20px 24px; width: calc(100% - 48px);
    text-align: center; padding: 12px;
  }
</style>

<script>
  (function () {
    const hdr = document.querySelector('.bh3a-hdr');
    const hdrIn = document.querySelector('.bh3a-hdr__in');
    if (!hdr || !hdrIn) return;
    const nav = document.querySelector('.bh3a-rnav');

    // Hamburger-Button erstellen
    let btn = document.querySelector('.bh3a-hamburger');
    if (!btn) {
      btn = document.createElement('button');
      btn.className = 'bh3a-hamburger';
      btn.setAttribute('aria-label', 'Menü öffnen');
      btn.innerHTML = '<span></span><span></span><span></span>';
      hdrIn.appendChild(btn);
    }

    // Mobile: Dropdown per Klick
    nav && nav.querySelectorAll('.bh3a-dd').forEach(function (dd) {
      const m = dd.querySelector('.bh3a-dd__menu');
      if (!m) return;
      dd.addEventListener('click', function (e) {
        if (!hdr.classList.contains('bh3a-open')) return;
        if (m.contains(e.target)) return;
        e.preventDefault(); e.stopPropagation();
        const isOpen = m.getAttribute('data-open') === '1';
        nav.querySelectorAll('.bh3a-dd__menu').forEach(function (om) {
          om.removeAttribute('data-open');
        });
        if (!isOpen) m.setAttribute('data-open', '1');
      });
    });

    function open() {
      hdr.classList.add('bh3a-open');
      btn.setAttribute('aria-label', 'Menü schließen');
      btn.innerHTML =
        '<span style="transform:rotate(45deg) translate(5px,7px)"></span>' +
        '<span style="opacity:0"></span>' +
        '<span style="transform:rotate(-45deg) translate(5px,-7px)"></span>';
      document.body.style.overflow = 'hidden';
    }

    function close() {
      hdr.classList.remove('bh3a-open');
      nav && nav.querySelectorAll('.bh3a-dd__menu').forEach(function (m) {
        m.removeAttribute('data-open');
      });
      btn.setAttribute('aria-label', 'Menü öffnen');
      btn.innerHTML = '<span></span><span></span><span></span>';
      document.body.style.overflow = '';
    }

    btn.addEventListener('click', function (e) {
      e.stopPropagation();
      hdr.classList.contains('bh3a-open') ? close() : open();
    });

    document.addEventListener('click', function (e) {
      if (hdr.contains(e.target)) return;
      if (hdr.classList.contains('bh3a-open')) close();
    });

    // ESC-Taste schließt Menü
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') close();
    });
  })();
</script>
