---
// „Häufige Fragen zur Seelsorge" — WP-Seite 48947 (WP-Block `sl-faq`). Eigene Klassen
// `astro-slfaq`. Natives <details> (kein JS, Muster wie PbFaq/TaufeFaq). Feste Inhalte.
const FAQ = [
  { q: 'Was ist geistliche Begleitung — und für wen ist sie gedacht?',
    a: 'Geistliche Begleitung steht jedem Menschen offen, unabhängig von Konfession oder Lebensweg. Sie besteht darin, anderen zu helfen, die Freude zu erfahren, angenommen und geliebt zu werden, wie sie wirklich sind. Ein geistlicher Begleiter hört betend zu und lädt ein, in unserem Herzen einen Raum für Gottes Stimme zu schaffen.' },
  { q: 'Wo finde ich einen Seelsorger in Frankfurt-Sachsenhausen?',
    a: 'In der Pfarrei Sankt Bonifatius Frankfurt stehen Ihnen P.&nbsp;Gaby Geagea cml. und Sr.&nbsp;Bettina Rupp SSpS für Seelsorge und geistliche Begleitung zur Verfügung. Sie erreichen uns über das Pfarrbüro oder sprechen die Begleiterinnen direkt an. Alle Kontaktdaten finden Sie auf dieser Seite.' },
  { q: 'Ist seelsorgliche Begleitung vertraulich?',
    a: 'Ja, selbstverständlich. Alle seelsorglichen Gespräche unterliegen der vollständigen Verschwiegenheit. Was Sie im Gespräch teilen, bleibt zwischen Ihnen und Ihrem Gesprächspartner.' },
  { q: 'Muss ich Mitglied der Pfarrei sein, um Seelsorge in Anspruch zu nehmen?',
    a: 'Nein. Seelsorge und geistliche Begleitung sind offen für alle Menschen — ohne Vorbedingungen. Sie brauchen keinen besonderen Anlass und auch keine Kirchenmitgliedschaft, um Kontakt aufzunehmen.' },
];
---
<section class="astro-slfaq">
  <div class="astro-slfaq__inner">
    <p class="astro-slfaq__eyebrow">Häufige Fragen</p>
    <h2 class="astro-slfaq__hl">Häufige Fragen zur Seelsorge</h2>
    <p class="astro-slfaq__lead">
      Antworten auf die meistgestellten Fragen rund um Seelsorge und geistliche Begleitung in Frankfurt.
    </p>
    <div class="astro-slfaq__list">
      {FAQ.map((f) => (
        <details>
          <summary><span set:html={f.q} /></summary>
          <div class="astro-slfaq__a" set:html={f.a} />
        </details>
      ))}
    </div>
  </div>
</section>

<style is:global>
.astro-slfaq{background:#f7f3ef;padding:80px 0}
.astro-slfaq__inner{max-width:840px;margin:0 auto;padding:0 40px}
.astro-slfaq__eyebrow{font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:#9a2d2d;margin:0 0 14px;font-weight:600;text-align:center}
.astro-slfaq__hl{font-family:'Playfair Display',serif;font-size:clamp(26px,3.4vw,40px);font-weight:700;color:#2c2420;margin:0 0 12px;text-align:center}
.astro-slfaq__lead{font-size:16px;color:#5c534c;line-height:1.6;text-align:center;max-width:600px;margin:0 auto 36px}
.astro-slfaq__list{max-width:840px;margin:0 auto}
.astro-slfaq details{background:#fff;border-radius:10px;margin-bottom:10px;box-shadow:0 2px 12px rgba(30,21,18,.05);overflow:hidden}
.astro-slfaq summary{padding:20px 24px;cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;gap:12px;font-weight:600;font-size:16px;color:#2c2420}
.astro-slfaq summary::-webkit-details-marker{display:none}
.astro-slfaq summary::after{content:"+";font-size:24px;color:#9a2d2d;transition:transform .2s;flex-shrink:0}
.astro-slfaq details[open] summary::after{transform:rotate(45deg)}
.astro-slfaq__a{padding:0 24px 20px;font-size:15px;color:#3d3530;line-height:1.65}
@media(max-width:600px){.astro-slfaq{padding:56px 0}.astro-slfaq__inner{padding:0 20px}}
</style>
