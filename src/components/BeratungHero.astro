---
// Hero der Seite „Beratung und Hilfe" — WP-Seite 48312 (/kontakt/beratung-und-hilfe/).
// Eigene Klassen `astro-ber` (Handbuch Abschnitt 3 — niemals WP-Klassen `berh-…`).
// Hero-Bild lokal unter public/uploads/ (Handbuch 1b); dunkler Verlauf darüber für
// Lesbarkeit + würdevollen, ruhigen Ton (sensibles Thema). Genau EINE sichtbare <h1>.
const HERO = '/uploads/2023/07/beratung-hilfe-stbonifatius.jpg';
---
<section class="astro-ber-hero" role="img" aria-label="Beratung und Hilfe in der Pfarrei Sankt Bonifatius Frankfurt">
  <div class="astro-ber-hero__inner">
    <p class="astro-ber-hero__eyebrow">Pfarrei Sankt Bonifatius &#183; Frankfurt</p>
    <h1 class="astro-ber-hero__title">Beratung und Hilfe</h1>
    <p class="astro-ber-hero__sub">
      Ob Sie seelische Unterstützung suchen, Orientierung brauchen oder vertraulich
      mit jemandem sprechen möchten &#8212; wir sind für Sie da.
    </p>
    <div class="astro-ber-hero__ctas">
      <a href="#astro-ber-team" class="astro-ber-hero__btn astro-ber-hero__btn--primary">Ansprechpersonen finden</a>
      <a href="#astro-ber-notfall" class="astro-ber-hero__btn astro-ber-hero__btn--outline">Notfall-Kontakte</a>
    </div>
  </div>
</section>

<style is:global>
.astro-ber-hero{position:relative;width:100vw;left:50%;margin-left:-50vw;margin-right:-50vw;display:flex;align-items:flex-end;min-height:440px;overflow:hidden;background:linear-gradient(180deg,rgba(33,19,13,.26) 0%,rgba(40,24,16,.38) 55%,rgba(30,21,18,.64) 100%),url('/uploads/2023/07/beratung-hilfe-stbonifatius.jpg') center/cover no-repeat;color:#f3ead9}
.astro-ber-hero::after{content:"";position:absolute;inset:0;background:radial-gradient(ellipse at 70% 50%,rgba(197,165,90,.12) 0%,transparent 62%)}
.astro-ber-hero__inner{position:relative;z-index:1;max-width:1200px;width:100%;margin:0 auto;padding:104px 40px 64px;text-align:center}
.astro-ber-hero__eyebrow{font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:#f0d79a;margin:0 0 16px;text-shadow:0 1px 10px rgba(0,0,0,.45)}
.astro-ber-hero__title{font-family:'Playfair Display',serif;font-weight:700;line-height:1.08;color:#fff;font-size:clamp(36px,5.6vw,62px);margin:0;letter-spacing:-.01em;text-shadow:0 2px 18px rgba(0,0,0,.45)}
.astro-ber-hero__sub{font-size:clamp(16px,1.9vw,19px);color:#f3ead9;line-height:1.62;margin:20px auto 0;max-width:580px;text-shadow:0 1px 12px rgba(0,0,0,.5)}
.astro-ber-hero__ctas{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-top:34px}
.astro-ber-hero__btn{padding:13px 26px;border-radius:50px;font-size:15px;font-weight:600;text-decoration:none;transition:background .2s,transform .2s,border-color .2s}
.astro-ber-hero__btn--primary{background:#9a2d2d;color:#fff}
.astro-ber-hero__btn--primary:hover{background:#7e2424;transform:translateY(-1px)}
.astro-ber-hero__btn--outline{border:2px solid rgba(197,165,90,.7);color:#c5a55a}
.astro-ber-hero__btn--outline:hover{background:rgba(197,165,90,.12)}
@media(max-width:600px){.astro-ber-hero{min-height:360px}.astro-ber-hero__inner{padding:88px 20px 44px}}
</style>
