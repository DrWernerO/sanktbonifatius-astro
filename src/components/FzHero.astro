---
// Hero der Unterseite „Kinder- & Jugendfreizeiten" — WP-Seite 49157
// (/jugend/kinder-und-jugendfreizeiten/, ersetzt WP-Block `fz-hero`).
// Eigene Klassen `astro-fzhero` (goldene Regel, Handbuch Abschnitt 3 — niemals WP-Klassen `fz-…`).
// Full-Bleed-Foto + warm-dunkler Verlauf (konsistent mit JugendHero) + Text.
// Bild lokal unter public/uploads/ (vom Live-WP geladen, Handbuch 1b).
const bg = '/uploads/2025/12/freizeiten-jugend-2026.jpg';
---
<section class="astro-fzhero">
  <div class="astro-fzhero__bg" role="img"
       aria-label="Kinder und Jugendliche baden gemeinsam in einem klaren See"
       style={`background-image:url('${bg}')`}></div>
  <div class="astro-fzhero__overlay"></div>
  <div class="astro-fzhero__inner">
    <p class="astro-fzhero__eyebrow">Jugend &middot; Sankt Bonifatius Frankfurt</p>
    <h1 class="astro-fzhero__title">Freizeiten &amp; Fahrten 2026</h1>
    <p class="astro-fzhero__sub">
      Sonne, Gemeinschaft und echte Abenteuer &#8212; vom Tagesausflug bis zur Sommerfreizeit.
      Finde heraus, welche Fahrt zu dir passt, und sei dabei.
    </p>
    <div class="astro-fzhero__btns">
      <a class="astro-fzhero__btn astro-fzhero__btn--primary" href="#alle-freizeiten">Alle Freizeiten 2026</a>
      <a class="astro-fzhero__btn astro-fzhero__btn--ghost" href="/jugend/reisebedingungen/">Reisebedingungen</a>
    </div>
  </div>
</section>

<style is:global>
.astro-fzhero{position:relative;width:100vw;left:50%;margin-left:-50vw;margin-right:-50vw;height:min(68vh,540px);display:flex;align-items:flex-end;overflow:hidden}
.astro-fzhero__bg{position:absolute;inset:0;background-size:cover;background-position:53% 50%}
.astro-fzhero__overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(20,32,45,.10) 0%,rgba(20,32,45,.48) 58%,rgba(15,24,38,.86) 100%)}
.astro-fzhero__inner{position:relative;z-index:2;width:100%;max-width:1280px;margin:0 auto;padding:0 40px 52px;color:#f0e8d8}
.astro-fzhero__eyebrow{font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:#c5a55a;margin:0 0 14px;font-weight:600}
.astro-fzhero__title{font-family:'Playfair Display',Georgia,serif;font-size:clamp(34px,5vw,64px);color:#fff;margin:0 0 16px;line-height:1.08;font-weight:700}
.astro-fzhero__sub{color:rgba(255,255,255,.9);font-size:clamp(16px,2vw,21px);margin:0 0 26px;max-width:620px;line-height:1.5}
.astro-fzhero__btns{display:flex;flex-wrap:wrap;gap:14px}
.astro-fzhero__btn{display:inline-flex;align-items:center;padding:13px 26px;border-radius:50px;font-size:15px;font-weight:600;text-decoration:none;transition:background .2s,border-color .2s,color .2s}
.astro-fzhero__btn--primary{background:#9a2d2d;color:#fff}
.astro-fzhero__btn--primary:hover{background:#b8423f}
.astro-fzhero__btn--ghost{border:1.5px solid rgba(255,255,255,.7);color:#fff}
.astro-fzhero__btn--ghost:hover{border-color:#fff;background:rgba(255,255,255,.12)}
@media(max-width:600px){.astro-fzhero{height:min(64vh,440px)}.astro-fzhero__inner{padding:0 20px 38px}}
</style>
