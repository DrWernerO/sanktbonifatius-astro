---
// „Was bringt Ihnen eine Anmeldung?" — WP-Seite 49146 (ersetzt WP-Block `cd-info`).
// Eigene Klassen `astro-cd-info`. Inhalte 1:1 aus dem WP-Content (Lead + 3 Vorteils-Karten).
// SVG-Icons (kein Emoji, Handbuch Lektion 7), dekorativ → aria-hidden.
const bullets = [
  {
    title: 'Veranstaltungen im Blick',
    text: 'Sie sehen das gesamte Veranstaltungsangebot der Pfarrei online und wissen jederzeit, was in unseren Kirchorten geplant ist.',
    icon: '<rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>',
  },
  {
    title: 'Im Austausch bleiben',
    text: 'In den ChurchDesk-Gruppen tauschen Sie mit anderen Ehrenamtlichen Nachrichten und Dokumente aus und stimmen sich unkompliziert ab.',
    icon: '<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>',
  },
  {
    title: 'Gut informiert sein',
    text: 'Über die ChurchDesk-Mail gibt Ihnen das Pastoralteam wichtige Informationen für Ehrenamtliche direkt weiter.',
    icon: '<path d="M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z"/><polyline points="22,6 12,13 2,6"/>',
  },
];
---
<section class="astro-cd-info">
  <div class="astro-cd-info__inner">
    <div class="astro-cd-info__head">
      <h2 class="astro-cd-info__hl">Was bringt Ihnen eine Anmeldung?</h2>
      <p class="astro-cd-info__lead">
        ChurchDesk ist die digitale Plattform unserer Pfarrei. Wenn Sie sich als ehrenamtlich
        engagierte Person persönlich anmelden, sind Sie mit dem Pastoralteam und den anderen
        Engagierten gut verbunden. Die Anmeldung ist für Sie als Einzelperson gedacht, nicht
        für eine ganze Gruppe.
      </p>
    </div>
    <div class="astro-cd-info__grid">
      {bullets.map((b) => (
        <div class="astro-cd-bullet">
          <svg class="astro-cd-bullet__icon" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="1.8" stroke-linecap="round"
               stroke-linejoin="round" aria-hidden="true" set:html={b.icon} />
          <h3 class="astro-cd-bullet__title">{b.title}</h3>
          <p class="astro-cd-bullet__text">{b.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
.astro-cd-info{background:#fff;padding:72px 0 40px}
.astro-cd-info__inner{max-width:880px;margin:0 auto;padding:0 40px}
.astro-cd-info__head{text-align:center;margin:0 0 36px}
.astro-cd-info__hl{font-family:'Playfair Display',Georgia,serif;font-size:clamp(24px,3.5vw,32px);color:#2c2420;margin:0 0 14px;font-weight:700;line-height:1.15}
.astro-cd-info__lead{font-size:clamp(15px,1.8vw,16.5px);color:#6b5c52;max-width:680px;margin:0 auto;line-height:1.7}
.astro-cd-info__grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px}
.astro-cd-bullet{background:#f7f3ef;border-radius:12px;padding:26px 24px;border-top:3px solid #c5a55a}
.astro-cd-bullet__icon{width:34px;height:34px;color:#9a2d2d;margin:0 0 14px}
.astro-cd-bullet__title{font-family:'Playfair Display',Georgia,serif;font-size:18px;color:#2c2420;margin:0 0 10px;font-weight:700;line-height:1.25}
.astro-cd-bullet__text{font-size:14.5px;color:#6b5c52;line-height:1.65;margin:0}
@media(max-width:780px){.astro-cd-info__grid{grid-template-columns:1fr}}
@media(max-width:600px){.astro-cd-info{padding:52px 0 32px}.astro-cd-info__inner{padding:0 20px}}
</style>
