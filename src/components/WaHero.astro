---
// Hero „BonFamily WhatsApp-Kanal" — Präfix `astro-wahero`.
// Grüner WA-Farbverlauf (kein Foto), SVG-Chat-Muster als dezente Textur.
const WA_URL = 'https://whatsapp.com/channel/0029VbC6BfmJ3juxrDFhJy16';
---
<section class="astro-wahero">
  <div class="astro-wahero__bg" aria-hidden="true"></div>
  <div class="astro-wahero__inner">
    <span class="astro-wahero__eyebrow">BonFamily · Pfarrei Sankt Bonifatius Frankfurt</span>
    <h1 class="astro-wahero__title">BonFamily WhatsApp-Kanal</h1>
    <p class="astro-wahero__sub">Unkompliziert und aktuell: Alle wichtigen Infos zu BonFamily-Angeboten in der Pfarrei Sankt Bonifatius Frankfurt – einfach aufs Handy.</p>
    <a href={WA_URL} target="_blank" rel="noopener" class="astro-wahero__btn">
      <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
      Kanal abonnieren
    </a>
  </div>
</section>

<style is:global>
.astro-wahero{position:relative;width:100vw;left:50%;margin-left:-50vw;margin-right:-50vw;min-height:480px;display:flex;align-items:flex-end;overflow:hidden;background:linear-gradient(135deg,#0a4e44 0%,#128C7E 50%,#1ba88f 100%)}
.astro-wahero__bg{position:absolute;inset:0;opacity:.08;background-image:url("data:image/svg+xml,%3Csvg width='160' height='160' viewBox='0 0 160 160' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' stroke='%23ffffff' stroke-width='1.2'%3E%3Cpath d='M30 35c0-7 6-13 13-13h28c7 0 13 6 13 13v18c0 7-6 13-13 13H55l-9 9v-9h-3c-7 0-13-6-13-13z'/%3E%3Cpath d='M82 100c0-7 6-13 13-13h28c7 0 13 6 13 13v18c0 7-6 13-13 13h-3v9l-9-9H95c-7 0-13-6-13-13z'/%3E%3C/g%3E%3C/svg%3E");background-size:160px 160px}
.astro-wahero__bg::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(7,60,55,.05) 0%,rgba(7,60,55,.5) 100%)}
.astro-wahero__inner{position:relative;max-width:1100px;margin:0 auto;width:100%;padding:100px 40px 64px;color:#fff}
.astro-wahero__eyebrow{display:block;font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:rgba(255,255,255,.75);margin-bottom:14px}
.astro-wahero__title{font-family:'Playfair Display',Georgia,serif;font-size:clamp(36px,5vw,60px);font-weight:700;color:#fff;margin:0 0 16px;line-height:1.05}
.astro-wahero__sub{font-size:clamp(16px,1.8vw,19px);color:rgba(255,255,255,.88);line-height:1.6;margin:0 0 32px;max-width:600px}
.astro-wahero__btn{display:inline-flex;align-items:center;gap:10px;padding:14px 28px;background:#25D366;color:#fff;font-size:15px;font-weight:700;text-decoration:none;border-radius:50px;transition:background .18s,transform .18s;box-shadow:0 4px 20px rgba(0,0,0,.25)}
.astro-wahero__btn:hover{background:#1fb859;transform:translateY(-2px)}
@media(max-width:600px){.astro-wahero__inner{padding:80px 20px 48px}}
</style>
