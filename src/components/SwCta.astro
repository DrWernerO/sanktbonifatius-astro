---
// Abschluss-CTA St. Wendel (WP-Block `stb2-cta`). Eigene Klassen `astro-swcta`.
---
<section class="astro-swcta">
  <div class="astro-swcta__in">
    <h2 class="astro-swcta__h2">Kommen Sie vorbei!</h2>
    <p class="astro-swcta__p">St. Wendel &middot; Altes Sch&uuml;tzenh&uuml;tteng&auml;sschen 2&ndash;6 &middot; 60599 Frankfurt am Main</p>
    <a class="astro-swcta__btn" href="/kontakt/">Kontakt aufnehmen</a>
  </div>
</section>

<style is:global>
.astro-swcta{background:linear-gradient(135deg,#011d52 0%,#012C7B 100%);width:100vw;position:relative;left:50%;margin-left:-50vw;margin-right:-50vw;padding:72px 0;text-align:center}
.astro-swcta__in{max-width:760px;margin:0 auto;padding:0 32px}
.astro-swcta__h2{font-family:'Playfair Display',Georgia,serif;font-size:clamp(28px,4vw,44px);color:#fff;margin:0 0 16px;line-height:1.15}
.astro-swcta__p{color:rgba(255,255,255,.82);font-size:17px;margin:0 0 32px;line-height:1.5}
.astro-swcta__btn{display:inline-block;background:#fff;color:#012C7B;font-weight:700;font-size:15px;padding:14px 32px;border-radius:999px;text-decoration:none;transition:all .2s}
.astro-swcta__btn:hover{background:#f0ebe0}
@media(max-width:600px){.astro-swcta__in{padding:0 16px}}
</style>
