---
// „Unsere Specials" der Seite „Ministranten St. Bonifatius" (WP-Block `mn-specials`).
// Eigene Klassen `astro-mnspec`. 4 Karten (Icon + Titel), Icons als SVG (kein Emoji, Handbuch 8.7).
const specials = [
  {
    title: 'Weihrauch-Tastings',
    // dampfende Schale / Weihrauch-Duft
    icon: '<path d="M8 20h16M10 20c0-3 4-3 4-6m4 6c0-2-3-2-3-5"/><path d="M14 11c0-2 2-2 2-4s-2-2-2-4"/><path d="M19 11c0-1.5 1.5-1.5 1.5-3"/>',
  },
  {
    title: 'Räuchersessions',
    // Flamme
    icon: '<path d="M24 6c4 6 8 8 8 14a8 8 0 0 1-16 0c0-4 3-6 4-9 1 2 2 3 4 4 0-5 0-7 0-9z"/>',
  },
  {
    title: 'Weihwasserbüsche mit „Auswurf“',
    // Wassertropfen
    icon: '<path d="M24 6c5 7 9 11 9 17a9 9 0 0 1-18 0c0-6 4-10 9-17z"/><path d="M19 24a5 5 0 0 0 5 5"/>',
  },
  {
    title: 'Freizeitprogramm & Ausbildung',
    // Zelt / Lagerfeuer-Gemeinschaft
    icon: '<path d="M24 8 8 34h32L24 8z"/><path d="M24 18v16M16 34l8-10 8 10"/>',
  },
];
---
<section class="astro-mnspec">
  <div class="astro-mnspec__in">
    <div class="astro-mnspec__head">
      <h2>Unsere Specials</h2>
      <p>Das macht den Dienst bei uns besonders.</p>
    </div>
    <div class="astro-mnspec__grid">
      {specials.map((s) => (
        <div class="astro-mnspec__card">
          <div class="astro-mnspec__icon" aria-hidden="true">
            <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={s.icon}></svg>
          </div>
          <h3 class="astro-mnspec__title" set:html={s.title}></h3>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
.astro-mnspec{background:#f7f3ef;padding:64px 24px}
.astro-mnspec__in{max-width:1100px;margin:0 auto}
.astro-mnspec__head{text-align:center;margin-bottom:40px}
.astro-mnspec__head h2{font-family:'Playfair Display',Georgia,serif;font-size:clamp(26px,4vw,38px);color:#2c2420;margin:0 0 10px;font-weight:700}
.astro-mnspec__head p{font-size:15.5px;color:#6b5c52;margin:0}
.astro-mnspec__grid{display:grid;grid-template-columns:repeat(4,1fr);gap:22px}
.astro-mnspec__card{background:#fff;border-radius:16px;padding:30px 22px;text-align:center;box-shadow:0 2px 10px rgba(44,36,32,.06);transition:transform .2s,box-shadow .2s}
.astro-mnspec__card:hover{transform:translateY(-4px);box-shadow:0 10px 26px rgba(44,36,32,.12)}
.astro-mnspec__icon{width:60px;height:60px;margin:0 auto 16px;border-radius:50%;background:#f7ece9;color:#9a2d2d;display:flex;align-items:center;justify-content:center}
.astro-mnspec__icon svg{width:30px;height:30px}
.astro-mnspec__title{font-family:'Playfair Display',Georgia,serif;font-size:17.5px;color:#2c2420;margin:0;line-height:1.3;font-weight:700}
@media(max-width:860px){.astro-mnspec__grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:480px){.astro-mnspec{padding:48px 18px}.astro-mnspec__grid{grid-template-columns:1fr}}
</style>
