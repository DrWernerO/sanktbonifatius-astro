<style is:global>
.astro-ap-team {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 28px;
  margin-top: 48px;
}
.astro-ap-person {
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: var(--ap-shd);
  display: flex;
  flex-direction: column;
  padding-bottom: 24px;
}
.astro-ap-person__photo {
  width: 100%;
  aspect-ratio: 1/1;
  background-size: cover;
  background-position: center top;
}
.astro-ap-person h3 {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: 18px;
  color: var(--ap-ink);
  margin: 18px 20px 4px;
  line-height: 1.2;
}
.astro-ap-person__role {
  font-size: 13px;
  color: var(--ap-g);
  font-weight: 600;
  letter-spacing: .04em;
  text-transform: uppercase;
  margin: 0 20px 12px;
}
.astro-ap-person a {
  display: block;
  font-size: 14px;
  color: var(--ap-mute);
  text-decoration: none;
  padding: 3px 20px;
  transition: color .2s;
}
.astro-ap-person a:hover { color: var(--ap-g); }
@media (max-width: 860px) {
  .astro-ap-team { grid-template-columns: 1fr; }
}
</style>
