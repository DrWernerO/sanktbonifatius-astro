<style is:global>
.astro-ap-team{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:32px}
.astro-ap-person{background:#fff;border-radius:12px;padding:32px 24px;text-align:center;box-shadow:var(--ap-shd)}
.astro-ap-person__photo{width:120px;height:120px;border-radius:50%;background-size:cover;background-position:center top;margin:0 auto 20px;box-shadow:0 4px 14px rgba(0,0,0,.15);border:4px solid #fff}
.astro-ap-person h3{font-family:'Playfair Display',Georgia,serif;font-size:21px;color:var(--ap-g);margin:0 0 4px;font-weight:700}
.astro-ap-person__role{color:var(--ap-mute);font-size:13px;margin:0 0 18px;letter-spacing:.08em;text-transform:uppercase}
.astro-ap-person a{color:var(--ap-ink);text-decoration:none;display:block;font-size:15px;margin:4px 0;transition:color .2s;word-break:break-word}
.astro-ap-person a:hover{color:var(--ap-g)}
@media(max-width:640px){.astro-ap-team{grid-template-columns:1fr}}
</style>
