---
// „Drei Wege" — Kindertaufe / Erwachsenentaufe / Aufnahme & Wiederaufnahme (WP-Block `kw-kacheln`).
// Eigene Klassen `astro-kw-wege` (WP-Klassen `kw-kachel` tabu). Feste Inhalte (1:1 aus WP-Seite 48544).
// Interne Links auf saubere Astro-Pfade: Kindertaufe → bereits gebaute Taufe-Seite; die übrigen
// auf /kontakt/ (Handbuch 12: tote Links portfolioweit erst vor Go-Live final prüfen).
const wege = [
  {
    tag: 'F&uuml;r Familien',
    // Tropfen/Taufe-Icon
    icon: '<path d="M12 2.7s6 6.6 6 11a6 6 0 0 1-12 0c0-4.4 6-11 6-11z"/>',
    title: 'Kindertaufe',
    text: 'Wenn Ihr Kind getauft werden soll, begleiten wir Sie und Ihre Familie vom ersten Gespr&auml;ch bis zur Feier der Taufe. Auf unserer Seite zur Kindertaufe finden Sie alle Informationen zu Ablauf, Voraussetzungen und Terminen in unseren Kirchen.',
    href: '/segen-sakramente/taufe/',
    linkText: 'Zur Kindertaufe-Seite &#8594;',
  },
  {
    tag: 'F&uuml;r Erwachsene',
    // Personen-Icon
    icon: '<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>',
    title: 'Erwachsenentaufe',
    text: 'Wenn Sie als Erwachsener getauft werden m&ouml;chten, gibt es verschiedene M&ouml;glichkeiten der Vorbereitung. Sie k&ouml;nnen an einem der sehr beliebten Taufvorbereitungskurse der Kath. Stadtkirche Frankfurt teilnehmen, oder wir besprechen mit Ihnen einen individuellen Weg der Taufvorbereitung, der f&uuml;r Sie gut passt.',
    href: '/kontakt/',
    linkText: 'Kontakt aufnehmen &#8594;',
  },
  {
    tag: 'Aufnahme &amp; Wiederaufnahme',
    // Tür/Eingang-Icon
    icon: '<path d="M3 21h18"/><path d="M6 21V4a1 1 0 0 1 1-1h7a1 1 0 0 1 1 1v17"/><path d="M11 12h.01"/>',
    title: 'F&uuml;r bereits Getaufte',
    text: 'Sie sind christlich getauft &#8212; evangelisch, orthodox oder in einer anderen Gemeinschaft &#8212; und m&ouml;chten zur katholischen Kirche wechseln? Oder Sie sind fr&uuml;her ausgetreten und m&ouml;chten zur&uuml;ckfinden? Das Vorgehen ist in beiden F&auml;llen &auml;hnlich: ein pers&ouml;nliches Gespr&auml;ch, eine kurze Vorbereitungszeit und die feierliche Aufnahme in unsere Pfarrei. Eine neue Taufe ist nicht n&ouml;tig.',
    href: '/kontakt/',
    linkText: 'Kontakt aufnehmen &#8594;',
  },
];
---
<section class="astro-kw-wege">
  <div class="astro-kw-wege__inner">
    <div class="astro-kw-wege__grid">
      {wege.map((w) => (
        <article class="astro-kw-wege__card">
          <div class="astro-kw-wege__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={w.icon} />
          </div>
          <span class="astro-kw-wege__tag" set:html={w.tag} />
          <h3 class="astro-kw-wege__title" set:html={w.title} />
          <p class="astro-kw-wege__text" set:html={w.text} />
          <a class="astro-kw-wege__link" href={w.href} set:html={w.linkText} />
        </article>
      ))}
    </div>
  </div>
</section>

<style is:global>
.astro-kw-wege{background:#f7f3ef;padding:80px 0}
.astro-kw-wege__inner{max-width:1200px;margin:0 auto;padding:0 40px}
.astro-kw-wege__grid{display:grid;grid-template-columns:repeat(3,1fr);gap:28px}
.astro-kw-wege__card{background:#fff;border-radius:16px;padding:36px 32px;display:flex;flex-direction:column;box-shadow:0 4px 20px rgba(30,21,18,.06);border:1px solid #e8e0d8}
.astro-kw-wege__icon{width:52px;height:52px;background:rgba(154,45,45,.08);border-radius:50%;display:flex;align-items:center;justify-content:center;margin-bottom:20px;flex-shrink:0}
.astro-kw-wege__icon svg{width:26px;height:26px;stroke:#9a2d2d}
.astro-kw-wege__tag{font-size:11px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:#9a2d2d;background:rgba(154,45,45,.08);border-radius:20px;padding:4px 12px;margin-bottom:16px;display:inline-block;align-self:flex-start}
.astro-kw-wege__title{font-family:'Playfair Display',Georgia,serif;font-weight:700;font-size:22px;color:#1e1512;margin:0 0 14px}
.astro-kw-wege__text{font-size:15px;line-height:1.7;color:#3a2e28;margin:0 0 22px}
.astro-kw-wege__link{margin-top:auto;align-self:flex-start;font-size:15px;font-weight:700;color:#9a2d2d;text-decoration:none;transition:color .2s}
.astro-kw-wege__link:hover{color:#7e2424}
@media(max-width:900px){.astro-kw-wege__grid{grid-template-columns:1fr;max-width:560px;margin:0 auto}}
@media(max-width:600px){.astro-kw-wege{padding:56px 0}.astro-kw-wege__inner{padding:0 20px}.astro-kw-wege__card{padding:30px 24px}}
</style>
