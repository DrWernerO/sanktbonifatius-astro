---
// Vorteils-Streifen direkt unter dem Hero (WP-Block `ta-strip`). Eigene Klassen `astro-tastrip`.
// SVG-Icons statt Emoji (Handbuch Lektion 7). Feste Inhalte.
const items = [
  { title: 'Kostenlos', text: 'Keine Gebühren &#8211; freiwillige Spende willkommen',
    icon: '<path d="M12 1v22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>' },
  { title: 'Monatliche Termine', text: 'In drei Kirchen, jeweils sonntags um 11 Uhr',
    icon: '<rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>' },
  { title: 'Offen für alle', text: 'Familien aus ganz Frankfurt sind herzlich willkommen',
    icon: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>' },
];
---
<section class="astro-tastrip">
  <div class="astro-tastrip__grid">
    {items.map((it) => (
      <div class="astro-tastrip__item">
        <svg class="astro-tastrip__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={it.icon} />
        <div>
          <p class="astro-tastrip__title">{it.title}</p>
          <p class="astro-tastrip__text" set:html={it.text} />
        </div>
      </div>
    ))}
  </div>
</section>

<style is:global>
.astro-tastrip{background:#9a2d2d}
.astro-tastrip__grid{max-width:1200px;margin:0 auto;padding:22px 40px;display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.astro-tastrip__item{display:flex;align-items:center;gap:14px;color:#fff}
.astro-tastrip__icon{width:30px;height:30px;color:#f0d9a0;flex-shrink:0}
.astro-tastrip__title{font-weight:700;font-size:16px;margin:0;color:#fff}
.astro-tastrip__text{font-size:13.5px;margin:2px 0 0;color:#f2d9d9;line-height:1.45}
@media(max-width:760px){.astro-tastrip__grid{grid-template-columns:1fr;gap:14px;padding:20px}}
</style>
