---
// Hero Gruppen & Gemeinschaft Herz Jesu — klon nach WP-Design (gd-hero-Muster).
// Eigene Klassen astro-hjghero; full-bleed, Bild + dunkler Gradient, Inhalt unten links.
---
<section class="astro-hjghero">
  <div class="astro-hjghero__bg"></div>
  <div class="astro-hjghero__inner">
    <div class="astro-hjghero__eyebrow">Herz Jesu &middot; Frankfurt-Oberrad</div>
    <h1 id="unsere-gruppen">Unsere Gruppen</h1>
    <p class="astro-hjghero__sub">Gemeinschaft erleben, Talente einbringen, neue Menschen kennenlernen &ndash; in Herz&nbsp;Jesu ist f&uuml;r jede Lebensphase etwas dabei.</p>
    <div class="astro-hjghero__btns">
      <a href="#gruppen" class="astro-hjghero__btn astro-hjghero__btn--prim">Alle Gruppen entdecken</a>
      <a href="/kirchorte/herz-jesu/" class="astro-hjghero__btn astro-hjghero__btn--out">&larr; Zur&uuml;ck zu Herz&nbsp;Jesu</a>
    </div>
  </div>
</section>

<style is:global>
.astro-hjghero{position:relative;min-height:560px;display:flex;align-items:flex-end;padding:96px 48px 72px;overflow:hidden;color:#fff;width:100vw;margin-left:calc(50% - 50vw);margin-right:calc(50% - 50vw);box-sizing:border-box}
.astro-hjghero__bg{position:absolute;inset:0;background-image:url('/uploads/2022/04/kirche-herz-jesu-frankfurt2.jpg');background-size:cover;background-position:center 20%;z-index:0}
.astro-hjghero__bg::after{content:'';position:absolute;inset:0;background:linear-gradient(180deg,rgba(30,21,18,.25) 0%,rgba(30,21,18,.45) 50%,rgba(30,21,18,.85) 100%)}
.astro-hjghero__inner{position:relative;z-index:1;max-width:1200px;width:100%;margin:0 auto}
.astro-hjghero__eyebrow{font-family:'Playfair Display',Georgia,serif;font-style:italic;font-size:14px;letter-spacing:.14em;color:#f0a0a0;text-transform:uppercase;margin-bottom:18px;font-weight:700;display:block}
.astro-hjghero h1{font-family:'Playfair Display',Georgia,serif;font-size:clamp(40px,6vw,68px);font-weight:700;letter-spacing:-.02em;color:#fff;margin:0 0 18px;line-height:1.05}
.astro-hjghero__sub{font-size:18.5px;line-height:1.55;max-width:540px;color:rgba(255,255,255,.88);margin:0 0 28px}
.astro-hjghero__btns{display:flex;gap:12px;flex-wrap:wrap}
.astro-hjghero__btn{display:inline-flex;align-items:center;gap:8px;padding:14px 26px;border-radius:28px;font-size:15.5px;font-weight:600;text-decoration:none;transition:all .2s;border:2px solid transparent}
.astro-hjghero__btn--prim{background:#910003;color:#fff;border-color:#910003}
.astro-hjghero__btn--prim:hover{background:#6e0002;border-color:#6e0002}
.astro-hjghero__btn--out{background:transparent;color:#fff;border:2px solid rgba(255,255,255,.8)}
.astro-hjghero__btn--out:hover{background:#fff;color:#2c2420;border-color:#fff}
@media(max-width:600px){.astro-hjghero{padding:72px 24px 48px;min-height:480px}}
</style>
