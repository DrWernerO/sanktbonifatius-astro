---
// Notfall-Banner „Telefonseelsorge" — WP-Seite 48312. Eigene Klassen `astro-ber-notfall`.
// Krisen-Rufnummern 1:1 aus WP übernommen (kostenlos, anonym, rund um die Uhr) — diese
// Nummern dürfen NICHT verfälscht werden. SVG-Icon statt Emoji (Handbuch Lektion 7).
const NUMS = [
  { tel: '08001110111', label: '0800 111 0 111', note: 'kostenlos · evangelisch' },
  { tel: '08001110222', label: '0800 111 0 222', note: 'kostenlos · katholisch' },
];
---
<section class="astro-ber-notfall" id="astro-ber-notfall">
  <div class="astro-ber-notfall__inner">
    <svg class="astro-ber-notfall__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.22h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.82a16 16 0 0 0 6.17 6.17l1.17-1.17a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
    <div class="astro-ber-notfall__body">
      <p class="astro-ber-notfall__title">Telefonseelsorge &#8212; rund um die Uhr erreichbar</p>
      <p class="astro-ber-notfall__desc">Kostenlos, anonym, vertraulich &#8212; 24 Stunden täglich, 365 Tage im Jahr</p>
    </div>
    <div class="astro-ber-notfall__nums">
      {NUMS.map((n) => (
        <div class="astro-ber-notfall__num">
          <a href={`tel:${n.tel}`}>{n.label}</a>
          <p class="astro-ber-notfall__note">{n.note}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
.astro-ber-notfall{width:100vw;position:relative;left:50%;margin-left:-50vw;margin-right:-50vw;background:#9a2d2d;padding:34px 24px}
.astro-ber-notfall__inner{max-width:1040px;margin:0 auto;display:flex;align-items:center;gap:26px;flex-wrap:wrap}
.astro-ber-notfall__icon{width:38px;height:38px;color:#fff;flex-shrink:0}
.astro-ber-notfall__body{flex:1;min-width:220px}
.astro-ber-notfall__title{font-family:'Playfair Display',serif;font-size:20px;font-weight:700;color:#fff;margin:0 0 4px}
.astro-ber-notfall__desc{font-size:14px;color:rgba(255,255,255,.82);margin:0;line-height:1.5}
.astro-ber-notfall__nums{display:flex;gap:12px;flex-wrap:wrap;align-items:flex-start}
.astro-ber-notfall__num a{font-size:19px;font-weight:700;color:#fff;text-decoration:none;background:rgba(0,0,0,.22);padding:9px 20px;border-radius:8px;display:inline-block;transition:background .18s;white-space:nowrap}
.astro-ber-notfall__num a:hover{background:rgba(0,0,0,.38)}
.astro-ber-notfall__note{font-size:12px;color:rgba(255,255,255,.7);margin:5px 0 0;text-align:center}
@media(max-width:560px){.astro-ber-notfall__inner{gap:18px}.astro-ber-notfall__nums{width:100%}}
</style>
