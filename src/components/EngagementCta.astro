---
// Abschluss-CTA „Neugierig geworden?" der Seite „Engagement" (WP-Block `eng-cta`).
// Eigene Klassen `astro-eng-cta`. Feste Inhalte (1:1 aus WP übernommen).
// WP verlinkte auf /kontakt (Astro-Pfad /kontakt/).
---
<section class="astro-eng-cta">
  <div class="astro-eng-cta__inner">
    <p class="astro-eng-cta__eyebrow">Mach den ersten Schritt</p>
    <h2 class="astro-eng-cta__hl">Neugierig geworden?</h2>
    <p class="astro-eng-cta__sub">
      Wir freuen uns auf deine Nachricht. Sag einfach, was dich interessiert &#8211; und wir
      melden uns pers&ouml;nlich bei dir.
    </p>
    <div class="astro-eng-cta__btns">
      <a class="astro-eng-cta__btn" href="/kontakt/">Ich habe Interesse &#8594;</a>
    </div>
  </div>
</section>

<style is:global>
.astro-eng-cta{position:relative;width:100vw;left:50%;margin-left:-50vw;margin-right:-50vw;background:linear-gradient(135deg,#9a2d2d 0%,#7e2424 100%);color:#fff;padding:76px 0;overflow:hidden}
.astro-eng-cta::after{content:"";position:absolute;inset:0;background:radial-gradient(circle at 20% 10%,rgba(255,255,255,.10),transparent 55%)}
.astro-eng-cta__inner{position:relative;z-index:1;max-width:760px;margin:0 auto;padding:0 40px;text-align:center}
.astro-eng-cta__eyebrow{font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:#f0d9a0;margin:0 0 14px;font-weight:600}
.astro-eng-cta__hl{font-family:'Playfair Display',serif;font-size:clamp(28px,3.5vw,44px);font-weight:700;color:#fff;margin:0 0 14px}
.astro-eng-cta__sub{font-size:clamp(15px,1.8vw,19px);color:#f2dede;line-height:1.6;margin:0 0 32px}
.astro-eng-cta__btns{display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:16px}
.astro-eng-cta__btn{display:inline-flex;align-items:center;gap:10px;padding:15px 32px;border-radius:50px;font-size:16px;font-weight:700;text-decoration:none;background:#fff;color:#9a2d2d;transition:background .2s,color .2s}
.astro-eng-cta__btn:hover{background:#f3e7d4;color:#7e2424}
@media(max-width:600px){.astro-eng-cta{padding:56px 0}.astro-eng-cta__inner{padding:0 20px}}
</style>
