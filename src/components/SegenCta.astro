---
// Abschluss-CTA „Fragen? Wir sind für Sie da." (WP-Block `ss-cta`). Eigene Klassen `astro-sscta`.
// Zwei Buttons: Kontakt + Gottesdienst & Glaube. Feste Inhalte.
---
<section class="astro-sscta">
  <div class="astro-sscta__inner">
    <p class="astro-sscta__eyebrow">Pers&ouml;nliche Begleitung</p>
    <h2 class="astro-sscta__hl">Fragen? Wir sind f&uuml;r Sie da.</h2>
    <p class="astro-sscta__sub">
      Sprechen Sie uns an &#8212; ob es um Ihre erste Orientierung, eine Anmeldung oder
      seelsorgerliche Begleitung geht.
    </p>
    <div class="astro-sscta__btns">
      <a class="astro-sscta__btn astro-sscta__btn--primary" href="/kontakt/">Kontakt aufnehmen</a>
      <a class="astro-sscta__btn astro-sscta__btn--ghost" href="/gottesdienst-glaube/">Gottesdienst &amp; Glaube</a>
    </div>
  </div>
</section>

<style is:global>
.astro-sscta{position:relative;width:100vw;left:50%;margin-left:-50vw;margin-right:-50vw;background:linear-gradient(135deg,#9a2d2d 0%,#7e2424 100%);color:#fff;padding:76px 0;overflow:hidden}
.astro-sscta::after{content:"";position:absolute;inset:0;background:radial-gradient(circle at 20% 10%,rgba(255,255,255,.10),transparent 55%)}
.astro-sscta__inner{position:relative;z-index:1;max-width:760px;margin:0 auto;padding:0 40px;text-align:center}
.astro-sscta__eyebrow{font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:#f0d9a0;margin:0 0 14px;font-weight:600}
.astro-sscta__hl{font-family:'Playfair Display',serif;font-size:clamp(26px,3.4vw,40px);font-weight:700;color:#fff;margin:0 0 14px}
.astro-sscta__sub{font-size:clamp(15px,1.8vw,19px);color:#f2dede;line-height:1.6;margin:0 0 32px}
.astro-sscta__btns{display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:16px}
.astro-sscta__btn{display:inline-flex;align-items:center;gap:10px;padding:14px 28px;border-radius:50px;font-size:15px;font-weight:600;text-decoration:none;transition:background .2s,border-color .2s,color .2s}
.astro-sscta__btn--primary{background:#fff;color:#9a2d2d}
.astro-sscta__btn--primary:hover{background:#f3e7d4}
.astro-sscta__btn--ghost{border:1.5px solid rgba(255,255,255,.6);color:#fff}
.astro-sscta__btn--ghost:hover{border-color:#fff;background:rgba(255,255,255,.1)}
@media(max-width:600px){.astro-sscta{padding:56px 0}.astro-sscta__inner{padding:0 20px}}
</style>
