---
// Dunkler Info-Streifen direkt unter dem Hero (WP-Block `eng-strip`). Eigene Klassen `astro-eng-strip`.
// SVG-Icons statt Emoji (Handbuch Lektion 7). Feste Inhalte (1:1 aus WP übernommen).
const items = [
  { text: '6 Bereiche zum Mitmachen',
    icon: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>' },
  { text: 'Flexibel &#8211; auch mit wenig Zeit',
    icon: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>' },
  { text: 'Kein Vorwissen n&ouml;tig',
    icon: '<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>' },
];
---
<section class="astro-eng-strip">
  <div class="astro-eng-strip__inner">
    {items.map((it) => (
      <div class="astro-eng-strip__item">
        <svg class="astro-eng-strip__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={it.icon} />
        <span set:html={it.text} />
      </div>
    ))}
  </div>
</section>

<style is:global>
.astro-eng-strip{background:#1e1512;width:100vw;left:50%;margin-left:-50vw;margin-right:-50vw;position:relative}
.astro-eng-strip__inner{max-width:1200px;margin:0 auto;display:flex;justify-content:center;flex-wrap:wrap}
.astro-eng-strip__item{display:flex;align-items:center;gap:11px;padding:18px 34px;color:#f0e8d8;font-size:13px;font-weight:600;text-transform:uppercase;letter-spacing:.08em;border-right:1px solid rgba(255,255,255,.1)}
.astro-eng-strip__item:last-child{border-right:none}
.astro-eng-strip__icon{width:20px;height:20px;flex-shrink:0;color:#c5a55a}
@media(max-width:760px){.astro-eng-strip__inner{flex-direction:column;align-items:stretch}.astro-eng-strip__item{border-right:none;border-bottom:1px solid rgba(255,255,255,.1);padding:14px 24px;justify-content:center;text-align:center}.astro-eng-strip__item:last-child{border-bottom:none}}
</style>
