---
// Quicklink-Leiste + Intro-Sektion (ersetzt WP-Block `boni-ql2` inkl. anschließendem
// "Mitten in Frankfurt"-Intro). Feste Inhalte. SVG-Icons (kein Emoji, UI-Regel).
const links = [
  { href: '/gottesdienst-glaube/gottesdienstordnung/', label: 'Gottesdienste',
    icon: '<path d="M10 9V7m4 2V7m-2-5v3m-6 17v-8l6-4 6 4v8M4 21h16M9 21v-4h6v4"/>' },
  { href: '/segen-sakramente/taufe/', label: 'Taufe',
    icon: '<path d="M12 3s-6 7-6 12a6 6 0 0 0 12 0c0-5-6-12-6-12z"/>' },
  { href: '/segen-sakramente/trauung/', label: 'Trauung',
    icon: '<circle cx="9" cy="14" r="6"/><circle cx="15" cy="10" r="6"/>' },
  { href: '/kontakt/trauerfall/', label: 'Trauerfall',
    icon: '<path d="M12 2v20M6 7h12"/>' },
  { href: '/kitas/', label: 'Kitas',
    icon: '<path d="M9 12h.01"/><path d="M15 12h.01"/><path d="M10 16c.5.3 1.2.5 2 .5s1.5-.2 2-.5"/><path d="M19 6.3a9 9 0 0 1 1.8 3.9 2 2 0 0 1 0 3.6 9 9 0 0 1-17.6 0 2 2 0 0 1 0-3.6A9 9 0 0 1 12 3c2 0 3.5 1.1 3.5 2.5s-1 1.5-2 1.5"/>' },
  { href: '/kontakt/', label: 'Kontakt',
    icon: '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>' },
];
---
<div class="astro-ql">
  <div class="astro-ql__inner">
    <span class="astro-ql__label">Was bringt Sie zu uns?</span>
    <nav class="astro-ql__nav">
      {links.map((l) => (
        <a href={l.href}>
          {l.icon && (
            <svg class="astro-ql__icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={l.icon} />
          )}
          <span>{l.label}</span>
        </a>
      ))}
    </nav>
  </div>
</div>

<section class="astro-ql-intro">
  <h2 class="astro-ql-intro__hl">Mitten in Frankfurt.<br />Mitten im Leben. Mitten im Glauben.</h2>
  <p class="astro-ql-intro__txt">Modern, lebendig, offen — eine Pfarrei mitten in Sachsenhausen seit über 100 Jahren. Herzlich willkommen.</p>
</section>

<style is:global>
.astro-ql{background:#f7f3ef;border-top:1px solid #e0d8cf;border-bottom:1px solid #e0d8cf;width:100vw;position:relative;left:50%;margin-left:-50vw;margin-right:-50vw;padding:14px 0}
.astro-ql__inner{display:flex;flex-direction:row;align-items:center;gap:20px;max-width:1240px;margin:0 auto;padding:0 32px;flex-wrap:nowrap}
.astro-ql__label{white-space:nowrap;font-size:13px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:#5a4a3a;flex-shrink:0}
.astro-ql__nav{display:flex;flex-wrap:wrap;gap:8px;flex:1}
.astro-ql__nav a{display:inline-flex;align-items:center;gap:8px;padding:9px 18px;font-size:14px;font-weight:500;color:#5a4a3a;text-decoration:none;background:#fff;border-radius:24px;border:1px solid #e0d8cf;transition:all .2s;white-space:nowrap}
.astro-ql__nav a:hover{background:#ede6dd;border-color:#928269;color:#2c2420}
.astro-ql__icon{flex-shrink:0;opacity:.85}
.astro-ql-intro{padding:56px 32px 40px;background:#f5efe6;text-align:center;width:100vw;position:relative;left:50%;margin-left:-50vw;margin-right:-50vw}
.astro-ql-intro__hl{font-family:'Playfair Display',Georgia,serif;font-size:clamp(22px,3vw,32px);color:#2c2420;margin:0 0 14px;font-weight:700;line-height:1.3}
.astro-ql-intro__txt{color:#5a4a3a;font-size:16px;max-width:600px;margin:0 auto}
@media(max-width:760px){
  .astro-ql__inner{flex-direction:column;align-items:center;gap:12px}
  .astro-ql__nav{justify-content:center}
  .astro-ql__nav a{font-size:13px;padding:8px 16px}
}
</style>
