---
// Abschluss-CTA „Neugierig geworden?" der Kampagnen-Seite „Ich bleibe!" — WP-Seite 48677.
// Eigene Klassen `astro-ibcta`. Full-Bleed, warmer Braun-Verlauf (wie WP-Vorlage). Feste Inhalte.
---
<section class="astro-ibcta">
  <div class="astro-ibcta__inner">
    <h2 class="astro-ibcta__hl">Neugierig geworden?</h2>
    <p class="astro-ibcta__sub">
      Kommen Sie zu uns &#8211; wir freuen uns auf Sie in unserer Gemeinschaft. Erleben Sie
      Gottesdienste, die bewegen, und Menschen, die willkommen hei&szlig;en.
    </p>
    <a class="astro-ibcta__btn" href="/gottesdienst-glaube/">Unsere Gottesdienste entdecken</a>
  </div>
</section>

<style is:global>
.astro-ibcta{width:100vw;left:50%;margin-left:-50vw;margin-right:-50vw;position:relative;background:linear-gradient(135deg,#4a2e1a,#3a2315);padding:88px 24px;text-align:center}
.astro-ibcta__inner{max-width:620px;margin:0 auto}
.astro-ibcta__hl{font-family:'Playfair Display',Georgia,serif;font-size:clamp(30px,4vw,48px);font-weight:700;color:#f0e8d8;margin:0 0 18px}
.astro-ibcta__sub{font-size:17px;color:rgba(240,232,216,.82);max-width:560px;margin:0 auto 36px;line-height:1.65}
.astro-ibcta__btn{display:inline-flex;align-items:center;background:#9a2d2d;color:#fff;border-radius:50px;padding:14px 34px;font-size:15px;font-weight:600;text-decoration:none;border:2px solid transparent;transition:background .2s,border-color .2s,color .2s}
.astro-ibcta__btn:hover{background:transparent;border-color:rgba(240,232,216,.7);color:#f0e8d8}
@media(max-width:600px){.astro-ibcta{padding:56px 20px}}
</style>
