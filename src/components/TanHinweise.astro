---
// „Ein paar hilfreiche Hinweise" vor dem Anmeldeformular (WP-Seite 48011). Eigene Klassen
// `astro-tan-hinweis`. Feste Inhalte (1:1 aus WP): Patenamt / Trauung / Vollständigkeit.
const hinweise = [
  {
    // Personen-Icon (Paten)
    icon: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
    title: 'Patenamt',
    text: 'Mindestens ein Pate bzw. eine Patin muss katholisch getauft und aktives Kirchenmitglied sein. Der zweite Pate / die zweite Patin muss ebenfalls getauft sein &#8211; darf aber auch einer anderen christlichen Konfession angeh&ouml;ren.',
  },
  {
    // Ringe/Herz-Icon (Trauung)
    icon: '<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>',
    title: 'Trauung',
    text: 'F&uuml;r die Taufe Ihres Kindes ist eine kirchliche Trauung keine Voraussetzung.',
  },
  {
    // Häkchen-Icon (Vollständigkeit)
    icon: '<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>',
    title: 'Vollst&auml;ndigkeit',
    text: 'Wenn Sie nicht alle Felder ausf&uuml;llen k&ouml;nnen, macht das nichts. Das k&ouml;nnen Sie beim Gespr&auml;ch nachholen.',
  },
];
---
<section class="astro-tan-hinweis">
  <div class="astro-tan-hinweis__inner">
    <p class="astro-tan-hinweis__eyebrow">Willkommen</p>
    <h2 class="astro-tan-hinweis__hl">Ein paar hilfreiche Hinweise</h2>
    <p class="astro-tan-hinweis__lead">
      Bevor Sie beginnen &#8211; drei kurze Dinge, die Ihnen die Anmeldung erleichtern.
    </p>
    <div class="astro-tan-hinweis__grid">
      {hinweise.map((h) => (
        <article class="astro-tan-hinweis__card">
          <div class="astro-tan-hinweis__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={h.icon} />
          </div>
          <h3 class="astro-tan-hinweis__title" set:html={h.title} />
          <p class="astro-tan-hinweis__text" set:html={h.text} />
        </article>
      ))}
    </div>
  </div>
</section>

<style is:global>
.astro-tan-hinweis{background:#fff;padding:72px 0 40px}
.astro-tan-hinweis__inner{max-width:1100px;margin:0 auto;padding:0 40px}
.astro-tan-hinweis__eyebrow{font-family:'Playfair Display',serif;font-style:italic;font-size:15px;letter-spacing:.06em;text-transform:uppercase;color:#9a2d2d;margin:0 0 14px;text-align:center}
.astro-tan-hinweis__hl{font-family:'Playfair Display',serif;font-weight:700;font-size:clamp(26px,3.2vw,38px);color:#1e1512;margin:0 0 12px;text-align:center}
.astro-tan-hinweis__lead{font-size:17px;color:#3a2e28;line-height:1.6;margin:0 auto 40px;text-align:center;max-width:560px}
.astro-tan-hinweis__grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.astro-tan-hinweis__card{background:#f7f3ef;border:1px solid #e8e0d8;border-radius:14px;padding:28px 26px}
.astro-tan-hinweis__icon{width:48px;height:48px;background:rgba(154,45,45,.08);border-radius:50%;display:flex;align-items:center;justify-content:center;margin-bottom:18px}
.astro-tan-hinweis__icon svg{width:24px;height:24px;stroke:#9a2d2d}
.astro-tan-hinweis__title{font-family:'Playfair Display',serif;font-weight:700;font-size:19px;color:#1e1512;margin:0 0 10px}
.astro-tan-hinweis__text{font-size:14.5px;line-height:1.65;color:#3a2e28;margin:0}
@media(max-width:860px){.astro-tan-hinweis__grid{grid-template-columns:1fr;max-width:520px;margin:0 auto}}
@media(max-width:600px){.astro-tan-hinweis{padding:48px 0 24px}.astro-tan-hinweis__inner{padding:0 20px}}
</style>
