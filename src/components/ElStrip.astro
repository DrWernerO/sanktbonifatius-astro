---
// Schnellzugriff-Band der Übersichtsseite „Engagiert Leben" — Präfix `astro-elstrip`.
// Gestaltung wie die Quick-Leisten der Kirchort-Seiten (ApQuick/HjQuick/SwQuick): weiße
// Pill-Buttons mit Border + SVG-Icon in der Rubrik-Farbe (Violett), Hover füllt die Pille.
// Springt zu den Anker-Karten in ElTiles.astro (Handbuch Abschnitt 17).
const links = [
  { label: 'Hilfenetz', href: '#el-hilfenetz',
    icon: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>' },
  { label: 'Kleider Café', href: '#el-kleica',
    icon: '<path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>' },
  { label: 'Kühlschrank', href: '#el-kuehlschrank',
    icon: '<rect x="5" y="2" width="14" height="20" rx="2"/><line x1="5" y1="9" x2="19" y2="9"/><line x1="8" y1="5" x2="8" y2="6.5"/><line x1="8" y1="12" x2="8" y2="13.5"/>' },
  { label: 'Sozialberatung', href: '#el-beratung',
    icon: '<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8z"/>' },
];
---
<nav class="astro-elstrip" aria-label="Schnellzugriff Engagiert Leben">
  <div class="astro-elstrip__in">
    <span class="astro-elstrip__lab">Schnellzugriff:</span>
    <div class="astro-elstrip__row">
      {links.map(l => (
        <a href={l.href}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
               aria-hidden="true" set:html={l.icon} />
          {l.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<style is:global>
.astro-elstrip{background:#f7f3ef;padding:22px 0;width:100vw;position:relative;left:50%;margin-left:-50vw;margin-right:-50vw}
.astro-elstrip__in{max-width:1280px;margin:0 auto;padding:0 32px;display:flex;align-items:center;justify-content:center;flex-wrap:wrap;gap:14px}
.astro-elstrip__lab{font-weight:700;color:#1e1512;font-size:15px;margin-right:6px}
.astro-elstrip__row{display:flex;flex-wrap:wrap;gap:10px}
.astro-elstrip a{display:inline-flex;align-items:center;gap:8px;padding:8px 14px;border-radius:999px;background:#fff;color:#1e1512;text-decoration:none;font-size:14px;font-weight:700;border:1px solid rgba(0,0,0,.08);transition:all .2s}
.astro-elstrip a svg{flex-shrink:0;color:#7b2fbe}
.astro-elstrip a:hover{background:#7b2fbe;color:#fff;border-color:#7b2fbe}
.astro-elstrip a:hover svg{color:#fff}
@media(max-width:760px){.astro-elstrip__in{flex-direction:column;align-items:flex-start}}
@media(max-width:600px){.astro-elstrip__in{padding:0 16px}}
</style>
