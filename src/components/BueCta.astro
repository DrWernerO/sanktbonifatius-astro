---
// Abschluss-CTA der Unterseite „Büchereien" (Page 49151). Eigene Klassen `astro-buecta`.
// Dunkler Verlauf wie WP-Vorlage (bu-cta). Feste Inhalte.
---
<section class="astro-buecta">
  <div class="astro-buecta__inner">
    <h2 class="astro-buecta__hl">Lust auf einen Besuch?</h2>
    <p class="astro-buecta__sub">
      Kommen Sie einfach in einer unserer &Ouml;ffnungszeiten vorbei &#8211; die ehrenamtlichen Teams
      beraten Sie gerne und freuen sich auf Sie.
    </p>
    <a class="astro-buecta__btn" href="/kultur-begegnung/">Weitere Angebote in Kultur &amp; Begegnung</a>
  </div>
</section>

<style is:global>
.astro-buecta{width:100vw;position:relative;left:50%;margin-left:-50vw;margin-right:-50vw;background:linear-gradient(135deg,#4a2018,#3a1810);padding:64px 24px;text-align:center;color:#fff}
.astro-buecta__inner{max-width:580px;margin:0 auto}
.astro-buecta__hl{font-family:'Playfair Display',Georgia,serif;font-size:clamp(24px,3.5vw,32px);color:#fff;margin:0 0 12px;font-weight:700}
.astro-buecta__sub{color:rgba(255,255,255,.82);font-size:15px;margin:0 0 24px;line-height:1.65}
.astro-buecta__btn{display:inline-flex;align-items:center;padding:13px 26px;border-radius:28px;font-size:14.5px;font-weight:600;text-decoration:none;background:#e8c89a;color:#4a2018;transition:background .2s,transform .2s;min-height:44px}
.astro-buecta__btn:hover{background:#f0d9b4;transform:translateY(-2px)}
@media(max-width:600px){.astro-buecta{padding:52px 20px}}
</style>
