---
// Hero der Kirchortrat-Seite Herz Jesu (/kirchorte/herz-jesu/kirchortrat/).
// Eigene Klassen astro-hjkhero (goldene Regel, Handbuch Abschnitt 3).
// Bild lokal: Bonifatius_HerzJesu_s-5775 (bereits für HjCards-Karte verwendet).
const bg = '/uploads/2024/04/Bonifatius_HerzJesu_s-5775-1024x683.jpg';
---
<section class="astro-hjkhero">
  <div class="astro-hjkhero__bg" role="img"
       aria-label="Kirche Herz Jesu Frankfurt-Oberrad"
       style={`background-image:url('${bg}')`}></div>
  <div class="astro-hjkhero__overlay"></div>
  <div class="astro-hjkhero__inner">
    <a class="astro-hjkhero__back" href="/kirchorte/herz-jesu/">&#8592; Zur&uuml;ck zu Herz&nbsp;Jesu</a>
    <span class="astro-hjkhero__badge">Kirchort Herz Jesu &middot; Frankfurt-Oberrad</span>
    <h1 class="astro-hjkhero__title">Kirchortrat</h1>
    <p class="astro-hjkhero__sub">Ehrenamtlich f&uuml;r die Gemeinde</p>
  </div>
</section>

<style is:global>
.astro-hjkhero{position:relative;width:100vw;left:50%;margin-left:-50vw;margin-right:-50vw;height:min(58vh,480px);display:flex;align-items:flex-end;overflow:hidden}
.astro-hjkhero__bg{position:absolute;inset:0;background-size:cover;background-position:center 50%}
.astro-hjkhero__overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(30,21,18,.1) 0%,rgba(30,21,18,.6) 55%,rgba(30,21,18,.9) 100%)}
.astro-hjkhero__inner{position:relative;z-index:2;width:100%;max-width:1280px;margin:0 auto;padding:0 40px 56px;display:flex;flex-direction:column;align-items:flex-start}
.astro-hjkhero__back{color:rgba(255,255,255,.75);font-size:13px;text-decoration:none;margin-bottom:16px;transition:color .2s}
.astro-hjkhero__back:hover{color:#fff}
.astro-hjkhero__badge{display:inline-flex;align-items:center;background:rgba(255,255,255,.15);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,.3);border-radius:30px;padding:6px 16px;margin-bottom:20px;color:#fff;font-size:12px;font-weight:700;letter-spacing:.1em;text-transform:uppercase}
.astro-hjkhero__title{font-family:'Playfair Display',Georgia,serif;font-size:clamp(34px,5vw,68px);color:#fff;margin:0 0 14px;line-height:1.08;font-weight:700}
.astro-hjkhero__sub{color:rgba(255,255,255,.88);font-size:clamp(15px,2vw,20px);margin:0;max-width:580px;line-height:1.45}
@media(max-width:600px){.astro-hjkhero__inner{padding:0 16px 44px}}
</style>
