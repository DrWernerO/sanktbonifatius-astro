---
// „Nutzen Sie unseren heißen Draht" — Präfix `astro-wareason`.
const WA_URL = 'https://whatsapp.com/channel/0029VbC6BfmJ3juxrDFhJy16';
---
<section class="astro-wareason">
  <div class="astro-wareason__inner">
    <div class="astro-wareason__text">
      <h2 class="astro-wareason__title">Nutzen Sie unseren heißen Draht</h2>
      <p class="astro-wareason__body">Wir wissen, wie trubelig der Familienalltag sein kann. Deshalb möchten wir Ihnen mit diesem Kanal einen kurzen, unkomplizierten Weg bieten, um über alles Interessante bei BonFamily informiert zu bleiben und nichts Wichtiges mehr zu verpassen. Wir freuen uns auf Sie!</p>
      <a href={WA_URL} target="_blank" rel="noopener" class="astro-wareason__btn">
        <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
        Jetzt abonnieren
      </a>
    </div>
    <div class="astro-wareason__visual" aria-hidden="true">
      <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg" class="astro-wareason__logo">
        <circle cx="60" cy="60" r="58" fill="#25D366"/>
        <path d="M60 20C37.9 20 20 37.9 20 60c0 7.1 1.9 13.8 5.2 19.6L20 100l21-5.1A39.8 39.8 0 0 0 60 100c22.1 0 40-17.9 40-40S82.1 20 60 20zm19.8 54.7c-.8 2.3-4.8 4.4-6.6 4.6-1.7.2-3.8.3-6.2-.4-1.4-.4-3.2-1-5.5-2-9.7-4.2-16-13.9-16.5-14.5-.5-.7-4-5.3-4-10.2s2.5-7.2 3.4-8.2c.9-1 1.9-1.2 2.6-1.2.6 0 1.3 0 1.8.02.6.02 1.4-.2 2.2 1.7.8 1.9 2.8 6.8 3 7.3.2.4.4.9.08 1.5-.3.5-.5.9-.9 1.3-.4.4-.9.9-1.2 1.2-.4.4-.8.8-.4 1.6.4.8 1.9 3.1 4 5.1 2.8 2.5 5.1 3.3 5.8 3.6.8.4 1.2.3 1.7-.2.5-.5 2-2.3 2.5-3.1.5-.8 1.1-.7 1.9-.4.7.3 4.6 2.2 5.4 2.5.8.4 1.3.6 1.5 1 .2.3-.07 2.7-.8 5z" fill="white"/>
      </svg>
    </div>
  </div>
</section>

<style is:global>
.astro-wareason{padding:72px 0;background:#fff;width:100vw;position:relative;left:50%;margin-left:-50vw;margin-right:-50vw}
.astro-wareason__inner{max-width:1100px;margin:0 auto;padding:0 40px;display:grid;grid-template-columns:1fr auto;gap:60px;align-items:center}
.astro-wareason__title{font-family:'Playfair Display',Georgia,serif;font-size:clamp(26px,3.5vw,38px);font-weight:700;color:#2c2420;margin:0 0 18px}
.astro-wareason__body{font-size:17px;line-height:1.7;color:#5a4a3a;margin:0 0 28px;max-width:560px}
.astro-wareason__btn{display:inline-flex;align-items:center;gap:10px;padding:13px 26px;background:#25D366;color:#fff;font-size:15px;font-weight:700;text-decoration:none;border-radius:50px;transition:background .18s}
.astro-wareason__btn:hover{background:#1fb859}
.astro-wareason__logo{width:120px;height:120px;opacity:.15}
@media(max-width:760px){.astro-wareason__inner{grid-template-columns:1fr}.astro-wareason__visual{display:none}}
@media(max-width:600px){.astro-wareason__inner{padding:0 20px}.astro-wareason{padding:52px 0}}
</style>
