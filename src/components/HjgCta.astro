---
// Abschluss-CTA Gruppen & Gemeinschaft Herz Jesu — roter Gradient, WP-Design-Klon.
// Eigene Klassen astro-hjgcta.
---
<section class="astro-hjgcta">
  <div class="astro-hjgcta__inner">
    <div class="astro-hjgcta__head">
      <h2 id="interesse-einfach-vorbeikommen">Interesse? Einfach vorbeikommen.</h2>
      <p>Alle Gruppen freuen sich über neue Mitglieder. Ein erster Besuch ist immer unverbindlich.</p>
    </div>
    <div class="astro-hjgcta__btns">
      <a href="/kirchorte/herz-jesu/" class="astro-hjgcta__btn astro-hjgcta__btn--out">&larr; Zur&uuml;ck zu Herz&nbsp;Jesu</a>
      <a href="/kontakt/pfarrbuero/" class="astro-hjgcta__btn astro-hjgcta__btn--wht">Pfarrb&uuml;ro kontaktieren</a>
    </div>
    <div class="astro-hjgcta__address">
      <span>Herz Jesu &middot; Mathildestra&szlig;e 30 &middot; 60599 Frankfurt</span>
      <a href="tel:+4969695975850">069 695 97 58 50</a>
      <a href="mailto:d.kadavil@sanktbonifatius.de">d.kadavil@sanktbonifatius.de</a>
    </div>
  </div>
</section>

<style is:global>
.astro-hjgcta{background:linear-gradient(135deg,#910003 0%,#6e0002 100%);text-align:center;padding:56px 24px;width:100vw;margin-left:calc(50% - 50vw);margin-right:calc(50% - 50vw);box-sizing:border-box}
.astro-hjgcta__inner{max-width:1200px;margin:0 auto}
.astro-hjgcta__head{max-width:720px;margin:0 auto 24px}
.astro-hjgcta__head h2{font-family:'Playfair Display',Georgia,serif;font-size:clamp(26px,4vw,36px);font-weight:700;color:#fff;margin:0 0 12px;line-height:1.15}
.astro-hjgcta__head p{font-size:16px;color:rgba(255,255,255,.8);margin:0}
.astro-hjgcta__btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-bottom:24px}
.astro-hjgcta__btn{display:inline-flex;align-items:center;gap:8px;padding:14px 26px;border-radius:28px;font-size:15.5px;font-weight:600;text-decoration:none;transition:all .2s;border:2px solid transparent}
.astro-hjgcta__btn--out{background:transparent;color:#fff;border:2px solid rgba(255,255,255,.8)}
.astro-hjgcta__btn--out:hover{background:#fff;color:#2c2420;border-color:#fff}
.astro-hjgcta__btn--wht{background:#fff;color:#910003;border-color:#fff}
.astro-hjgcta__btn--wht:hover{background:rgba(255,255,255,.9)}
.astro-hjgcta__address{font-size:14.5px;color:rgba(255,255,255,.7);display:flex;gap:24px;justify-content:center;flex-wrap:wrap;align-items:center}
.astro-hjgcta__address a{color:#f0c0c0;text-decoration:none;font-weight:600}
.astro-hjgcta__address a:hover{color:#fff}
@media(max-width:600px){.astro-hjgcta{padding:40px 20px}.astro-hjgcta__address{flex-direction:column;gap:8px}}
</style>
