---
// „Das Team" — 11 Team-Karten (Foto, Name, Rolle, ggf. Kirchort, E-Mail) + PDF-Download.
// Eigene Klassen `astro-ptteam`. Fotos lokal in public/uploads/ (Handbuch 1b). mailto im
// Klartext (wartbar, Handbuch 11). aria-label auf Foto (Inventar 48534, Screenreader).
const IMG = '/uploads';
const TEAM = [
  { name: 'Pfr. Dr. Werner Otto', role: 'Pfarrer', photo: `${IMG}/2023/07/Bonifatius_Pastoralteam_Werner-edited-1.jpg`, mail: 'w.otto@sanktbonifatius.de' },
  { name: 'Pfr. Uwe Michler', role: 'Priesterlicher Mitarbeiter', photo: `${IMG}/2023/05/Bonifatius_Pastoralteam_Uwe-edited.jpg`, mail: 'u.michler@sanktbonifatius.de' },
  { name: 'P. Gaby Geagea c.m.l', role: 'Priesterlicher Mitarbeiter', photo: `${IMG}/2023/07/Bonifatius_Pastoralteam_Gaby-e1659515837936-edited.jpg`, mail: 'g.geagea@sanktbonifatius.de' },
  { name: 'Martin Kestler', role: 'Pastoralreferent', sub: 'Ansprechpartner St. Wendel', photo: `${IMG}/2023/05/Bonifatius_Pastoralteam_Martin-e1659516162716-edited.jpg`, mail: 'm.kestler@sanktbonifatius.de' },
  { name: 'Lilian Wykipil', role: 'Pastoralreferentin', sub: 'Ansprechpartnerin St. Aposteln', photo: `${IMG}/2023/09/lilian-wykipil-1.jpeg`, mail: 'l.wykipil@sanktbonifatius.de' },
  { name: 'Doly Kadavil', role: 'Pastoralreferentin', sub: 'Ansprechpartnerin Herz-Jesu', photo: `${IMG}/2023/08/image.png`, mail: 'd.kadavil@sanktbonifatius.de' },
  { name: 'Sr. Bettina Rupp SSPS', role: 'Sozialarbeiterin', photo: `${IMG}/2025/05/bettina-edited.jpg`, mail: 'bettina.rupp@ssps.de' },
  { name: 'Dorothea Schneider', role: 'Pastoralreferentin', sub: 'Ansprechpartnerin St. Bonifatius', photo: `${IMG}/2024/01/Dorothea.jpg`, mail: 'd.schneider@sanktbonifatius.de' },
  { name: 'Frank Hoffmann', role: 'Referent Familienpastoral', photo: `${IMG}/2025/06/DSC00850-1.jpg`, mail: 'f.hoffmann@sanktbonifatius.de' },
  { name: 'Sandra Roos-Greulich', role: 'Koordinatorin Kindertagesstätten', photo: `${IMG}/2023/05/Sandra-Roos-Greulich-edited-1.jpg`, mail: 's.roos-greulich@sanktbonifatius.de' },
  { name: 'Annette Gause', role: 'Verwaltungsleiterin', photo: `${IMG}/2025/06/DSC00845.jpg`, mail: 'a.gause@sanktbonifatius.de' },
];
const PDF = `${IMG}/2024/11/Arbeitsbereiche-Pastoralteam-2024.pdf`;
---
<section class="astro-ptteam">
  <div class="astro-ptteam__in">
    <h2 class="astro-ptteam__h2">Das Team</h2>
    <div class="astro-ptteam__grid">
      {TEAM.map((p) => (
        <div class="astro-ptteam__card">
          <div class="astro-ptteam__photo" role="img" aria-label={`Foto von ${p.name}`}
               style={`background-image:url('${p.photo}')`}></div>
          <h3 class="astro-ptteam__name">{p.name}</h3>
          <p class="astro-ptteam__role">{p.role}</p>
          {p.sub && <p class="astro-ptteam__sub">{p.sub}</p>}
          <a class="astro-ptteam__mail" href={`mailto:${p.mail}`}>{p.mail}</a>
        </div>
      ))}
    </div>

    <div class="astro-ptteam__pdf">
      <div>
        <h3 class="astro-ptteam__pdfh">Aufgabenaufteilung im Pastoralteam</h3>
        <p class="astro-ptteam__pdfp">Detaillierte Übersicht über alle Ansprechpersonen und Arbeitsbereiche in unserer Pfarrei.</p>
      </div>
      <a class="astro-ptteam__pdfbtn" href={PDF} target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
        PDF herunterladen
      </a>
    </div>
  </div>
</section>

<style is:global>
.astro-ptteam{background:#f7f3ef;padding:80px 0;width:100vw;position:relative;left:50%;margin-left:-50vw;margin-right:-50vw}
.astro-ptteam__in{max-width:1140px;margin:0 auto;padding:0 40px}
.astro-ptteam__h2{font-family:'Playfair Display',Georgia,serif;font-weight:700;color:#2c2420;text-align:center;font-size:clamp(26px,3.4vw,38px);margin:0 0 44px}
.astro-ptteam__grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.astro-ptteam__card{background:#fff;border-radius:14px;padding:32px 24px;text-align:center;box-shadow:0 2px 16px rgba(30,21,18,.07);transition:transform .2s,box-shadow .2s}
.astro-ptteam__card:hover{transform:translateY(-3px);box-shadow:0 12px 28px rgba(30,21,18,.12)}
.astro-ptteam__photo{width:128px;height:128px;border-radius:50%;background-size:cover;background-position:center top;margin:0 auto 20px;box-shadow:0 4px 14px rgba(0,0,0,.15);border:4px solid #fff;background-color:#ede4d5}
.astro-ptteam__name{font-family:'Playfair Display',Georgia,serif;font-size:21px;color:#2c2420;margin:0 0 6px;font-weight:700}
.astro-ptteam__role{color:#9a2d2d;font-size:12px;margin:0 0 4px;letter-spacing:.08em;text-transform:uppercase;font-weight:600}
.astro-ptteam__sub{color:#8a7a6e;font-size:13px;margin:0 0 12px}
.astro-ptteam__card .astro-ptteam__role + .astro-ptteam__mail{margin-top:12px}
.astro-ptteam__mail{display:inline-block;color:#3a2e28;font-size:14px;word-break:break-word;transition:color .2s}
.astro-ptteam__mail:hover{color:#9a2d2d}
.astro-ptteam__pdf{display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:20px;margin-top:40px;background:#fff;border:1px solid #e0d8cf;border-radius:14px;padding:28px 32px}
.astro-ptteam__pdfh{font-family:'Playfair Display',Georgia,serif;font-size:20px;color:#2c2420;margin:0 0 6px;font-weight:700}
.astro-ptteam__pdfp{color:#6b5c52;font-size:15px;margin:0;max-width:560px}
.astro-ptteam__pdfbtn{display:inline-flex;align-items:center;gap:8px;background:#9a2d2d;color:#fff;padding:13px 24px;border-radius:50px;font-size:14px;font-weight:600;white-space:nowrap;transition:background .2s}
.astro-ptteam__pdfbtn:hover{background:#7e2424}
@media(max-width:900px){.astro-ptteam__grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:560px){.astro-ptteam{padding:56px 0}.astro-ptteam__in{padding:0 20px}.astro-ptteam__grid{grid-template-columns:1fr}.astro-ptteam__pdf{flex-direction:column;align-items:flex-start}}
</style>
