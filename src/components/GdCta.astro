---
// Abschluss-CTA „Wie können wir Ihnen helfen?" (ersetzt WP-Block `gd-cta`).
// Eigene Klassen `astro-gdcta`. Kontaktdaten des Pfarrbüros.
---
<section class="astro-gdcta">
  <div class="astro-gdcta__inner">
    <h2 class="astro-gdcta__hl">Wie können wir Ihnen helfen?</h2>
    <p class="astro-gdcta__sub">Ob Taufe, Hochzeit oder Trauerfall – das Pfarrbüro ist Ihr erster Ansprechpartner. Wir begleiten Sie gerne.</p>
    <div class="astro-gdcta__btns">
      <a class="astro-gdcta__btn" href="/kontakt/">Kontakt aufnehmen</a>
    </div>
    <div class="astro-gdcta__contact">
      <a class="astro-gdcta__item" href="tel:+4969695975850">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        069 695 97 58 50
      </a>
      <a class="astro-gdcta__item" href="mailto:info@sanktbonifatius.de">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 6L2 7"/></svg>
        info@sanktbonifatius.de
      </a>
      <span class="astro-gdcta__item astro-gdcta__item--hours">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
        Di–Fr 09–12 Uhr
      </span>
    </div>
  </div>
</section>

<style is:global>
.astro-gdcta{background:linear-gradient(135deg,#2c1a12 0%,#4a2620 55%,#6b2e2a 100%);color:#f0e8d8;padding:72px 0;width:100vw;position:relative;left:50%;margin-left:-50vw;margin-right:-50vw}
.astro-gdcta__inner{max-width:760px;margin:0 auto;padding:0 40px;text-align:center}
.astro-gdcta__hl{font-family:'Playfair Display',serif;font-size:clamp(26px,3.6vw,40px);font-weight:700;color:#fff;margin:0 0 16px}
.astro-gdcta__sub{font-size:clamp(15px,1.8vw,18px);color:#e0d6c6;line-height:1.65;margin:0 auto 28px;max-width:560px}
.astro-gdcta__btns{margin:0 0 36px}
.astro-gdcta__btn{display:inline-block;padding:14px 32px;border-radius:50px;background:#9a2d2d;color:#fff;font-size:15px;font-weight:600;transition:background .2s}
.astro-gdcta__btn:hover{background:#7e2424}
.astro-gdcta__contact{display:flex;flex-wrap:wrap;justify-content:center;gap:14px 32px}
.astro-gdcta__item{display:inline-flex;align-items:center;gap:9px;font-size:15px;color:#e8ddc9}
.astro-gdcta__item svg{width:18px;height:18px;color:#c5a55a;flex-shrink:0}
a.astro-gdcta__item:hover{color:#fff}
.astro-gdcta__item--hours{color:#bbae97}
@media(max-width:600px){.astro-gdcta{padding:52px 0}.astro-gdcta__inner{padding:0 20px}.astro-gdcta__contact{flex-direction:column;align-items:center;gap:12px}}
</style>
