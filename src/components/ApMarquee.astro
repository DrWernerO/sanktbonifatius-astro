  '/uploads/2022/10/Kleidercafe-staposteln-frankfurt.jpg',
  '/uploads/2026/05/10-jahre-steyler-missionsschwestern-st-aposteln.jpg',
];
---
<div class="astro-apos-marquee" id="galerie">
  <div class="astro-apos-marquee-track">
    {images.map(src => <img src={src} alt="Leben in St. Aposteln" loading="lazy" />)}
    {images.map(src => <img src={src} alt="" loading="lazy" aria-hidden="true" />)}
  </div>
</div>

<style is:global>
.astro-apos-marquee {
  overflow: hidden;
  background: #1e1512;
  padding: 6px 0;
  width: 100vw;
  position: relative;
  left: 50%;
  margin-left: -50vw;
}
.astro-apos-marquee-track {
  display: flex;
  gap: 8px;
  width: max-content;
  animation: astroAposMarquee 70s linear infinite;
}
.astro-apos-marquee-track:hover { animation-play-state: paused; }
.astro-apos-marquee-track img {
  height: 240px;
  width: auto;
  object-fit: cover;
  border-radius: 4px;
  display: block;
  flex-shrink: 0;
}
@keyframes astroAposMarquee {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}
@media (max-width: 600px) {
  .astro-apos-marquee-track img { height: 160px; }
}
</style>
