        Häufige Fragen
      </a>
    </div>
  </div>
</div>

<style is:global>
.astro-ap-quick {
  background: var(--ap-cream);
  padding: 22px 0;
  width: 100vw;
  margin-left: calc(50% - 50vw);
}
.astro-ap-quick__in {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 14px;
}
.astro-ap-quick__lab {
  font-size: 15px;
  color: var(--ap-ink);
  font-weight: 700;
  margin-right: 6px;
}
.astro-ap-quick__row {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}
.astro-ap-quick a {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 8px 14px;
  border-radius: 999px;
  background: #fff;
  color: var(--ap-ink);
  text-decoration: none;
  font-size: 14px;
  font-weight: 700;
  border: 1px solid rgba(0,0,0,.08);
  transition: all .2s;
}
.astro-ap-quick a svg { flex-shrink: 0; color: var(--ap-g); }
.astro-ap-quick a:hover { background: var(--ap-g); color: #fff; border-color: var(--ap-g); }
.astro-ap-quick a:hover svg { color: #fff; }
</style>
