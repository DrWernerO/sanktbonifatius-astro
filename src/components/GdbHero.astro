---
// Hero „Gottesdienste, die berühren" (ersetzt WP-Block `gd-hero`). Eigene Klassen `astro-gdbhero`.
// Foto-Hero (Full-Bleed) + Verlauf-Overlay + Text (Muster GdHero.astro, Handbuch 10).
// Bild lokal im Projekt unter public/uploads/ (vom WP heruntergeladen, Handbuch 1b).
const bg = '/uploads/2023/07/stbonifatius-gottesdienste-die-beruehren.jpg';
---
<section class="astro-gdbhero">
  <div class="astro-gdbhero__bg" role="img"
       aria-label="Gottesdienst bei Kerzenlicht in der Pfarrkirche St. Bonifatius Frankfurt"
       style={`background-image:url('${bg}')`}></div>
  <div class="astro-gdbhero__overlay"></div>
  <div class="astro-gdbhero__inner">
    <p class="astro-gdbhero__eyebrow">Pfarrei Sankt Bonifatius · Frankfurt</p>
    <h1 class="astro-gdbhero__title">Gottesdienste, die berühren</h1>
    <p class="astro-gdbhero__sub">Besondere Formate, die Stille, Musik und Gemeinschaft vereinen – für alle, die mehr suchen als das Gewöhnliche.</p>
    <div class="astro-gdbhero__btns">
      <a class="astro-gdbhero__btn astro-gdbhero__btn--primary" href="/gottesdienst-glaube/gottesdienstordnung/">Alle Gottesdienste</a>
      <a class="astro-gdbhero__btn astro-gdbhero__btn--ghost" href="/kontakt/">Fragen &amp; Kontakt</a>
    </div>
  </div>
</section>

<style is:global>
.astro-gdbhero{position:relative;width:100vw;left:50%;margin-left:-50vw;margin-right:-50vw;min-height:560px;display:flex;align-items:flex-end;overflow:hidden;background:#150806}
.astro-gdbhero__bg{position:absolute;inset:0;background-size:cover;background-position:center 35%;filter:brightness(.88)}
.astro-gdbhero__overlay{position:absolute;inset:0;background:linear-gradient(160deg,rgba(10,4,2,.2) 0%,rgba(20,8,5,.55) 45%,rgba(35,10,8,.9) 100%)}
.astro-gdbhero__inner{position:relative;max-width:1200px;width:100%;margin:0 auto;padding:0 40px 64px;color:#f0e8d8}
.astro-gdbhero__eyebrow{font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:#c5a55a;margin:0 0 14px}
.astro-gdbhero__title{font-family:'Playfair Display',serif;font-weight:700;line-height:1.05;color:#fff;font-size:clamp(40px,6vw,72px);margin:0}
.astro-gdbhero__sub{font-size:clamp(16px,1.9vw,20px);color:#e8ddc9;line-height:1.55;margin:18px 0 0;max-width:640px}
.astro-gdbhero__btns{display:flex;flex-wrap:wrap;gap:14px;margin:30px 0 0}
.astro-gdbhero__btn{display:inline-block;padding:13px 26px;border-radius:50px;font-size:14px;font-weight:600;letter-spacing:.02em;transition:background .2s,color .2s,border-color .2s}
.astro-gdbhero__btn--primary{background:#9a2d2d;color:#fff}
.astro-gdbhero__btn--primary:hover{background:#7e2424}
.astro-gdbhero__btn--ghost{border:1px solid rgba(240,232,216,.55);color:#f0e8d8}
.astro-gdbhero__btn--ghost:hover{background:rgba(240,232,216,.12);border-color:#f0e8d8}
@media(max-width:600px){.astro-gdbhero{min-height:460px}.astro-gdbhero__inner{padding:0 20px 44px}}
</style>
