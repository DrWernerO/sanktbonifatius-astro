---
// Hero der Seite „ChurchDesk-Registrierung" — WP-Seite 49146 (/ueberuns/churchdesk-registrierung/,
// ersetzt WP-Block `cd-hero`). Eigene Klassen `astro-cd-hero` (Handbuch Abschnitt 3 — niemals
// WP-Klassen `cd-…`). Inhalte 1:1 aus dem WP-Content übernommen (Eyebrow, H1, Untertitel).
// Neutraler Hero OHNE Foto (auf Wunsch): dunkel-warmer Verlauf wie KontaktHero, dezentes
// Raster-SVG. Genau EINE sichtbare <h1> der Seite (Hero).
---
<section class="astro-cd-hero">
  <div class="astro-cd-hero__deco" aria-hidden="true"></div>
  <div class="astro-cd-hero__inner">
    <p class="astro-cd-hero__eyebrow">Für Ehrenamtliche</p>
    <h1 class="astro-cd-hero__title">ChurchDesk-Registrierung für Ehrenamtliche</h1>
    <p class="astro-cd-hero__sub">
      Sind Sie in der Pfarrei Sankt Bonifatius Frankfurt ehrenamtlich engagiert? Mit Ihrer
      persönlichen Anmeldung bei ChurchDesk behalten Sie unsere Veranstaltungen im Blick,
      tauschen sich mit anderen Engagierten aus und erhalten wichtige Informationen aus dem
      Pastoralteam.
    </p>
  </div>
</section>

<style is:global>
.astro-cd-hero{position:relative;width:100vw;left:50%;margin-left:-50vw;margin-right:-50vw;display:flex;align-items:flex-end;min-height:480px;overflow:hidden;background:linear-gradient(135deg,#2c1a14 0%,#3a241b 55%,#1f130d 100%);color:#fff}
.astro-cd-hero::after{content:"";position:absolute;inset:0;z-index:0;background:radial-gradient(circle at 20% 0%,rgba(197,165,90,.18),transparent 55%)}
.astro-cd-hero__deco{position:absolute;inset:0;z-index:0;opacity:.06;background-image:url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Crect x='5' y='5' width='50' height='50' fill='none' stroke='%23fff' stroke-width='.5'/%3E%3Cpath d='M30 5v50M5 30h50' stroke='%23fff' stroke-width='.3'/%3E%3C/svg%3E");background-size:60px 60px}
.astro-cd-hero__inner{position:relative;z-index:1;max-width:980px;width:100%;margin:0 auto;padding:140px 40px 60px}
.astro-cd-hero__eyebrow{font-family:'Playfair Display',Georgia,serif;font-style:italic;font-size:13px;color:#e8d99c;letter-spacing:.14em;text-transform:uppercase;font-weight:700;margin:0 0 14px}
.astro-cd-hero__title{font-family:'Playfair Display',Georgia,serif;font-size:clamp(34px,5vw,52px);font-weight:700;color:#fff;margin:0 0 14px;letter-spacing:-.01em;line-height:1.1}
.astro-cd-hero__sub{font-size:clamp(15px,1.7vw,18px);color:rgba(255,255,255,.9);max-width:580px;margin:0;line-height:1.55}
@media(max-width:600px){.astro-cd-hero{min-height:380px}.astro-cd-hero__inner{padding:120px 20px 44px}}
</style>
