---
// Abschluss-CTA „Du bist herzlich eingeladen" (WP-Block `jug-cta`). Eigene Klassen `astro-jucta`.
// Warm-brauner Verlauf (Design-System §5: kein Near-Black für Banner). Feste Inhalte.
// „Kontakt aufnehmen" geht an die Jugend-Ansprechpartnerin (l.wykipil@), nicht ans Pfarrbüro.
---
<section class="astro-jucta">
  <div class="astro-jucta__inner">
    <p class="astro-jucta__eyebrow">Komm vorbei</p>
    <h2 class="astro-jucta__hl">Du bist herzlich eingeladen</h2>
    <p class="astro-jucta__sub">
      Ob du erst hineinschnuppern oder gleich einsteigen m&ouml;chtest &#8212; wir freuen uns auf dich.
      Melde dich einfach bei uns oder komm beim n&auml;chsten Termin vorbei.
    </p>
    <div class="astro-jucta__btns">
      <a class="astro-jucta__btn astro-jucta__btn--primary"
         href="mailto:l.wykipil@sanktbonifatius.de?subject=Jugend%20in%20Sankt%20Bonifatius">Jetzt Kontakt aufnehmen</a>
      <a class="astro-jucta__btn astro-jucta__btn--ghost" href="/terminkalender/">Alle Termine &#8594;</a>
    </div>
  </div>
</section>

<style is:global>
.astro-jucta{position:relative;width:100vw;left:50%;margin-left:-50vw;margin-right:-50vw;background:linear-gradient(135deg,#4a2e1a 0%,#3a2315 100%);color:#fff;padding:76px 0;overflow:hidden}
.astro-jucta::after{content:"";position:absolute;inset:0;background:radial-gradient(circle at 20% 10%,rgba(197,165,90,.16),transparent 55%)}
.astro-jucta__inner{position:relative;z-index:1;max-width:760px;margin:0 auto;padding:0 40px;text-align:center}
.astro-jucta__eyebrow{font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:#d4aa5a;margin:0 0 14px;font-weight:600}
.astro-jucta__hl{font-family:'Playfair Display',serif;font-size:clamp(26px,3.4vw,40px);font-weight:700;color:#fff;margin:0 0 14px}
.astro-jucta__sub{font-size:clamp(15px,1.8vw,19px);color:rgba(255,255,255,.85);line-height:1.6;margin:0 0 32px}
.astro-jucta__btns{display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:16px}
.astro-jucta__btn{display:inline-flex;align-items:center;gap:10px;padding:14px 28px;border-radius:50px;font-size:15px;font-weight:600;text-decoration:none;transition:background .2s,border-color .2s,color .2s}
.astro-jucta__btn--primary{background:#9a2d2d;color:#fff}
.astro-jucta__btn--primary:hover{background:#b8423f}
.astro-jucta__btn--ghost{border:1.5px solid rgba(255,255,255,.55);color:#fff}
.astro-jucta__btn--ghost:hover{border-color:#fff;background:rgba(255,255,255,.1)}
@media(max-width:600px){.astro-jucta{padding:56px 0}.astro-jucta__inner{padding:0 20px}}
</style>
