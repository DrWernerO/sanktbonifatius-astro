---
// Hero der Seite „Krankensalbung" — WP-Seite 47431 (/segen-sakramente/krankensalbung/, WP-Block
// `ks-hero`). Eigene Klassen `astro-ks-hero` (goldene Regel, Handbuch Abschnitt 3 — WP-Klassen
// `ks-…` tabu). Foto-Hero (Live-Mediathek, HTTP 200) → Bild + dunkler Gradient (Muster BcHero,
// Handbuch § 4/10). Einzige sichtbare <h1> der Seite.
---
<section class="astro-ks-hero">
  <div class="astro-ks-hero__inner">
    <span class="astro-ks-hero__eyebrow">Pfarrei Sankt Bonifatius Frankfurt</span>
    <h1 class="astro-ks-hero__title">Krankensalbung</h1>
    <p class="astro-ks-hero__sub">
      Das Sakrament der St&auml;rkung &#8211; f&uuml;r Kranke, vor Operationen und in schwierigen
      Lebenslagen. Wir kommen zu Ihnen.
    </p>
    <div class="astro-ks-hero__btns">
      <a class="astro-ks-hero__btn" href="#ks-contact">Jetzt anfragen</a>
    </div>
  </div>
</section>

<style is:global>
.astro-ks-hero{position:relative;width:100vw;left:50%;margin-left:-50vw;margin-right:-50vw;min-height:520px;display:flex;align-items:flex-end;overflow:hidden}
@media(min-width:768px){.astro-ks-hero{min-height:600px}}
.astro-ks-hero::before{content:"";position:absolute;inset:0;background-image:url('https://www.sanktbonifatius.de/wp-content/uploads/2023/07/salbung-sakramente-stbonifatius.jpg');background-size:cover;background-position:center 42%;z-index:0}
.astro-ks-hero::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(20,10,2,.35) 0%,rgba(20,10,2,.55) 55%,rgba(20,10,2,.9) 100%);z-index:1}
.astro-ks-hero__inner{position:relative;z-index:2;width:100%;max-width:1200px;margin:0 auto;padding:48px 48px 60px;color:#fff}
.astro-ks-hero__eyebrow{font-family:'Playfair Display',Georgia,serif;font-style:italic;font-size:.95rem;color:#c8a96e;letter-spacing:.06em;display:block;margin-bottom:12px}
.astro-ks-hero__title{font-family:'Playfair Display',Georgia,serif;font-size:clamp(34px,5vw,66px);font-weight:700;color:#fff;margin:0 0 16px;line-height:1.1}
.astro-ks-hero__sub{font-size:clamp(16px,2vw,21px);color:rgba(255,255,255,.85);max-width:580px;line-height:1.65;margin:0 0 28px}
.astro-ks-hero__btns{display:flex;gap:14px;flex-wrap:wrap}
.astro-ks-hero__btn{display:inline-flex;align-items:center;gap:8px;padding:14px 30px;border-radius:50px;font-size:15px;font-weight:700;text-decoration:none;background:#9a2d2d;color:#fff;transition:background .2s}
.astro-ks-hero__btn:hover{background:#7e2424}
@media(max-width:600px){.astro-ks-hero{min-height:460px}.astro-ks-hero__inner{padding:0 20px 40px}}
</style>
