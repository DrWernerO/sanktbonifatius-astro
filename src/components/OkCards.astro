---
// „Wie funktioniert das Lebensmittel-Teilen?" — Unterseite „Offener Kühlschrank" (WP-Seite 49123).
// Eigene Klassen `astro-okcards`. Zwei Karten (spenden / mitnehmen) mit SVG-Icon, H3, Lead, Liste.
// SVG statt Emoji. id="mitmachen" für Sprung-Anker. Feste Inhalte.
const cards = [
  {
    icon: '<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>',
    title: 'Lebensmittel spenden',
    lead: 'Sie haben mehr, als Sie brauchen? Bringen Sie haltbare und abgepackte Lebensmittel einfach vorbei &#8211; andere in Frankfurt-Sachsenhausen freuen sich!',
    list: [
      'Abgepackte, haltbare Lebensmittel',
      'Unge&ouml;ffnete Originalverpackungen',
      'Frisches Obst &amp; Gem&uuml;se willkommen',
      'Konserven, Nudeln, Reis, Milchprodukte',
    ],
  },
  {
    icon: '<path d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17"/><circle cx="9" cy="20" r="1"/><circle cx="17" cy="20" r="1"/>',
    title: 'Lebensmittel mitnehmen',
    lead: 'Kein Nachweis, keine Fragen, keine Bedingungen: Schauen Sie einfach vorbei und nehmen Sie mit, was Sie brauchen. Das Angebot ist vollst&auml;ndig kostenlos.',
    list: [
      'Kostenlos f&uuml;r alle Menschen',
      'T&auml;glich zug&auml;nglich (Fr. 10&#8211;14 Uhr)',
      'K&uuml;hlschrank &amp; Trockenregale',
      'Regelm&auml;&szlig;ig aufgef&uuml;llt durch foodsharing',
    ],
  },
];
---
<section class="astro-okcards" id="mitmachen">
  <div class="astro-okcards__inner">
    <h2 class="astro-okcards__hl">Wie funktioniert das Lebensmittel-Teilen?</h2>
    <div class="astro-okcards__grid">
      {cards.map((c) => (
        <div class="astro-okcard">
          <span class="astro-okcard__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={c.icon} />
          </span>
          <h3 class="astro-okcard__title" set:html={c.title} />
          <p class="astro-okcard__lead" set:html={c.lead} />
          <ul class="astro-okcard__list">
            {c.list.map((li) => (
              <li class="astro-okcard__li">
                <svg class="astro-okcard__check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                <span set:html={li} />
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
.astro-okcards{background:#fff;padding:80px 0}
.astro-okcards__inner{max-width:1100px;margin:0 auto;padding:0 40px}
.astro-okcards__hl{font-family:'Playfair Display',serif;font-size:clamp(26px,3.4vw,40px);font-weight:700;color:#2c2420;margin:0 0 40px;text-align:center}
.astro-okcards__grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px}
.astro-okcard{background:#f7f3ef;border-radius:14px;padding:36px 32px;box-shadow:0 2px 14px rgba(30,21,18,.05)}
.astro-okcard__icon{display:inline-flex;align-items:center;justify-content:center;width:56px;height:56px;border-radius:14px;background:#9a2d2d;color:#fff;margin:0 0 20px}
.astro-okcard__icon svg{width:28px;height:28px}
.astro-okcard__title{font-family:'Playfair Display',serif;font-size:23px;font-weight:700;color:#2c2420;margin:0 0 12px}
.astro-okcard__lead{font-size:16px;color:#6b5c52;line-height:1.65;margin:0 0 22px}
.astro-okcard__list{list-style:none;margin:0;padding:0}
.astro-okcard__li{display:flex;align-items:flex-start;gap:12px;font-size:15px;color:#3d3530;line-height:1.5;padding:8px 0;border-top:1px solid rgba(154,45,45,.1)}
.astro-okcard__li:first-child{border-top:none}
.astro-okcard__check{width:18px;height:18px;color:#9a2d2d;flex-shrink:0;margin-top:2px}
@media(max-width:760px){.astro-okcards__grid{grid-template-columns:1fr}}
@media(max-width:600px){.astro-okcards{padding:56px 0}.astro-okcards__inner{padding:0 20px}.astro-okcard{padding:28px 24px}}
</style>
