---
// Seite „Über uns" — WP-Seite 46786 (/ueberuns/), vollständig aus eigenen astro-Komponenten
// (kein set:html mit WP-Markup, vgl. Handbuch Abschnitt 9b). Nav + Footer kommen global aus
// Base.astro. Inhalte fest gepflegt (selten geändert — Handbuch Abschnitt 9b „feste Inhalte").
import Base from '../layouts/Base.astro';
import UeberunsHero from '../components/UeberunsHero.astro';
import UeberunsLeitbild from '../components/UeberunsLeitbild.astro';
import UeberunsAngebote from '../components/UeberunsAngebote.astro';
import UeberunsPfarrei from '../components/UeberunsPfarrei.astro';
import UeberunsKirchorte from '../components/UeberunsKirchorte.astro';
import UeberunsLeitung from '../components/UeberunsLeitung.astro';
import UeberunsCta from '../components/UeberunsCta.astro';
import { getSeoHead } from '../lib/wordpress.js';

// SEO (Titel/Description/OG/JSON-LD) aus der mit SEOPress optimierten WP-Seite übernehmen.
const seo = await getSeoHead('/ueberuns/');
---
<Base seo={seo} title="Über uns">
  <UeberunsHero />
  <UeberunsLeitbild />
  <UeberunsAngebote />
  <UeberunsPfarrei />
  <UeberunsKirchorte />
  <UeberunsLeitung />
  <UeberunsCta />
</Base>
