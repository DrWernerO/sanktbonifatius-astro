---
// Terminkalender — WP-Seite 47024 (/terminkalender), komplett aus eigenen astro-Komponenten.
// Nav + Footer kommen global aus Base.astro. Termine live aus der WP-API (CalendarOverview).
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import CalendarOverview from '../components/CalendarOverview.astro';
---
<Base title="Terminkalender">
  <PageHeader
    eyebrow="Pfarrei St. Bonifatius · Frankfurt"
    title="Terminkalender"
    sub="Alle Veranstaltungen und Gottesdienste auf einen Blick – filtern nach Monat, Kirchort und Kategorie."
  >
    <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
    </svg>
  </PageHeader>
  <CalendarOverview />
</Base>
