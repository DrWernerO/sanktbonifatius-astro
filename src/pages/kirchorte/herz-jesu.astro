---
// Kirchort „Herz Jesu" — WP-Seite 47906 (/ueberuns/kirchorte/herz-jesu/), Astro-Pfad
// /kirchorte/herz-jesu/ (Kirchorte liegen im Astro-Frontend auf Hauptebene, vgl. Handbuch Abschnitt 5).
// Vollständig aus eigenen astro-hj…-Komponenten (kein set:html mit WP-Markup). Nav + Footer
// kommen global aus Base.astro. Inhalte fest gepflegt; nur der SEO-Head kommt live aus WP.
import Base from '../../layouts/Base.astro';
import HjHero from '../../components/HjHero.astro';
import HjQuick from '../../components/HjQuick.astro';
import HjWelcome from '../../components/HjWelcome.astro';
import HjGottesdienste from '../../components/HjGottesdienste.astro';
import HjCards from '../../components/HjCards.astro';
import HjTeam from '../../components/HjTeam.astro';
import HjGallery from '../../components/HjGallery.astro';
import HjFaq from '../../components/HjFaq.astro';
import HjCta from '../../components/HjCta.astro';
import { getSeoHead } from '../../lib/wordpress.js';

const seo = await getSeoHead('/ueberuns/kirchorte/herz-jesu/');
---
<Base seo={seo} title="Kirchort Herz Jesu Frankfurt-Oberrad · Pfarrei Sankt Bonifatius">
  <HjHero />
  <HjQuick />
  <HjWelcome />
  <HjGottesdienste />
  <HjCards />
  <HjTeam />
  <HjGallery />
  <HjFaq />
  <HjCta />
</Base>
