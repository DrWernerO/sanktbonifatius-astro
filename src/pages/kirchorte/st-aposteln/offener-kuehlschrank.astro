  left: 0;
  color: var(--ok-g);
  font-weight: 700;
}

/* ─── Warum (bg) ─── */
.astro-ok-bg {
  padding: 80px 0;
}
.astro-ok-bg__inner {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 32px;
  display: grid;
  grid-template-columns: 1fr 1.4fr;
  gap: 60px;
  align-items: center;
}
.astro-ok-bg__img img {
  width: 100%;
  border-radius: 12px;
  display: block;
  box-shadow: var(--ok-shd);
}
.astro-ok-bg__h2 {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: clamp(22px, 2.8vw, 32px);
  color: var(--ok-ink);
  margin: 0 0 18px;
  line-height: 1.2;
}
.astro-ok-bg__p {
  font-size: 16px;
  color: var(--ok-mute);
  line-height: 1.7;
  margin: 0 0 14px;
}
.astro-ok-bg__link { color: var(--ok-g); font-weight: 600; text-decoration: none; }
.astro-ok-bg__link:hover { text-decoration: underline; }

/* ─── Standort ─── */
.astro-ok-standort {
  background: var(--ok-cream);
  padding: 80px 0;
  width: 100vw;
  position: relative;
  left: 50%;
  margin-left: -50vw;
