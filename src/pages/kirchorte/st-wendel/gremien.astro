---
// Gremien / Kirchortrat St. Wendel (WP-Draft ID 49288, /kirchorte/st-wendel/gremien/)
// Primärfarbe Dunkelblau #012C7B. Eigene Klassen astro-swgr*.
import Base from '../../../layouts/Base.astro';

const seo = {
  title: 'Kirchortrat St. Wendel – Pfarrei Sankt Bonifatius Frankfurt',
  description: 'Der Kirchortrat St. Wendel vertritt die Anliegen der Gemeindemitglieder und sorgt dafür, dass St. Wendel ein lebendiger Ort des Glaubens und der Begegnung bleibt.',
};
---
<Base seo={seo} title={seo.title}>

  <!-- Intro-Header -->
  <section class="astro-swgr__intro">
    <div class="astro-swgr__intro-in">
      <a class="astro-swgr__back" href="/kirchorte/st-wendel/">&larr; St. Wendel</a>
      <p class="astro-swgr__eyebrow">Kirchort St. Wendel &middot; Frankfurt-Sachsenhausen</p>
      <h1 class="astro-swgr__h1">Kirchortrat St. Wendel</h1>
      <p class="astro-swgr__lead">Ehrenamtlich für die Gemeinde – der Kirchortrat vertritt die Anliegen der Gemeindemitglieder und begleitet das Gemeindeleben in St. Wendel.</p>
    </div>
  </section>

  <!-- Inhalt -->
  <section class="astro-swgr__sec" id="kirchortrat">
    <div class="astro-swgr__sec-in">
      <div class="astro-swgr__grid">

        <!-- Vorsitz -->
        <div class="astro-swgr__card">
          <div class="astro-swgr__card-head">
            <div class="astro-swgr__card-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="28" height="28"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
            </div>
            <div>
              <div class="astro-swgr__card-title">Vorsitz</div>
              <div class="astro-swgr__card-sub">2 Personen</div>
            </div>
          </div>
          <div class="astro-swgr__card-body">
            <div class="astro-swgr__vorsitz">
              <div class="astro-swgr__vorsitz-label">Vorsitzende</div>
              <div class="astro-swgr__vorsitz-name">
                Alexandra Gockel-Bok<br>
                <span class="astro-swgr__vorsitz-rolle">Gospelchor</span><br>
                <a href="mailto:alexandra.bok@web.de">alexandra.bok@web.de</a>
              </div>
            </div>
            <div class="astro-swgr__vorsitz">
              <div class="astro-swgr__vorsitz-label">Vorsitzende</div>
              <div class="astro-swgr__vorsitz-name">
                Valerie Buchmaier<br>
                <span class="astro-swgr__vorsitz-rolle">Kommunionhelfer / Lektoren</span><br>
                <a href="mailto:buchmaiervalerie@gmail.com">buchmaiervalerie@gmail.com</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Mitglieder -->
        <div class="astro-swgr__card">
          <div class="astro-swgr__card-head">
            <div class="astro-swgr__card-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="28" height="28"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <div>
              <div class="astro-swgr__card-title">Weitere Mitglieder</div>
              <div class="astro-swgr__card-sub">16 Personen &middot; alle Bereiche</div>
            </div>
          </div>
          <div class="astro-swgr__card-body">
            <table class="astro-swgr__table">
              <tr><td>Manuel Nieder</td><td>Liturgie</td></tr>
              <tr><td>Danielle Wendel-Baumert</td><td>Repair Café, Ukraine-Treff, Senioren</td></tr>
              <tr><td>Reinhard Bok</td><td>Bauausschuss</td></tr>
              <tr><td>Gaby Hideghety</td><td>Bauausschuss</td></tr>
              <tr><td>Sabine Nolte</td><td>InklusionsAG, Inklusion-Spielgruppe</td></tr>
              <tr><td>Silke Weidner</td><td>Bücherei</td></tr>
              <tr><td>Tobias Naumann</td><td>Kita</td></tr>
              <tr><td>Frank Goldberg</td><td>Erwachsenenbildung</td></tr>
              <tr><td>Lilien Ács</td><td>Messdiener</td></tr>
              <tr><td>Adelheid Müller-Horrig</td><td>Chor 1 – klassischer Kirchenchor</td></tr>
              <tr><td>Doris Burnaws-Dieter</td><td>Jugendfahrten, Sternsinger</td></tr>
              <tr><td>Noah Treiling</td><td>Kirchcafé</td></tr>
              <tr><td>Bernhard Stadler</td><td>Kinderkarfreitag, Weltkirche</td></tr>
              <tr><td>Julia Berkmann</td><td>Mini-Gottesdienst</td></tr>
              <tr><td>Anna Stork</td><td>Familiengottesdienst</td></tr>
              <tr><td>Pater Gaby Geagea c.m.l</td><td>Maronitische Gemeinde</td></tr>
            </table>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="astro-swgr__cta">
    <div class="astro-swgr__cta-in">
      <h2 class="astro-swgr__cta-h2">Interesse am Ehrenamt?</h2>
      <p class="astro-swgr__cta-p">Wer sich im Kirchortrat oder einem seiner Bereiche engagieren möchte, ist herzlich willkommen. Sprechen Sie uns einfach an.</p>
      <div class="astro-swgr__cta-btns">
        <a class="astro-swgr__cta-outline" href="/kirchorte/st-wendel/">&larr; Zurück zu St. Wendel</a>
        <a class="astro-swgr__cta-btn" href="/kontakt/">Pfarrbüro kontaktieren</a>
      </div>
    </div>
  </section>

</Base>

<style is:global>
/* ── Intro-Header ─────────────────────────────────────── */
.astro-swgr__intro{
  background:linear-gradient(160deg,#011d52 0%,#012C7B 60%,#01408c 100%);
  width:100vw;position:relative;left:50%;margin-left:-50vw;margin-right:-50vw;
  padding:120px 24px 64px;text-align:center;color:#fff;
}
.astro-swgr__intro-in{max-width:800px;margin:0 auto}
.astro-swgr__back{display:inline-block;color:rgba(255,255,255,.7);text-decoration:none;font-size:14px;margin-bottom:20px;letter-spacing:.04em}
.astro-swgr__back:hover{color:#fff}
.astro-swgr__eyebrow{font-family:'Playfair Display',Georgia,serif;font-style:italic;font-size:13px;color:rgba(255,255,255,.7);letter-spacing:.06em;text-transform:uppercase;margin-bottom:16px}
.astro-swgr__h1{font-family:'Playfair Display',Georgia,serif;font-size:clamp(28px,4vw,46px);line-height:1.15;margin:0 0 20px;color:#fff}
.astro-swgr__lead{font-size:17px;color:rgba(255,255,255,.85);line-height:1.6;margin:0}

/* ── Haupt-Sektion ────────────────────────────────────── */
.astro-swgr__sec{padding:72px 0;background:#f7f3ef;width:100vw;position:relative;left:50%;margin-left:-50vw;margin-right:-50vw}
.astro-swgr__sec-in{max-width:1280px;margin:0 auto;padding:0 32px}

/* ── Karten-Grid (1 + 2 Spalten) ─────────────────────── */
.astro-swgr__grid{display:grid;grid-template-columns:1fr 2fr;gap:28px}
.astro-swgr__card{background:#fff;border-radius:12px;box-shadow:0 2px 16px rgba(30,21,18,.1);overflow:hidden;display:flex;flex-direction:column}
.astro-swgr__card-head{background:#012C7B;padding:22px 24px;display:flex;align-items:center;gap:16px}
.astro-swgr__card-icon{background:rgba(255,255,255,.15);border-radius:8px;width:52px;height:52px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.astro-swgr__card-title{font-family:'Playfair Display',Georgia,serif;font-size:17px;color:#fff;font-weight:700;line-height:1.2;margin-bottom:4px}
.astro-swgr__card-sub{font-size:12px;color:rgba(255,255,255,.7);letter-spacing:.04em}
.astro-swgr__card-body{padding:24px;flex:1;font-size:15px;color:#3d3530;line-height:1.6}

/* ── Vorsitz ──────────────────────────────────────────── */
.astro-swgr__vorsitz{padding:16px 0;border-bottom:1px solid #f0ebe0}
.astro-swgr__vorsitz:last-child{border-bottom:none}
.astro-swgr__vorsitz-label{font-size:11px;text-transform:uppercase;letter-spacing:.08em;color:#012C7B;font-weight:700;margin-bottom:6px}
.astro-swgr__vorsitz-name{font-size:15px;color:#1e1512;line-height:1.6}
.astro-swgr__vorsitz-rolle{font-size:13px;color:#6b5c52}
.astro-swgr__vorsitz-name a{color:#012C7B;text-decoration:none}
.astro-swgr__vorsitz-name a:hover{text-decoration:underline}

/* ── Mitglieder-Tabelle ───────────────────────────────── */
.astro-swgr__table{width:100%;border-collapse:collapse;font-size:14px}
.astro-swgr__table tr{border-bottom:1px solid #f0ebe0}
.astro-swgr__table tr:last-child{border-bottom:none}
.astro-swgr__table td{padding:8px 4px;vertical-align:top}
.astro-swgr__table td:first-child{font-weight:600;white-space:nowrap;padding-right:16px;color:#012C7B;width:44%}

/* ── CTA ──────────────────────────────────────────────── */
.astro-swgr__cta{background:linear-gradient(135deg,#011d52 0%,#012C7B 100%);width:100vw;position:relative;left:50%;margin-left:-50vw;margin-right:-50vw;padding:72px 0;text-align:center}
.astro-swgr__cta-in{max-width:760px;margin:0 auto;padding:0 32px}
.astro-swgr__cta-h2{font-family:'Playfair Display',Georgia,serif;font-size:clamp(26px,3.5vw,40px);color:#fff;margin:0 0 16px;line-height:1.15}
.astro-swgr__cta-p{color:rgba(255,255,255,.82);font-size:17px;margin:0 0 32px;line-height:1.5}
.astro-swgr__cta-btns{display:flex;gap:16px;justify-content:center;flex-wrap:wrap}
.astro-swgr__cta-btn{display:inline-block;background:#fff;color:#012C7B;font-weight:700;font-size:15px;padding:14px 32px;border-radius:999px;text-decoration:none;transition:background .2s}
.astro-swgr__cta-btn:hover{background:#f0ebe0}
.astro-swgr__cta-outline{display:inline-block;padding:14px 28px;border-radius:999px;border:2px solid rgba(255,255,255,.5);color:#fff;text-decoration:none;font-weight:600;font-size:15px;transition:all .2s}
.astro-swgr__cta-outline:hover{border-color:#fff;background:rgba(255,255,255,.1)}

/* ── Responsive ───────────────────────────────────────── */
@media(max-width:860px){.astro-swgr__grid{grid-template-columns:1fr}}
@media(max-width:640px){
  .astro-swgr__intro{padding:100px 16px 48px}
  .astro-swgr__sec-in{padding:0 16px}
  .astro-swgr__cta-in{padding:0 16px}
}
</style>
