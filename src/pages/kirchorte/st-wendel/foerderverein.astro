---
// Förderverein St. Wendel-Gemeinde e.V. (WP-Draft ID 49295, /kirchorte/st-wendel/foerderverein/)
// Primärfarbe Dunkelblau #012C7B. Eigene Klassen astro-swfv*.
import Base from '../../../layouts/Base.astro';

const seo = {
  title: 'Förderverein St. Wendel-Gemeinde e.V. – Kirchort der Pfarrei Sankt Bonifatius Frankfurt',
  description: 'Seit 2006 unterstützt der Förderverein St. Wendel-Gemeinde e.V. das Gemeindeleben in Frankfurt-Sachsenhausen – mit über 70 Mitgliedern und vielen verwirklichten Projekten.',
};
---
<Base seo={seo} title={seo.title}>

  <!-- Hero -->
  <section class="astro-swfv-hero">
    <div class="astro-swfv-hero__in">
      <a class="astro-swfv-back" href="/kirchorte/st-wendel/">&larr; St. Wendel</a>
      <span class="astro-swfv-hero__eyebrow">Kirchort St. Wendel &middot; Frankfurt-Sachsenhausen</span>
      <h1 class="astro-swfv-hero__h1">Förderverein<br>St. Wendel-Gemeinde e.V.</h1>
      <p class="astro-swfv-hero__lead">Gegründet am 17. Januar 2006 &ndash; über 70 Mitglieder stärken das Gemeindeleben mit Herz und Engagement.</p>
    </div>
  </section>

  <!-- Karten: Geschichte, Vorstand, Projekte -->
  <section class="astro-swsec" id="foerderverein">
    <div class="astro-swsec__in">

      <div class="astro-swfv__grid">

        <!-- Geschichte & Zweck -->
        <div class="astro-swfv__card">
          <div class="astro-swfv__card-head">
            <div class="astro-swfv__card-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="28" height="28"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
            </div>
            <div>
              <div class="astro-swfv__card-title">Geschichte &amp; Zweck</div>
              <div class="astro-swfv__card-sub">Gegründet 17. Januar 2006</div>
            </div>
          </div>
          <div class="astro-swfv__card-body">
            <p>Am 17. Januar 2006 gründeten 15 Personen den Verein mit dem Ziel, &bdquo;kirchliche, soziale und religiöse Belange der St. Wendel-Gemeinde zu unterstützen&ldquo; &ndash; als Reaktion auf die Sparmaßnahmen des Bistums Limburg. Heute zählt der Förderverein über 70 Mitglieder. Der Jahresbeitrag beträgt mindestens 25 €.</p>
            <a class="astro-swfv__btn" href="/wp-content/uploads/2025/05/Beitrittserklaerungaktuell.pdf" target="_blank" rel="noopener">Beitrittserklärung (PDF) &rarr;</a>
          </div>
        </div>

        <!-- Vorstand -->
        <div class="astro-swfv__card">
          <div class="astro-swfv__card-head">
            <div class="astro-swfv__card-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="28" height="28"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
            </div>
            <div>
              <div class="astro-swfv__card-title">Vorstand</div>
              <div class="astro-swfv__card-sub">Gewählt März 2026 &middot; 2 Jahre</div>
            </div>
          </div>
          <div class="astro-swfv__card-body">
            <table class="astro-swfv__table">
              <tr>
                <td>Reinhard Bok</td>
                <td>Vorsitzender &middot; <a href="mailto:Reinhard.Bok@web.de">Reinhard.Bok@web.de</a></td>
              </tr>
              <tr>
                <td>Ann-Kristin Schäfer</td>
                <td>Stellv. Vorsitzende &middot; <a href="mailto:Ann-Kristin.Schaefer@t-online.de">Ann-Kristin.Schaefer@t-online.de</a></td>
              </tr>
              <tr>
                <td>Monika Laier</td>
                <td>Schriftführerin</td>
              </tr>
              <tr>
                <td>Andreas Klüber</td>
                <td>Kassenführer</td>
              </tr>
            </table>
          </div>
        </div>

        <!-- Projekte -->
        <div class="astro-swfv__card">
          <div class="astro-swfv__card-head">
            <div class="astro-swfv__card-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="28" height="28"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
            </div>
            <div>
              <div class="astro-swfv__card-title">Projekte seit 2007</div>
              <div class="astro-swfv__card-sub">Auswahl geförderter Vorhaben</div>
            </div>
          </div>
          <div class="astro-swfv__card-body">
            <ul class="astro-swfv__list">
              <li>Glasfenster in der Taufkapelle</li>
              <li>Keyboard für Kinder- und Jugendgottesdienste</li>
              <li>Elektronische Setzeranlage für die Orgel</li>
              <li>Kirchweihkonzerte (seit 2012)</li>
              <li>Zelte für das Jugendzeltlager (2018)</li>
              <li>Rollladen für die Bücherei (2020)</li>
              <li>Erweiterung der Kirchenorgel</li>
              <li>Neue Kinderecke in der Kirche</li>
              <li>Nachmittagsbetreuung für Schulkinder (Kooperation Mühlbergschule)</li>
              <li>Unterstützung der Erstkommunionfeier</li>
            </ul>
          </div>
        </div>

      </div>

      <!-- Mitglied werden / Spendenkonto -->
      <div class="astro-swfv__spenden">
        <div class="astro-swfv__spenden-text">
          <h2 class="astro-swfv__spenden-h2">Mitglied werden &amp; Spenden</h2>
          <p>Unterstützen Sie die Gemeinde als Mitglied oder mit einer Spende. Jeder Beitrag hilft, wichtige Projekte in St. Wendel zu ermöglichen. Der Jahresbeitrag beträgt mindestens 25 €.</p>
          <a class="astro-swfv__spenden-btn" href="/wp-content/uploads/2025/05/Beitrittserklaerungaktuell.pdf" target="_blank" rel="noopener">Beitrittserklärung (PDF) &rarr;</a>
        </div>
        <div class="astro-swfv__konto">
          <div class="astro-swfv__konto-label">Spendenkonto</div>
          <div class="astro-swfv__konto-row"><span>Kontoinhaber</span><span>Förderverein St. Wendel-Gemeinde Frankfurt e.V.</span></div>
          <div class="astro-swfv__konto-row"><span>IBAN</span><span>DE09 5005 0201 0200 2691 86</span></div>
          <div class="astro-swfv__konto-row"><span>BIC</span><span>HELADEF1822</span></div>
          <div class="astro-swfv__konto-row"><span>Bank</span><span>Frankfurter Sparkasse</span></div>
        </div>
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="astro-swcta">
    <div class="astro-swcta__in">
      <h2 class="astro-swcta__h2">Fragen zum Förderverein?</h2>
      <p class="astro-swcta__p">Sprechen Sie den Vorstand gerne direkt an oder wenden Sie sich ans Pfarrbüro.</p>
      <div class="astro-swfv__cta-btns">
        <a class="astro-swfv__cta-outline" href="/kirchorte/st-wendel/">&larr; Zurück zu St. Wendel</a>
        <a class="astro-swcta__btn" href="mailto:Reinhard.Bok@web.de">Vorstand schreiben</a>
      </div>
    </div>
  </section>

</Base>

<style is:global>
/* Hero */
.astro-swfv-hero{background:linear-gradient(160deg,#011d52 0%,#012C7B 60%,#01408c 100%);width:100vw;position:relative;left:50%;margin-left:-50vw;margin-right:-50vw;padding:64px 0 72px;text-align:center;color:#fff}
.astro-swfv-hero__in{max-width:800px;margin:0 auto;padding:0 32px}
.astro-swfv-back{display:inline-block;color:rgba(255,255,255,.7);text-decoration:none;font-size:14px;margin-bottom:24px;letter-spacing:.04em}
.astro-swfv-back:hover{color:#fff}
.astro-swfv-hero__eyebrow{display:block;font-family:'Playfair Display',Georgia,serif;font-style:italic;font-size:13px;color:rgba(255,255,255,.7);letter-spacing:.06em;text-transform:uppercase;margin-bottom:16px}
.astro-swfv-hero__h1{font-family:'Playfair Display',Georgia,serif;font-size:clamp(32px,5vw,52px);line-height:1.1;margin:0 0 20px;color:#fff}
.astro-swfv-hero__lead{font-size:17px;color:rgba(255,255,255,.85);line-height:1.6;margin:0}

/* Karten-Grid */
.astro-swfv__grid{display:grid;grid-template-columns:repeat(3,1fr);gap:28px;margin-bottom:56px}
.astro-swfv__card{background:#fff;border-radius:12px;box-shadow:0 2px 16px rgba(30,21,18,.1);overflow:hidden;display:flex;flex-direction:column}
.astro-swfv__card-head{background:#012C7B;padding:22px 24px;display:flex;align-items:center;gap:16px}
.astro-swfv__card-icon{background:rgba(255,255,255,.15);border-radius:8px;width:52px;height:52px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.astro-swfv__card-title{font-family:'Playfair Display',Georgia,serif;font-size:17px;color:#fff;font-weight:700;line-height:1.2;margin-bottom:4px}
.astro-swfv__card-sub{font-size:12px;color:rgba(255,255,255,.7);letter-spacing:.04em}
.astro-swfv__card-body{padding:24px;flex:1;font-size:15px;color:#3d3530;line-height:1.6}
.astro-swfv__btn{display:inline-block;margin-top:16px;padding:10px 20px;border-radius:999px;background:#012C7B;color:#fff;text-decoration:none;font-weight:600;font-size:14px;transition:background .2s}
.astro-swfv__btn:hover{background:#011d52}

/* Tabelle Vorstand */
.astro-swfv__table{width:100%;border-collapse:collapse;font-size:14px}
.astro-swfv__table tr{border-bottom:1px solid #f0ebe0}
.astro-swfv__table tr:last-child{border-bottom:none}
.astro-swfv__table td{padding:8px 4px;vertical-align:top}
.astro-swfv__table td:first-child{font-weight:600;white-space:nowrap;padding-right:12px;color:#012C7B}
.astro-swfv__table a{color:#012C7B;text-decoration:none}
.astro-swfv__table a:hover{text-decoration:underline}

/* Liste Projekte */
.astro-swfv__list{margin:0;padding:0 0 0 18px;list-style:disc}
.astro-swfv__list li{padding:4px 0;font-size:14px;color:#3d3530}

/* Spenden-Box */
.astro-swfv__spenden{background:#012C7B;border-radius:14px;padding:48px;display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:start;color:#fff}
.astro-swfv__spenden-h2{font-family:'Playfair Display',Georgia,serif;font-size:26px;color:#fff;margin:0 0 14px;line-height:1.2}
.astro-swfv__spenden p{color:rgba(255,255,255,.85);font-size:15px;line-height:1.6;margin:0 0 20px}
.astro-swfv__spenden-btn{display:inline-flex;align-items:center;padding:12px 24px;border-radius:999px;background:#fff;color:#012C7B;text-decoration:none;font-weight:600;font-size:14px;transition:background .2s}
.astro-swfv__spenden-btn:hover{background:#f0ebe0}
.astro-swfv__konto{background:rgba(255,255,255,.12);border-radius:10px;padding:24px}
.astro-swfv__konto-label{font-weight:700;font-size:13px;text-transform:uppercase;letter-spacing:.06em;color:rgba(255,255,255,.7);margin-bottom:16px}
.astro-swfv__konto-row{display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.15);font-size:14px;gap:12px}
.astro-swfv__konto-row:last-child{border-bottom:none}
.astro-swfv__konto-row span:first-child{color:rgba(255,255,255,.7);flex-shrink:0}
.astro-swfv__konto-row span:last-child{text-align:right}

/* CTA-Buttons */
.astro-swfv__cta-btns{display:flex;gap:16px;justify-content:center;flex-wrap:wrap;margin-top:8px}
.astro-swfv__cta-outline{display:inline-block;padding:14px 28px;border-radius:999px;border:2px solid rgba(255,255,255,.5);color:#fff;text-decoration:none;font-weight:600;font-size:15px;transition:all .2s}
.astro-swfv__cta-outline:hover{border-color:#fff;background:rgba(255,255,255,.1)}

/* Responsive */
@media(max-width:900px){.astro-swfv__grid{grid-template-columns:1fr 1fr}}
@media(max-width:700px){.astro-swfv__grid{grid-template-columns:1fr}.astro-swfv__spenden{grid-template-columns:1fr;padding:32px 24px;gap:28px}}
@media(max-width:480px){.astro-swfv-hero__in{padding:0 16px}.astro-swfv__spenden{padding:24px 16px}}
</style>
