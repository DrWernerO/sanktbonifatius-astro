---
// Beitrags-Detailseite (eine Route → automatisch je Beitrag eine Seite).
// Aufbau: Bild-Hero (Beitragsbild als Hintergrund + Titel-Overlay) → Beitragstext.
// getStaticPaths() erzeugt beim Build je Beitrag eine Seite; Pflege weiter im WP-Admin.
import Base from '../../layouts/Base.astro';
import { getPosts, getSeoHead } from '../../lib/wordpress.js';

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const seo = await getSeoHead(post.wpPath);

const decode = (s) =>
  (s || '')
    .replace(/&#(\d+);/g, (_, n) => String.fromCharCode(Number(n)))
    .replace(/&#x([0-9a-f]+);/gi, (_, n) => String.fromCharCode(parseInt(n, 16)))
    .replace(/&amp;/g, '&').replace(/&quot;/g, '"').replace(/&#0?39;/g, "'")
    .replace(/&lt;/g, '<').replace(/&gt;/g, '>').replace(/&nbsp;/g, ' ');

const title = decode(post.title);
const dateStr = new Date(post.date).toLocaleDateString('de-DE', { day: 'numeric', month: 'long', year: 'numeric' });
const heroStyle = post.image ? `background-image:url('${post.image}')` : '';
---
<Base seo={seo} title={title}>
  <header class={`astro-post-hero${post.image ? '' : ' astro-post-hero--plain'}`} style={heroStyle}>
    <div class="astro-post-hero__inner">
      <p class="astro-post-hero__eyebrow">{dateStr}</p>
      <h1 class="astro-post-hero__title">{title}</h1>
    </div>
  </header>

  <section class="astro-post">
    <div class="astro-post__inner">
      <article class="astro-post__content" set:html={post.content} />
      <a href="/boniblog/" class="astro-post__back">← Zurück zum BoniBlog</a>
    </div>
  </section>
</Base>

<style is:global>
.astro-post-hero{position:relative;width:100vw;left:50%;margin-left:-50vw;margin-right:-50vw;
  min-height:460px;display:flex;align-items:flex-end;background-size:cover;background-position:center;background-color:#2c1a12}
.astro-post-hero::after{content:'';position:absolute;inset:0;
  background:linear-gradient(to top,rgba(20,15,12,.88) 0%,rgba(20,15,12,.4) 50%,rgba(20,15,12,.2) 100%)}
.astro-post-hero--plain{background:linear-gradient(135deg,#2c1a12 0%,#4a2620 55%,#6b2e2a 100%)}
.astro-post-hero--plain::after{display:none}
.astro-post-hero__inner{position:relative;z-index:1;width:100%;max-width:1100px;margin:0 auto;padding:120px 40px 44px;color:#fff}
.astro-post-hero__eyebrow{font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:#c5a55a;margin:0 0 12px}
.astro-post-hero__title{font-family:'Playfair Display',serif;font-weight:700;line-height:1.1;color:#fff;
  font-size:clamp(32px,4.6vw,56px);margin:0;max-width:900px;text-shadow:0 2px 24px rgba(0,0,0,.35)}
.astro-post{background:#fff;padding:48px 0 64px}
.astro-post__inner{max-width:760px;margin:0 auto;padding:0 24px}
.astro-post__content{font-size:17px;line-height:1.75;color:#3a3228}
.astro-post__content > *:first-child{margin-top:0}
.astro-post__content p{margin:0 0 18px}
.astro-post__content h2{font-family:'Playfair Display',serif;font-size:26px;font-weight:700;color:#2c2420;line-height:1.25;margin:36px 0 14px}
.astro-post__content h3{font-family:'Playfair Display',serif;font-size:21px;font-weight:700;color:#2c2420;margin:28px 0 12px}
.astro-post__content a{color:#9a2d2d;text-decoration:underline;text-underline-offset:2px}
.astro-post__content a:hover{color:#7e2424}
.astro-post__content ul,.astro-post__content ol{margin:0 0 18px;padding-left:24px}
.astro-post__content li{margin:0 0 8px}
.astro-post__content img{max-width:100%;height:auto;border-radius:8px;margin:24px 0}
.astro-post__content blockquote{margin:24px 0;padding:8px 0 8px 20px;border-left:3px solid #c5a55a;color:#6b5c52;font-style:italic}
.astro-post__content figure{margin:24px 0}
.astro-post__content figcaption{font-size:13px;color:#928269;margin-top:8px;text-align:center}
.astro-post__back{display:inline-block;margin-top:40px;font-size:14px;font-weight:600;color:#9a2d2d}
.astro-post__back:hover{color:#7e2424}
@media(max-width:600px){
  .astro-post-hero{min-height:340px}
  .astro-post-hero__inner{padding:100px 20px 32px}
}
</style>
