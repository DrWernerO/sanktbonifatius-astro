import EkGalerie from '../../components/EkGalerie.astro';
import EkAnmeldung from '../../components/EkAnmeldung.astro';
import EkFaq from '../../components/EkFaq.astro';
import EkCta from '../../components/EkCta.astro';
import { getSeoHead } from '../../lib/wordpress.js';

const seo = await getSeoHead('/segen-sakramente/erstkommunion/');
---
<Base seo={seo} title="Erstkommunion in Frankfurt – St. Bonifatius">
  <EkHero />
  <EkIntro />
  <EkVorbereitung />
