---
// Seite „Impressum" — WP-Seite 49117 (/impressum/), vollständig aus eigenen astro-Komponenten
// (kein set:html mit WP-Markup, vgl. Migrationsplan Abschnitt 9b). Nav + Footer kommen global
// aus Base.astro (Handbuch Abschnitt 4b) — hier NICHT erneut einbinden. Der Footer verlinkt
// bereits auf /impressum/ (Footer.astro). Spätere eRecht24-Anbindung erfolgt separat über Netlify.
import Base from '../layouts/Base.astro';
import ImpressumHero from '../components/ImpressumHero.astro';
import ImpressumBody from '../components/ImpressumBody.astro';
import ImpressumCta from '../components/ImpressumCta.astro';
import { getSeoHead } from '../lib/wordpress.js';

// SEO (Titel/Description/OG) aus der mit SEOPress optimierten WP-Seite übernehmen.
const seo = await getSeoHead('/impressum/');
---
<Base seo={seo} title="Impressum – Pfarrei Sankt Bonifatius Frankfurt">
  <ImpressumHero />
  <ImpressumBody />
  <ImpressumCta />
</Base>
