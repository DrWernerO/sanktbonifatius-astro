---
// Seite „Beratung und Hilfe" — WP-Seite 48312 (/kontakt/beratung-und-hilfe/), vollständig aus
// eigenen astro-Komponenten (Handbuch 9b/11). Nav + Footer global aus Base.astro (4b) — hier
// NICHT erneut einbinden. Bänder-Prinzip: dunkler Hero → Bordeaux-Notfallbanner → Crème
// Angebote → weiße Ansprechpersonen → Crème externe Stellen → weißer Schutz → dunkler CTA.
// Würdevoller, ruhiger Ton (sensibles Thema). Eigener CSS-Präfix `astro-ber`.
// SEO-Head live aus WordPress via getSeoHead (macht intern einen Netz-Call — nur im echten
// Build/Dev relevant; bei WP-Ausfall liefert getSeoHead leeren String, Base nutzt Fallback).
import Base from '../../layouts/Base.astro';
import BeratungHero from '../../components/BeratungHero.astro';
import BeratungNotfall from '../../components/BeratungNotfall.astro';
import BeratungCards from '../../components/BeratungCards.astro';
import BeratungTeam from '../../components/BeratungTeam.astro';
import BeratungExtern from '../../components/BeratungExtern.astro';
import BeratungSchutz from '../../components/BeratungSchutz.astro';
import BeratungCta from '../../components/BeratungCta.astro';
import { getSeoHead } from '../../lib/wordpress.js';

const seo = await getSeoHead('/kontakt/beratung-und-hilfe/');
---
<Base seo={seo} title="Beratung und Hilfe">
  <BeratungHero />
  <BeratungNotfall />
  <BeratungCards />
  <BeratungTeam />
  <BeratungExtern />
  <BeratungSchutz />
  <BeratungCta />
</Base>
