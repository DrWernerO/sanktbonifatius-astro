    opts: [
      {
        title: 'Pfarrgemeinderat, Verwaltungsrat, Kirchort-R&auml;te',
        text: 'Mitdenken und mitentscheiden: &uuml;ber Geb&auml;ude, Kita-Konzepte und nachhaltige Investitionen.',
        quote: 'Ich will, dass mein Know-how nicht nur meiner Firma, sondern auch der Gesellschaft dient.',
      },
    ],
    href: '/ueberuns/leitung/',
    linkText: 'Mehr &uuml;ber Mitgestaltung &#8594;',
  },
  {
    // Noten-/Musik-Icon
    icon: '<path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>',
