      {
        title: 'Fiat Lux, BonEsprit oder Taiz&eacute;',
        text: 'Kreative Gestaltung, Musik, Lesung, Begleitung &#8211; jedes Format hat seinen eigenen Stil und braucht engagierte Menschen.',
        quote: 'Die Mitarbeit im Fiat-Lux-Team ist f&uuml;r mich eine pers&ouml;nliche Bereicherung und ich genie&szlig;e einfach diese sch&ouml;nen Gottesdienste.',
      },
    ],
    href: '/gottesdienst-glaube/gottesdienste-die-beruehren/',
    linkText: 'Mehr &uuml;ber unsere Gottesdienst-Formate &#8594;',
  },
  {
    // Familien-/Personen-Icon
    icon: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
    title: 'BonFamily &amp; Familien',
    lead: 'Bei BonFamily dabei sein &#8211; unserem bunten Programm rund um kreative Gottesdienste, Kinderprojekte und Eltern-Treffpunkte. F&uuml;r alle, die sich f&uuml;r Kinder und Familien stark machen wollen.',
    opts: [
      {
        title: 'Kreativgottesdienste, Kinderprojekte, Eltern-Treffpunkte',
        text: 'Ideen einbringen, mitgestalten, begleiten &#8211; f&uuml;r Kinder jeden Alters und ihre Familien.',
        quote: 'Ich bringe meine Ideen ins Kreativgottesdienst-Team ein &#8211; und sehe, wie Kinderaugen leuchten.',
      },
    ],
    href: '/bonfamily/',
    linkText: 'Mehr &uuml;ber BonFamily &#8594;',
  },
  {
    // Herz-Icon
    icon: '<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>',
    title: 'Soziales Engagement',
    lead: 'Menschen in schwierigen Lebenslagen begleiten, unterst&uuml;tzen, beistehen &#8211; mit Zeit, Herz und deinen pers&ouml;nlichen F&auml;higkeiten.',
    opts: [
      {
        title: 'Nachbarschafts-Hilfsnetz',
        text: '&Auml;ltere oder eingeschr&auml;nkte Menschen im Alltag unterst&uuml;tzen &#8211; mit Zeit, Herz und einer Portion Pragmatismus.',
