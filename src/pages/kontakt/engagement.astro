---
// Seite „Engagement" — WP-Seite 48449 (/kontakt/engagement/), vollständig aus eigenen
// astro-Komponenten (kein set:html mit WP-Markup, vgl. Handbuch 14). Nav + Footer kommen global
// aus Base.astro (Handbuch Abschnitt 4b) — hier NICHT erneut einbinden. SEO live aus WP (SEOPress).
//
// Liegt in src/pages/kontakt/ → koexistiert mit der bestehenden src/pages/kontakt.astro.
// Relative Import-Pfade ../../ wegen Unterordner.
//
// Farbwelt: WP-Türkis wurde bewusst NICHT übernommen, sondern in die warme Astro-Welt
// (Bordeaux #9a2d2d / Gold #c5a55a) überführt — konsistent mit den übrigen Seiten.
//
// Interne Links aus dem WP-Content auf saubere Astro-Pfade übernommen. Einige Ziele sind in
// Astro noch NICHT gebaut (siehe Bericht/Handbuch 12) — hrefs zeigen schon auf die künftigen Pfade.
import Base from '../../layouts/Base.astro';
import EngagementHero from '../../components/EngagementHero.astro';
import EngagementStrip from '../../components/EngagementStrip.astro';
import EngagementIntro from '../../components/EngagementIntro.astro';
import EngagementTiles from '../../components/EngagementTiles.astro';
import EngagementSteps from '../../components/EngagementSteps.astro';
import EngagementCta from '../../components/EngagementCta.astro';
import { getSeoHead } from '../../lib/wordpress.js';

const seo = await getSeoHead('/kontakt/engagement/');

// „Konkret & nahbar — was du tun kannst" — 6 Engagement-Bereiche (1:1 aus WP-Seite 48449)
const cards = [
  {
    // Notenblatt-Icon
    icon: '<path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>',
    title: 'Gottesdienst-Teams',
    lead: 'Mitarbeit in einem unserer Gottesdienst-Teams &#8211; eine tolle M&ouml;glichkeit, sich kreativ einzubringen und dabei den eigenen Glauben und das theologische Wissen zu vertiefen.',
