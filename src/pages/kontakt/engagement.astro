      {
        title: 'Kirchench&ouml;re',
        text: 'Kinderchor, Jugendchor, Gospelchor &#8211; einfach mitsingen und Teil etwas Sch&ouml;nem sein.',
        quote: 'Die Auftritte mit dem Chor sind f&uuml;r mich immer etwas ganz Besonderes.',
      },
      {
        title: 'Konzerte &amp; Kulturveranstaltungen',
        text: 'Mitwirken als Musiker:in, Techniker:in oder Organisationstalent &#8211; das kulturelle Leben der Pfarrei mitpr&auml;gen.',
        quote: 'Musik ist mein Ausgleich &#8211; hier teile ich sie mit anderen.',
      },
    ],
    href: '/kultur-begegnung/',
    linkText: 'Mehr &uuml;ber Musik &amp; Kultur &#8594;',
  },
];
---
<Base seo={seo}>
  <EngagementHero />
  <EngagementStrip />
  <EngagementIntro />
  <EngagementTiles
    eyebrow="Deine Möglichkeiten"
    heading="Konkret &amp; nahbar &#8211; was du tun kannst"
    cards={cards}
  />
  <EngagementSteps />
  <EngagementCta />
</Base>
