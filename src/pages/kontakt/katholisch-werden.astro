---
// Seite „Katholisch werden" — WP-Seite 48544 (/kontakt/katholisch-werden/), vollständig aus eigenen
// astro-Komponenten (kein set:html mit WP-Markup, vgl. Handbuch 14). Nav + Footer kommen global
// aus Base.astro (Handbuch Abschnitt 4b) — hier NICHT erneut einbinden. SEO live aus WP (SEOPress).
//
// Liegt in src/pages/kontakt/ → koexistiert mit der bestehenden src/pages/kontakt.astro.
// Relative Import-Pfade ../../ wegen Unterordner. Prefix `astro-kw` (WP-Klassen `kw-…` tabu, Regel 3).
import Base from '../../layouts/Base.astro';
import KwHero from '../../components/KwHero.astro';
import KwStrip from '../../components/KwStrip.astro';
import KwTaufe from '../../components/KwTaufe.astro';
import KwWege from '../../components/KwWege.astro';
import KwFaq from '../../components/KwFaq.astro';
import KwCta from '../../components/KwCta.astro';
import { getSeoHead } from '../../lib/wordpress.js';

const seo = await getSeoHead('/kontakt/katholisch-werden/');
---
<Base seo={seo} title="Katholisch werden – St. Bonifatius Frankfurt">
  <KwHero />
  <KwStrip />
  <KwTaufe />
  <KwWege />
  <KwFaq />
  <KwCta />
</Base>
