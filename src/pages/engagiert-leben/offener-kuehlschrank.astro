---
// Unterseite „Offener Kühlschrank" — WP-Seite 49123 (/engagiert-leben/offener-kuehlschrank/),
// vollständig aus eigenen Astro-Komponenten (kein set:html mit WP-Markup, vgl. Handbuch 9b/16).
// Nav + Footer global aus Base.astro (Handbuch 4b). Inhalte fest; nur SEO-Head live aus WP (SEOPress)
// via getSeoHead. Eigenes CSS-Präfix `astro-ok…` (WP nutzt `ok-` → tabu, goldene Regel Handbuch 3).
import Base from '../../layouts/Base.astro';            // ACHTUNG: zwei Ebenen hoch
import { getSeoHead } from '../../lib/wordpress.js';
import OkHero from '../../components/OkHero.astro';
import OkLead from '../../components/OkLead.astro';
import OkIntro from '../../components/OkIntro.astro';
import OkCards from '../../components/OkCards.astro';
import OkBg from '../../components/OkBg.astro';
import OkStandort from '../../components/OkStandort.astro';
import OkFaq from '../../components/OkFaq.astro';
import OkCta from '../../components/OkCta.astro';

const seo = await getSeoHead('/engagiert-leben/offener-kuehlschrank/');
---
<Base seo={seo} title="Offener Kühlschrank Frankfurt-Sachsenhausen – Lebensmittel teilen · St. Bonifatius">
  <OkHero />
  <OkLead />
  <OkIntro />
  <OkCards />
  <OkBg />
  <OkStandort />
  <OkFaq />
  <OkCta />
</Base>

<style is:global>
/* Anker-Versatz: fixierte Nav (80px) verdeckt sonst den Sprung-Anker */
#standort,
#mitmachen { scroll-margin-top: 96px; }
</style>
